<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – ACI Project System</title>

    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<!-- ─── Top Navbar ─────────────────────────────────────── -->
<nav class="navbar navbar-expand-lg navbar-dark bg-primary fixed-top aci-topbar">
    <div class="container-fluid">
        <!-- Sidebar Toggle -->
        <button class="btn btn-link text-white me-2" id="sidebarToggle">
            <i class="bi bi-list fs-5"></i>
        </button>

        <!-- Logo -->
        <a class="navbar-brand fw-bold" asp-page="/Index">
            <i class="bi bi-building me-1"></i>ACI
        </a>

        <!-- Project Selector (현재 프로젝트) -->
        @if (ViewData["CurrentProjectId"] != null)
        {
            <span class="navbar-text text-white-50 ms-2 small d-none d-md-inline">
                <i class="bi bi-folder2-open me-1"></i>@ViewData["CurrentProjectName"]
            </span>
        }

        <div class="ms-auto d-flex align-items-center gap-2">
            <!-- Notifications -->
            <button class="btn btn-link text-white position-relative">
                <i class="bi bi-bell fs-5"></i>
            </button>

            <!-- User Menu -->
            <div class="dropdown">
                <button class="btn btn-link text-white dropdown-toggle" data-bs-toggle="dropdown">
                    <i class="bi bi-person-circle me-1"></i>
                    <span class="d-none d-md-inline">@User.Identity?.Name?.Split('@')[0]</span>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li><a class="dropdown-item" asp-page="/Account/Profile"><i class="bi bi-person me-2"></i>Profile</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <form asp-page="/Account/Logout" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="dropdown-item text-danger">
                                <i class="bi bi-box-arrow-right me-2"></i>Logout
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</nav>

<!-- ─── Sidebar ────────────────────────────────────────── -->
<div id="sidebar" class="aci-sidebar">
    <div class="sidebar-section">
        <div class="sidebar-section-title">PORTFOLIO</div>
        <a class="sidebar-link @(ViewData["ActiveMenu"]?.ToString() == "dashboard" ? "active" : "")" asp-page="/Index">
            <i class="bi bi-grid-1x2"></i><span>Dashboard</span>
        </a>
        <a class="sidebar-link @(ViewData["ActiveMenu"]?.ToString() == "projects" ? "active" : "")" asp-page="/Projects/Index">
            <i class="bi bi-folder2"></i><span>Projects</span>
        </a>
    </div>

    @if (ViewData["CurrentProjectId"] != null)
    {
        var pid = ViewData["CurrentProjectId"];
        <div class="sidebar-section">
            <div class="sidebar-section-title">SCHEDULING</div>
            <a class="sidebar-link @(ViewData["ActiveMenu"]?.ToString() == "schedule" ? "active" : "")"
               asp-page="/Schedule/Index" asp-route-projectId="@pid">
                <i class="bi bi-bar-chart-steps"></i><span>Baseline Schedule</span>
            </a>
            <a class="sidebar-link @(ViewData["ActiveMenu"]?.ToString() == "progress" ? "active" : "")"
               asp-page="/Progress/Index" asp-route-projectId="@pid">
                <i class="bi bi-bar-chart-line"></i><span>Current Schedule</span>
            </a>
            <a class="sidebar-link @(ViewData["ActiveMenu"]?.ToString() == "revisions" ? "active" : "")"
               asp-page="/Progress/Revisions" asp-route-projectId="@pid">
                <i class="bi bi-clock-history"></i><span>Change Log</span>
            </a>
            <a class="sidebar-link @(ViewData["ActiveMenu"]?.ToString() == "comparison" ? "active" : "")"
               asp-page="/Progress/Comparison" asp-route-projectId="@pid">
                <i class="bi bi-layout-split"></i><span>Schedule Comparison</span>
            </a>
        </div>
        <div class="sidebar-section">
            <div class="sidebar-section-title">BASELINES</div>
            <a class="sidebar-link @(ViewData["ActiveMenu"]?.ToString() == "baselines" ? "active" : "")"
               asp-page="/Baselines/Index" asp-route-projectId="@pid">
                <i class="bi bi-shield-lock"></i><span>Baseline Versions</span>
            </a>
            <a class="sidebar-link @(ViewData["ActiveMenu"]?.ToString() == "simulations" ? "active" : "")"
               asp-page="/Simulations/Index" asp-route-projectId="@pid">
                <i class="bi bi-lightning"></i><span>What-If Scenarios</span>
            </a>
        </div>
        <div class="sidebar-section">
            <div class="sidebar-section-title">PLANNING</div>
            <a class="sidebar-link @(ViewData["ActiveMenu"]?.ToString() == "lookahead" ? "active" : "")"
               asp-page="/Lookahead/Index" asp-route-projectId="@pid">
                <i class="bi bi-calendar3-range"></i><span>Lookahead</span>
            </a>
            <a class="sidebar-link @(ViewData["ActiveMenu"]?.ToString() == "weekly" ? "active" : "")"
               asp-page="/WeeklyPlan/Index" asp-route-projectId="@pid">
                <i class="bi bi-calendar-week"></i><span>Weekly Work Plan</span>
            </a>
        </div>
        <div class="sidebar-section">
            <div class="sidebar-section-title">ANALYTICS</div>
            <a class="sidebar-link @(ViewData["ActiveMenu"]?.ToString() == "analytics" ? "active" : "")"
               asp-page="/Analytics/Index" asp-route-projectId="@pid">
                <i class="bi bi-graph-up-arrow"></i><span>Reports & Analytics</span>
            </a>
        </div>
    }

    @*
        권한 원칙:
        - Admin       : 시스템 전체 관리자 (HR/Project 모든 영역 포함)
        - HrAdmin     : HR 민감 데이터(AdminDetail) 및 Role 부여
        - HrManager   : HrUser 이상 (현재는 enum만, 정책 로직은 추후 확장)
        - HrUser      : HR 기본 조회 및 Detail 편집
        - LsProjAdmin : Lump Sum 프로젝트 마스터 편집 (Trades & Subs 등)
        - JocProjAdmin: JOC 프로젝트 마스터 편집 (Trades & Subs 등)
        메뉴는 정책 체크와 일치해야 하므로, 보유 권한이 있는 사용자에게만 해당 섹션을 노출.
        단, Trades & Subs는 조회가 전체 허용이므로 인증된 모든 사용자에게 노출.
    *@
    @{
        var isAdmin         = User.IsInRole("Admin");
        var isHrAdmin       = isAdmin || User.IsInRole("HrAdmin");            // Admin ⊇ HrAdmin
        var isHr            = isHrAdmin
                              || User.IsInRole("HrManager")
                              || User.IsInRole("HrUser");                     // HR 폴더 전체 접근
        var isProjectAdmin  = isAdmin
                              || User.IsInRole("LsProjAdmin")
                              || User.IsInRole("JocProjAdmin");
        var isSafetyUser    = isAdmin || User.IsInRole("SafetyAdmin")
                              || User.IsInRole("SafetyManager")
                              || User.IsInRole("SafetyUser");
        var isSafetyManager = isAdmin || User.IsInRole("SafetyAdmin")
                              || User.IsInRole("SafetyManager");
        var isSafetyAdmin   = isAdmin || User.IsInRole("SafetyAdmin");
        // Settings 메뉴: SafetyManager+ 또는 담당 프로젝트가 있는 현장 인력
        var canSeeSettings  = isSafetyManager
                              || User.IsInRole("Superintendent")
                              || User.IsInRole("ProjectManager");
    }

    @* ─── 프로젝트 마스터 (인증된 모든 사용자 조회 가능) ────────────── *@
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="sidebar-section">
            <div class="sidebar-section-title">MASTER DATA</div>
            <a class="sidebar-link @(ViewData["ActiveMenu"]?.ToString() == "trades" ? "active" : "")"
               asp-page="/Trades/Index">
                <i class="bi bi-tools"></i><span>Trades &amp; Subs</span>
                @if (!isProjectAdmin)
                {
                    <i class="bi bi-eye ms-1 small text-muted" title="Read-only"></i>
                }
            </a>
        </div>
    }

    @* ─── Safety 영역 (SafetyUser / SafetyManager / SafetyAdmin / Admin) ── *@
    @if (isSafetyUser)
    {
        <div class="sidebar-section">
            <div class="sidebar-section-title" style="color:#fd7e14;">SAFETY</div>
            <a class="sidebar-link @(ViewData["ActiveMenu"]?.ToString() == "safety-reports" ? "active" : "")"
               asp-page="/Safety/Reports">
                <i class="bi bi-shield-exclamation" style="color:#fd7e14;"></i><span>Weekly Reports</span>
            </a>
            <a class="sidebar-link @(ViewData["ActiveMenu"]?.ToString() == "safety-mine" ? "active" : "")"
               asp-page="/Safety/MyReports">
                <i class="bi bi-clipboard2-check"></i><span>My Projects</span>
            </a>
            @if (canSeeSettings)
            {
                <a class="sidebar-link @(ViewData["ActiveMenu"]?.ToString() == "safety-settings" ? "active" : "")"
                   asp-page="/Safety/Settings">
                    <i class="bi bi-gear"></i><span>Report Settings</span>
                </a>
            }
        </div>
    }

    @* ─── HR 영역 (HrUser / HrManager / HrAdmin / Admin) ─────────────── *@
    @if (isHr)
    {
        <div class="sidebar-section">
            <div class="sidebar-section-title" style="color:@(isHrAdmin ? "#dc3545" : "#6c757d");">
                HR@(isHrAdmin ? " ADMIN" : "")
            </div>
            <a class="sidebar-link @(ViewData["ActiveMenu"]?.ToString() == "employees" ? "active" : "")"
               asp-page="/Hr/Employees/Index">
                <i class="bi bi-people @(isHrAdmin ? "text-danger" : "")"></i><span>Employees</span>
            </a>
            <a class="sidebar-link @(ViewData["ActiveMenu"]?.ToString() == "orgunits" ? "active" : "")"
               asp-page="/Hr/OrgUnits/Index">
                <i class="bi bi-diagram-3"></i><span>Org Units</span>
            </a>
            <a class="sidebar-link @(ViewData["ActiveMenu"]?.ToString() == "jobpositions" ? "active" : "")"
               asp-page="/Hr/JobPositions/Index">
                <i class="bi bi-person-badge"></i><span>Job Positions</span>
            </a>
            <a class="sidebar-link @(ViewData["ActiveMenu"]?.ToString() == "users" ? "active" : "")"
               asp-page="/Hr/Users/Index">
                <i class="bi bi-person-gear"></i><span>Users</span>
            </a>
        </div>
    }

    @* ─── 시스템 관리 영역 (Admin 전용) ──────────────────── *@
    @if (isAdmin)
    {
        <div class="sidebar-section">
            <div class="sidebar-section-title" style="color:#6f42c1;">SYSTEM ADMIN</div>
            <a class="sidebar-link @(ViewData["ActiveMenu"]?.ToString() == "privileges" ? "active" : "")"
               asp-page="/SystemAdmin/Privileges/Index">
                <i class="bi bi-key" style="color:#6f42c1;"></i><span>Privileges</span>
            </a>
            @* 향후 Audit Log / Email 설정 등 배치 예정 *@
        </div>
    }
</div>

<!-- ─── Main Content ───────────────────────────────────── -->
<div id="mainContent" class="aci-main-content">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mx-3 mt-2 mb-0" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mx-3 mt-2 mb-0" role="alert">
            <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @RenderBody()
</div>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<!-- HTMX -->
<script src="https://unpkg.com/htmx.org@1.9.10"></script>
<!-- ApexCharts -->
<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>

<script src="~/js/site.js" asp-append-version="true"></script>

@* SVAR React Gantt 번들 — gantt 페이지에서만 로드 *@
@if (ViewData["LoadGanttBundle"] as bool? == true)
{
    <script src="~/gantt-dist/gantt-bundle.js" asp-append-version="true"></script>
}

@await RenderSectionAsync("Scripts", required: false)

@* ── 전역 확인 모달 (모든 페이지에서 confirmAction / confirmAsync 사용 가능) ── *@
<div class="modal fade" id="aci-confirm-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-semibold" id="aci-confirm-title"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="aci-confirm-body"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="aci-confirm-ok">Confirm</button>
            </div>
        </div>
    </div>
</div>
</body>
</html>
