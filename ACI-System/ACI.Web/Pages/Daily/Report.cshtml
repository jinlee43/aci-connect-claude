@page
@using ACI.Web.Data.Entities
@model ACI.Web.Pages.Daily.ReportModel
@{
    Layout = Model.Modal
        ? "~/Pages/Shared/_ModalLayout.cshtml"
        : "~/Pages/Shared/_Layout.cshtml";

    var r        = Model.Report;
    var isLocked = r?.IsLocked ?? false;
    var isNew    = r == null;
    var status   = r?.Status ?? DailyReportStatus.Draft;
    var pid      = Model.ProjectId ?? r?.ProjectId ?? 0;
    var dateStr  = r?.ReportDate.ToString("yyyy-MM-dd")
               ?? Model.Date
               ?? DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd");

    ViewData["Title"]      = isNew ? "New Daily Report" : $"Daily Report #{r!.ReportNumber}";
    ViewData["ActiveMenu"] = "daily-reports";

    // Work Performed Trade 목록 — 프로젝트 Trade + 표준 간접작업 (template 포함 전체 scope)
    var stdTrades = new[]{ "Supervision","Site Safety","Inspection","Cleanup","Material Handling","Layout / Survey","General Labor" };
    var allTrades = Model.Trades.Select(t => t.Name)
                       .Concat(stdTrades.Where(s => !Model.Trades.Any(t => t.Name.Equals(s, StringComparison.OrdinalIgnoreCase))))
                       .ToList();
}

@if (!Model.Modal)
{
    <div class="aci-page-header">
        <div>
            <h1 class="d-flex align-items-center flex-wrap gap-2">
                <span><i class="bi bi-journal-text me-2 text-primary"></i>Daily Report</span>
                @if (!string.IsNullOrEmpty(Model.ProjectCode) || !string.IsNullOrEmpty(Model.ProjectName))
                {
                    <span class="text-muted" style="font-size:.7em; font-weight:500;">
                        <span class="text-primary fw-bold">@Model.ProjectCode</span> — @Model.ProjectName
                        @if (!string.IsNullOrEmpty(Model.PmName))
                        {
                            <span class="ms-1">(<i>@Model.PmName</i>)</span>
                        }
                    </span>
                }
                @if (r != null)
                {
                    var (hcss, hicon, hlbl) = status switch
                    {
                        DailyReportStatus.Draft          => ("bg-secondary",         "bi-pencil",           "Draft"),
                        DailyReportStatus.Submitted      => ("bg-primary",           "bi-send",             "Submitted"),
                        DailyReportStatus.Reviewed       => ("bg-info text-dark",    "bi-eye-fill",         "Reviewed"),
                        DailyReportStatus.Approved       => ("bg-success",           "bi-shield-check",     "Approved"),
                        DailyReportStatus.Voided         => ("bg-danger",            "bi-x-circle-fill",    "Voided"),
                        DailyReportStatus.NoWork         => ("bg-warning text-dark", "bi-dash-circle",      "No Work"),
                        DailyReportStatus.NoWorkApproved => ("bg-success",           "bi-dash-circle-fill", "No Work (Apv)"),
                        _                                => ("bg-secondary",         "bi-question",         "Unknown"),
                    };
                    <span class="badge @hcss" style="font-size:.72em; padding:.35em .8em;">
                        <i class="bi @hicon me-1"></i>@hlbl
                    </span>
                    @if (r.AuthoredByName != null)
                    {
                        <span class="text-muted" style="font-size:.65em; font-weight:400;">
                            <i class="bi bi-person me-1"></i>@r.AuthoredByName
                        </span>
                    }
                }
            </h1>
            @if (r != null)
            {
                <p class="text-muted mb-0 small">@r.ReportDate.ToString("dddd, MMMM d, yyyy")</p>
            }
        </div>
        <a asp-page="/Daily/Index" asp-route-projectId="@pid" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back to List
        </a>
    </div>
}

@if (TempData["Success"] is string ok)
{
    <div class="px-3 pt-2">
        <div class="alert alert-success alert-dismissible fade show py-2 small" role="alert">
            <i class="bi bi-check-circle me-1"></i>@ok
            <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert"></button>
        </div>
    </div>
}
@if (TempData["Error"] is string err)
{
    <div class="px-3 pt-2">
        <div class="alert alert-danger alert-dismissible fade show py-2 small" role="alert">
            <i class="bi bi-exclamation-triangle me-1"></i>@err
            <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert"></button>
        </div>
    </div>
}

<div class="p-3" style="font-size:.875rem;">

    @* ── Status Bar ──────────────────────────────────────────────────────────── *@
    @if (r != null)
    {
        <div class="d-flex align-items-center gap-3 mb-3 flex-wrap">
            @if (r.SubmittedAt.HasValue)
            {
                <span class="text-muted small"><i class="bi bi-send me-1"></i>Submitted @r.SubmittedAt.Value.ToLocalTime().ToString("MM/dd HH:mm")</span>
            }
            @if (r.ReviewedByName != null)
            {
                <span class="text-muted small"><i class="bi bi-eye me-1"></i>Reviewed by @r.ReviewedByName</span>
            }
            @if (r.ApprovedByName != null)
            {
                <span class="text-muted small"><i class="bi bi-shield-check me-1 text-success"></i>Approved by @r.ApprovedByName</span>
            }
        </div>

        @* ── Action buttons ──────────────────────────────────────────────────── *@
        <div class="d-flex gap-2 mb-3 flex-wrap">
            @if (Model.CanReview && status == DailyReportStatus.Submitted)
            {
                <form method="post" asp-page-handler="Review">
                    <input type="hidden" name="reportId" value="@r.Id" />
                    <input type="hidden" name="Modal"    value="@Model.Modal" />
                    <input type="hidden" name="reviewNotes" value="" />
                    <button type="submit" class="btn btn-info btn-sm">
                        <i class="bi bi-eye me-1"></i>Mark Reviewed
                    </button>
                </form>
            }
            @if (Model.CanApprove && status is DailyReportStatus.Reviewed or DailyReportStatus.Submitted or DailyReportStatus.NoWork)
            {
                <form method="post" asp-page-handler="Approve">
                    <input type="hidden" name="reportId"      value="@r.Id" />
                    <input type="hidden" name="Modal"         value="@Model.Modal" />
                    <input type="hidden" name="approvalNotes" value="" />
                    <button type="submit" class="btn btn-success btn-sm"
                            onclick="return confirmAction(this,'Approve this daily report?')">
                        <i class="bi bi-shield-check me-1"></i>Approve
                    </button>
                </form>
            }
            @if (Model.CanVoid && status is not (DailyReportStatus.Draft or DailyReportStatus.Voided))
            {
                <form method="post" asp-page-handler="Void">
                    <input type="hidden" name="reportId"  value="@r.Id" />
                    <input type="hidden" name="Modal"     value="@Model.Modal" />
                    <input type="hidden" name="voidReason" value="" />
                    <button type="submit" class="btn btn-outline-danger btn-sm"
                            onclick="return confirmAction(this,'Void this daily report?')">
                        <i class="bi bi-x-circle me-1"></i>Void
                    </button>
                </form>
            }
        </div>
    }

    @* ── Main Form ───────────────────────────────────────────────────────────── *@
    @if (isLocked)
    {
        @* Read-only view *@
        <div class="alert alert-success py-2 small mb-3">
            <i class="bi bi-lock-fill me-1"></i>This report is <strong>locked</strong> and cannot be edited.
        </div>
    }

    <form method="post"
          asp-page-handler="@(isNew || (!isLocked && Model.CanWrite) ? "Save" : "")"
          id="reportForm">
        <input type="hidden" name="ReportId"  value="@(r?.Id)" />
        <input type="hidden" name="ProjectId" value="@pid" />
        <input type="hidden" name="Date"      value="@dateStr" />
        <input type="hidden" name="Modal"     value="@Model.Modal" />
        @Html.AntiForgeryToken()

        @* ── Top Row: Report Info (left) + Task Progress (right) ──────────── *@
        <div class="d-flex gap-3 align-items-start flex-wrap mb-0">

        @* ── Section 1: Report Info ─────────────────────────────────────────── *@
        <div class="aci-card mb-3" style="max-width:640px; background:#f5f8ff;">
            <div class="card-header-aci d-flex align-items-center gap-2 px-3 py-2 border-bottom">
                <i class="bi bi-info-circle text-primary"></i>
                <span class="fw-semibold small">Report Info</span>
                @if (r != null)
                {
                    <span class="text-muted small ms-auto">Report #@r.ReportNumber</span>
                }
            </div>
            <div class="px-3 py-3">
                <div class="d-flex flex-column gap-2">

                    @* Date *@
                    <div class="d-flex align-items-center gap-2">
                        <label class="form-label small fw-semibold mb-0 text-end" style="width:90px; min-width:90px;">Date</label>
                        <input type="date" id="reportDate" name="Date"
                               class="form-control form-control-sm"
                               value="@dateStr"
                               data-original="@dateStr"
                               style="max-width:160px;"
                               @(isLocked ? "readonly" : "") />
                    </div>

                    @* Location / Area *@
                    <div class="d-flex align-items-center gap-2">
                        <label class="form-label small fw-semibold mb-0 text-end" style="width:90px; min-width:90px;">Location / Area</label>
                        <input type="text" name="Location" class="form-control form-control-sm"
                               value="@(r?.Location ?? (isNew ? Model.DefaultLocation : ""))"
                               placeholder="e.g. Building A – Level 3"
                               @(isLocked ? "readonly" : "") maxlength="200" />
                    </div>

                    @* Weather *@
                    <div class="d-flex align-items-center gap-2">
                        <label class="form-label small fw-semibold mb-0 text-end" style="width:90px; min-width:90px;">Weather</label>
                        <div class="d-flex gap-2 align-items-center flex-wrap" style="flex:1;">
                            <select name="WeatherCondition" class="form-select form-select-sm"
                                    style="width:130px; max-width:130px; flex:none;"
                                    @(isLocked ? "disabled" : "")>
                                <option value="">— Condition —</option>
                                @foreach (var wc in new[]{"Clear","Partly Cloudy","Cloudy","Rain","Heavy Rain","Snow","Fog","Windy"})
                                {
                                    <option value="@wc" selected="@(r?.WeatherCondition == wc)">@wc</option>
                                }
                            </select>
                            <div class="d-flex align-items-center gap-1">
                                <span class="small text-muted" style="white-space:nowrap;">Hi °F</span>
                                <input type="number" name="TempHigh" class="form-control form-control-sm text-center"
                                       value="@(r?.TempHigh?.ToString() ?? "")"
                                       style="width:58px;"
                                       @(isLocked ? "readonly" : "") />
                            </div>
                            <div class="d-flex align-items-center gap-1">
                                <span class="small text-muted" style="white-space:nowrap;">Lo °F</span>
                                <input type="number" name="TempLow" class="form-control form-control-sm text-center"
                                       value="@(r?.TempLow?.ToString() ?? "")"
                                       style="width:58px;"
                                       @(isLocked ? "readonly" : "") />
                            </div>
                            <div class="form-check mb-0">
                                <input class="form-check-input" type="checkbox" name="IsWindy" value="true"
                                       id="chkWindy" @(r?.IsWindy == true ? "checked" : "") @(isLocked ? "disabled" : "") />
                                <label class="form-check-label small" for="chkWindy"><i class="bi bi-wind me-1"></i>Windy</label>
                            </div>
                            <div class="form-check mb-0">
                                <input class="form-check-input" type="checkbox" name="IsRainy" value="true"
                                       id="chkRainy" @(r?.IsRainy == true ? "checked" : "") @(isLocked ? "disabled" : "") />
                                <label class="form-check-label small" for="chkRainy"><i class="bi bi-cloud-rain me-1"></i>Rainy</label>
                            </div>
                        </div>
                    </div>

                    @* Weather status — 바로 아래 행에 바짝 붙여 표시 *@
                    @if (isNew && !isLocked && (Model.SiteLat.HasValue || !string.IsNullOrEmpty(Model.WeatherAddress)))
                    {
                        <div class="d-flex align-items-center gap-2" style="margin-top:-4px;">
                            <div style="width:90px; min-width:90px;"></div>
                            <span id="weatherStatus" class="text-muted"
                                  style="font-size:.72rem; font-style:italic;">
                                <i class="bi bi-cloud-download me-1"></i>Loading weather…
                            </span>
                        </div>
                    }

                </div>
            </div>
        </div>

        @* ── Task Progress (Report Info 오른쪽) ─────────────────────────────── *@
        <div class="aci-card mb-3" style="flex:1; min-width:320px; border-left:3px solid #0d6efd; background:#eef2ff;">
            <div class="card-header-aci d-flex align-items-center gap-2 px-3 py-2 border-bottom">
                <i class="bi bi-bar-chart-line text-primary"></i>
                <span class="fw-semibold small">Task Progress</span>
                <span class="badge bg-primary ms-1" style="font-size:.65rem;">Required</span>
            </div>
            <div class="px-3 py-2">
                <table class="table table-sm mb-0" id="taskTable" style="font-size:.82rem; --bs-table-bg:#eef2ff;">
                    <thead style="background:#dce4ff;">
                        <tr>
                            <th style="width:38%;">Task</th>
                            <th style="width:88px;" class="text-center">Due Date</th>
                            <th style="width:72px;" class="text-center">Prior %</th>
                            <th style="width:72px;" class="text-center">Today %</th>
                            <th>Notes</th>
                        </tr>
                    </thead>
                    <tbody id="taskBody">
                        @if (isLocked && r?.TaskProgress.Any() == true)
                        {
                            @* 잠금: 저장된 진행률만 표시 *@
                            @foreach (var tp in r.TaskProgress.OrderBy(x => x.SortOrder))
                            {
                                <tr>
                                    <td class="small">
                                        <input type="hidden" name="tp_taskId" value="@(tp.WorkingTaskId?.ToString()??"")" />
                                        @if (tp.WorkingTask?.WbsCode != null) { <span class="text-muted me-1">@tp.WorkingTask.WbsCode</span> }
                                        @(tp.TaskText ?? tp.WorkingTask?.Text ?? "")
                                    </td>
                                    <td class="text-center small text-muted">
                                        @(tp.WorkingTask?.EndDate.ToString("MM/dd") ?? "—")
                                    </td>
                                    <td class="text-center small">@tp.ProgressBeforePercent%</td>
                                    <td class="text-center small fw-semibold">@tp.ProgressAfterPercent%</td>
                                    <td class="small text-muted">@tp.Notes</td>
                                </tr>
                            }
                        }
                        else if (Model.ActiveTasks.Any())
                        {
                            @* 편집: 스케줄 Task 전체 + 기존 저장값 병합 *@
                            @foreach (var t in Model.ActiveTasks)
                            {
                                var saved     = Model.TaskProgressMap.GetValueOrDefault(t.Id);
                                var priorPct  = saved?.ProgressBeforePercent ?? t.ProgressPercent;
                                var todayPct  = saved?.ProgressAfterPercent  ?? t.ProgressPercent;
                                var delta     = todayPct - priorPct;
                                <tr>
                                    <td class="small">
                                        <input type="hidden" name="tp_taskId" value="@t.Id" />
                                        <input type="hidden" name="tp_text"   value="@t.Text" />
                                        @if (t.WbsCode != null) { <span class="text-muted me-1">@t.WbsCode</span> }
                                        @t.Text
                                    </td>
                                    <td class="text-center small text-muted">
                                        @t.EndDate.ToString("MM/dd")
                                    </td>
                                    <td>
                                        <input type="number" name="tp_before" value="@priorPct"
                                               class="form-control form-control-sm text-center" min="0" max="100"
                                                />
                                    </td>
                                    <td>
                                        <input type="number" name="tp_after" value="@todayPct"
                                               class="form-control form-control-sm text-center tp-after" min="0" max="100"
                                                />
                                    </td>
                                    <td>
                                        <input type="text" name="tp_notes" value="@(saved?.Notes??"")"
                                               class="form-control form-control-sm" maxlength="500" />
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-3 small text-muted">
                                    No active tasks scheduled for this date.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        </div>@* ── /Top Row flex wrapper ────────────────────────────────────────── *@

        @* ── Section 2: Work Performed ─────────────────────────────────────── *@
        <div class="aci-card mb-3" style="background:#fffdf5;">
            <div class="card-header-aci d-flex align-items-center gap-2 px-3 py-2 border-bottom">
                <i class="bi bi-hammer text-warning"></i>
                <span class="fw-semibold small">Work Performed</span>
                @if (!isLocked && Model.CanWrite)
                {
                    <button type="button" class="btn btn-link btn-sm ms-auto py-0 px-1"
                            onclick="addRow('workTable','work-row-tpl')">
                        <i class="bi bi-plus-lg"></i> Add Item
                    </button>
                }
            </div>
            <div class="px-3 py-2" style="overflow-x:auto;">
                <table class="table table-sm mb-0" id="workTable" style="font-size:.82rem; min-width:1020px;">
                    <thead class="table-light">
                        <tr>
                            <th style="width:200px;">Trade</th>
                            <th style="width:190px;">Area / Zone</th>
                            <th style="width:200px;">Company Name</th>
                            <th class="text-center" style="width:65px;">Workers</th>
                            <th class="text-center" style="width:100px;">Start</th>
                            <th class="text-center" style="width:100px;">End</th>
                            <th class="text-center" style="width:68px;">Man-Hrs</th>
                            <th>Description</th>
                            @if (!isLocked && Model.CanWrite)
                            { <th style="width:40px;"></th> }
                        </tr>
                    </thead>
                    <tbody id="workBody">
                        @if (r?.WorkItems.Any() == true)
                        {
                            @foreach (var w in r.WorkItems.OrderBy(x => x.SortOrder))
                            {
                                <tr>
                                    <td>
                                        <div class="work-trade-wrap d-flex gap-1 align-items-center">
                                            <select class="form-select form-select-sm work-trade-sel" style="flex:1;min-width:0;" @(isLocked?"disabled":"") onchange="tradeSelChange(this)">
                                                <option value="">— Trade —</option>
                                                @foreach (var tn in allTrades) { <option value="@tn">@tn</option> }
                                                @if (!isLocked) { <option value="__direct__">✏ Direct Input</option> }
                                            </select>
                                            <input type="text" name="work_trade" class="form-control form-control-sm work-trade-txt"
                                                   style="display:none;flex:1;min-width:0;" value="@(w.TradeText??"")"
                                                   placeholder="Type trade…" maxlength="100" @(isLocked?"readonly":"") />
                                            @if (!isLocked) {
                                                <button type="button" class="btn p-0 px-1 work-trade-back lh-1"
                                                        style="display:none;color:#6c757d;font-size:.8rem;" onclick="tradeBackToSel(this)" title="Back to list">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                    <td><input type="text" name="work_area"    value="@(w.Area??"")"                      class="form-control form-control-sm" @(isLocked?"readonly":"") maxlength="200" placeholder="Bldg A – L3" /></td>
                                    <td><input type="text" name="work_company" value="@(w.CompanyName??"")"               class="form-control form-control-sm" @(isLocked?"readonly":"") maxlength="200" placeholder="ACI / Sub" /></td>
                                    <td><input type="number" name="work_count" value="@(w.WorkerCount?.ToString()??"")"   class="form-control form-control-sm text-center work-count" min="0" @(isLocked?"readonly":"") /></td>
                                    <td><input type="time" name="work_start" value="@(w.StartTime?.ToString("H:mm")??"")" class="form-control form-control-sm text-center work-start" style="max-width:100px;padding-left:2px;padding-right:2px;" @(isLocked?"readonly":"") /></td>
                                    <td><input type="time" name="work_end"   value="@(w.EndTime?.ToString("H:mm")??"")"   class="form-control form-control-sm text-center work-end"   style="max-width:100px;padding-left:2px;padding-right:2px;" @(isLocked?"readonly":"") /></td>
                                    <td><input type="number" name="work_hours" value="@(w.WorkerHours?.ToString("G")??"")" class="form-control form-control-sm text-center work-hrs" min="0" step="0.5" @(isLocked?"readonly":"") /></td>
                                    <td><textarea name="work_desc" class="form-control form-control-sm" rows="1" style="resize:vertical;min-height:32px;" @(isLocked?"readonly":"") maxlength="500">@w.Description</textarea></td>
                                    @if (!isLocked && Model.CanWrite)
                                    { <td><button type="button" class="btn btn-link text-danger btn-sm py-0" onclick="removeRow(this)"><i class="bi bi-trash"></i></button></td> }
                                </tr>
                            }
                        }
                        else if (!isLocked && Model.CanWrite)
                        {
                            <tr>
                                <td>
                                    <div class="work-trade-wrap d-flex gap-1 align-items-center">
                                        <select class="form-select form-select-sm work-trade-sel" style="flex:1;min-width:0;" onchange="tradeSelChange(this)">
                                            <option value="">— Trade —</option>
                                            @foreach (var tn in allTrades) { <option value="@tn">@tn</option> }
                                            <option value="__direct__">✏ Direct Input</option>
                                        </select>
                                        <input type="text" name="work_trade" class="form-control form-control-sm work-trade-txt"
                                               style="display:none;flex:1;min-width:0;" placeholder="Type trade…" maxlength="100" />
                                        <button type="button" class="btn p-0 px-1 work-trade-back lh-1"
                                                style="display:none;color:#6c757d;font-size:.8rem;" onclick="tradeBackToSel(this)" title="Back to list">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </div>
                                </td>
                                <td><input type="text"   name="work_area"    class="form-control form-control-sm" maxlength="200" placeholder="Bldg A – L3" /></td>
                                <td><input type="text"   name="work_company" class="form-control form-control-sm" maxlength="200" placeholder="ACI / Sub" /></td>
                                <td><input type="number" name="work_count"   class="form-control form-control-sm text-center work-count" min="0" /></td>
                                <td><input type="time" name="work_start" class="form-control form-control-sm text-center work-start" style="max-width:100px;padding-left:2px;padding-right:2px;" /></td>
                                <td><input type="time" name="work_end"   class="form-control form-control-sm text-center work-end"   style="max-width:100px;padding-left:2px;padding-right:2px;" /></td>
                                <td><input type="number" name="work_hours"   class="form-control form-control-sm text-center work-hrs" min="0" step="0.5" /></td>
                                <td><textarea name="work_desc" class="form-control form-control-sm" rows="1" style="resize:vertical;min-height:32px;" maxlength="500" placeholder="Describe the work performed…"></textarea></td>
                                <td><button type="button" class="btn btn-link text-danger btn-sm py-0" onclick="removeRow(this)"><i class="bi bi-trash"></i></button></td>
                            </tr>
                        }
                    </tbody>
                </table>
                @if (r != null && r.WorkItems.Any(w => w.WorkerHours.HasValue))
                {
                    <div class="text-end text-muted small mt-1">
                        Total: <strong>@r.TotalManHours.ToString("F0") man-hours</strong>
                    </div>
                }
            </div>
        </div>

        @* ── Section 4 + 7: Equipment (left) & Notes (right) ─────────────── *@
        <div class="d-flex gap-3 align-items-start flex-wrap mb-3">

            @* Equipment *@
            <div class="aci-card" style="flex:1; min-width:300px; background:#f8f9fa;">
                <div class="card-header-aci d-flex align-items-center gap-2 px-3 py-2 border-bottom">
                    <i class="bi bi-truck text-secondary"></i>
                    <span class="fw-semibold small">Equipment</span>
                    @if (!isLocked && Model.CanWrite)
                    {
                        <button type="button" class="btn btn-link btn-sm ms-auto py-0 px-1"
                                onclick="addRow('eqTable','eq-row-tpl')">
                            <i class="bi bi-plus-lg"></i> Add Equipment
                        </button>
                    }
                </div>
                <div class="px-3 py-2">
                    <table class="table table-sm mb-0" id="eqTable" style="font-size:.82rem;">
                        <thead class="table-light">
                            <tr>
                                <th style="width:182px;">Equipment Name</th>
                                <th style="width:80px;">Tag / #</th>
                                <th class="text-center" style="width:50px;">Hrs</th>
                                <th>Notes</th>
                                @if (!isLocked && Model.CanWrite)
                                { <th style="width:36px;"></th> }
                            </tr>
                        </thead>
                        <tbody id="eqBody">
                            @if (r?.Equipment.Any() == true)
                            {
                                @foreach (var eq in r.Equipment.OrderBy(x => x.SortOrder))
                                {
                                    <tr>
                                        <td><input type="text" name="eq_name"  value="@eq.Name"               class="form-control form-control-sm" @(isLocked?"readonly":"") maxlength="200" /></td>
                                        <td><input type="text" name="eq_tag"   value="@(eq.EquipmentTag??"")"  class="form-control form-control-sm" @(isLocked?"readonly":"") maxlength="50" /></td>
                                        <td><input type="number" name="eq_hours" value="@eq.HoursUsed"         class="form-control form-control-sm text-center" min="0" step="0.5" @(isLocked?"readonly":"") /></td>
                                        <td><input type="text" name="eq_notes" value="@(eq.Notes??"")"          class="form-control form-control-sm" @(isLocked?"readonly":"") maxlength="300" /></td>
                                        @if (!isLocked && Model.CanWrite)
                                        { <td><button type="button" class="btn btn-link text-danger btn-sm py-0" onclick="removeRow(this)"><i class="bi bi-trash"></i></button></td> }
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @* Notes / Remarks *@
            <div class="aci-card" style="flex:1; min-width:300px; background:#f5fdf8;">
                <div class="card-header-aci d-flex align-items-center gap-2 px-3 py-2 border-bottom">
                    <i class="bi bi-chat-text text-muted"></i>
                    <span class="fw-semibold small">Notes / Remarks</span>
                </div>
                <div class="px-3 py-2 h-100">
                    <textarea id="reportNotes" name="Notes" rows="1"
                              class="form-control form-control-sm w-100"
                              style="resize:vertical;"
                              maxlength="2000" @(isLocked ? "readonly" : "")
                              placeholder="General notes, observations, RFI references, delays…">@(r?.Notes ?? "")</textarea>
                </div>
            </div>

        </div>@* ── /Equipment + Notes row ─────────────────────────────────────────── *@

        @* ── Section 6: Files / Photos ─────────────────────────────────────── *@
        <div class="aci-card mb-3" style="background:#f5fdff;">
            <div class="card-header-aci d-flex align-items-center gap-2 px-3 py-2 border-bottom">
                <i class="bi bi-images text-info"></i>
                <span class="fw-semibold small">Photos &amp; Documents</span>
            </div>
            <div class="px-3 py-2">
                @* ── Upload zone (상단 고정) ─────────────────────────────────── *@
                @if (!isLocked && Model.CanWrite)
                {
                    <div id="dropZone"
                         class="rounded mb-3 d-flex align-items-center justify-content-center gap-2 flex-wrap"
                         style="border:2px dashed #b0bec5; padding:.6rem 1rem; cursor:pointer;
                                background:#fafcff; transition:background .15s, border-color .15s;"
                         onclick="document.getElementById('fileInput').click()">
                        <input type="file" id="fileInput" multiple class="d-none"
                               accept=".pdf,.jpg,.jpeg,.png,.gif,.doc,.docx,.xls,.xlsx" />
                        <i class="bi bi-cloud-upload text-secondary" style="font-size:1.3rem;"></i>
                        <span class="small text-muted">Drop files here or <u>click to browse</u></span>
                        <span class="text-muted small" id="uploadStatus"></span>
                    </div>
                }
                @if (r?.Files.Any(f => f.IsActive) == true)
                {
                    @* ── 업로드 순서대로 Photo/Document 혼합 배치 ──────────────── *@
                    <div class="d-flex flex-wrap gap-3 mb-2 align-items-start">
                        @foreach (var f in r.Files.Where(f => f.IsActive).OrderBy(f => f.CreatedAt))
                        {
                            if (f.FileType == DailyReportFileType.Photo)
                            {
                                var fileUrl = $"/api/daily-reports/files/{f.Id}/{Uri.EscapeDataString(f.FileName)}?inline=true";
                                <div class="position-relative border rounded overflow-hidden"
                                     style="width:120px; flex-shrink:0;">
                                    <a href="@fileUrl" target="_blank" title="@f.FileName">
                                        <img src="@fileUrl" alt="@f.FileName"
                                             style="width:120px; height:90px; object-fit:cover; display:block;" />
                                    </a>
                                    @if (!string.IsNullOrEmpty(f.Caption))
                                    {
                                        <div class="text-truncate px-1"
                                             style="font-size:.68rem; color:#555; background:#f8f9fa;">@f.Caption</div>
                                    }
                                    @if (!isLocked && Model.CanWrite)
                                    {
                                        <button type="button"
                                                class="btn btn-sm btn-danger py-0 px-1 position-absolute top-0 end-0"
                                                style="font-size:.7rem; opacity:.85; line-height:1.4;"
                                                onclick="deleteFile(@f.Id, this)" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="border rounded p-2 d-flex align-items-center gap-2"
                                     style="font-size:.78rem; min-width:160px; max-width:220px;">
                                    <i class="bi bi-file-earmark-text text-secondary fs-5 flex-shrink-0"></i>
                                    <div class="overflow-hidden">
                                        <a href="/api/daily-reports/files/@f.Id/@Uri.EscapeDataString(f.FileName)?inline=true"
                                           target="_blank" class="text-truncate d-block"
                                           title="@f.FileName" style="max-width:130px;">@f.FileName</a>
                                        @if (!string.IsNullOrEmpty(f.Caption))
                                        { <div class="text-muted" style="font-size:.72rem;">@f.Caption</div> }
                                        <div class="text-muted" style="font-size:.7rem;">@f.FileSizeDisplay</div>
                                    </div>
                                    @if (!isLocked && Model.CanWrite)
                                    {
                                        <button type="button"
                                                class="btn btn-link text-danger btn-sm py-0 ms-auto flex-shrink-0"
                                                onclick="deleteFile(@f.Id, this)" title="Delete">
                                            <i class="bi bi-trash" style="font-size:.8rem;"></i>
                                        </button>
                                    }
                                </div>
                            }
                        }
                    </div>
                }
            </div>
        </div>

        @* ── sticky footer 높이만큼 하단 여백 ────────────────────────────────── *@
        @if (!isLocked && Model.CanWrite)
        {
            <div style="height:60px;"></div>
        }
    </form>

    @* ── Sticky Action Footer ────────────────────────────────────────────────── *@
    @if (!isLocked && Model.CanWrite)
    {
        <div id="stickyFooter"
             style="position:fixed; bottom:0; right:0; z-index:1040;
                    background:#fff; border-top:1px solid #dee2e6;
                    padding:.6rem 1.25rem; display:flex; align-items:center; gap:.6rem;
                    box-shadow:0 -2px 8px rgba(0,0,0,.08);">
            <button type="submit" form="reportForm" class="btn btn-primary btn-sm"
                    formaction="?handler=Save">
                <i class="bi bi-floppy me-1"></i>Save Draft
            </button>
            <button type="submit" form="reportForm" class="btn btn-success btn-sm"
                    formaction="?handler=Submit"
                    onclick="return confirmAction(this,'Submit this report for review?')">
                <i class="bi bi-send me-1"></i>Submit for Review
            </button>
            <button type="button" class="btn btn-outline-warning btn-sm"
                    data-bs-toggle="modal" data-bs-target="#noWorkModal">
                <i class="bi bi-dash-circle me-1"></i>No Work Today
            </button>
            @if (r != null && status == DailyReportStatus.Draft)
            {
                <button type="button" class="btn btn-outline-danger btn-sm ms-2"
                        data-bs-toggle="modal" data-bs-target="#deleteReportModal">
                    <i class="bi bi-trash me-1"></i>Delete Draft
                </button>
            }
            @if (r != null)
            {
                <span class="ms-auto text-muted small">
                    <i class="bi bi-journal-text me-1"></i>Report #@r.ReportNumber
                    &nbsp;·&nbsp; @r.ReportDate.ToString("ddd, MMM d yyyy")
                </span>
            }
        </div>
    }
</div>

@* ── No Work Modal ──────────────────────────────────────────────────────────── *@
<div class="modal fade" id="noWorkModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:420px;">
        <div class="modal-content">
            <form method="post" asp-page-handler="NoWork">
                <input type="hidden" name="ReportId"  value="@(r?.Id)" />
                <input type="hidden" name="ProjectId" value="@pid" />
                <input type="hidden" name="Date"      value="@dateStr" />
                <input type="hidden" name="Modal"     value="@Model.Modal" />
                @Html.AntiForgeryToken()
                <div class="modal-header py-2">
                    <h6 class="modal-title"><i class="bi bi-dash-circle-fill text-warning me-2"></i>Mark as No Work</h6>
                    <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <label class="form-label small fw-semibold">Reason (optional)</label>
                    <textarea name="noWorkReason" rows="3" class="form-control form-control-sm"
                              placeholder="Holiday / Weather / Owner hold / etc." maxlength="500"></textarea>
                </div>
                <div class="modal-footer py-2">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning btn-sm">
                        <i class="bi bi-dash-circle me-1"></i>Confirm No Work
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@* ── Delete Draft Modal ─────────────────────────────────────────────────────── *@
@if (r != null && Model.CanWrite && status == DailyReportStatus.Draft)
{
    <div class="modal fade" id="deleteReportModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" style="max-width:400px;">
            <div class="modal-content">
                <form method="post" asp-page-handler="Delete">
                    <input type="hidden" name="ReportId"  value="@r.Id" />
                    <input type="hidden" name="ProjectId" value="@pid" />
                    <input type="hidden" name="Modal"     value="@Model.Modal" />
                    @Html.AntiForgeryToken()
                    <div class="modal-header py-2">
                        <h6 class="modal-title text-danger">
                            <i class="bi bi-trash me-2"></i>Delete Draft Report
                        </h6>
                        <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body small">
                        <p class="mb-1">Are you sure you want to delete <strong>Report #@r.ReportNumber</strong>?</p>
                        <p class="mb-0 text-muted">@r.ReportDate.ToString("dddd, MMMM d, yyyy")</p>
                        <p class="mt-2 mb-0 text-danger"><i class="bi bi-exclamation-triangle me-1"></i>This action cannot be undone.</p>
                    </div>
                    <div class="modal-footer py-2">
                        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger btn-sm">
                            <i class="bi bi-trash me-1"></i>Delete
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@* ── Row Templates (hidden) ───────────────────────────────────────────────── *@
<template id="work-row-tpl">
    <tr>
        <td>
            <div class="work-trade-wrap d-flex gap-1 align-items-center">
                <select class="form-select form-select-sm work-trade-sel" style="flex:1;min-width:0;" onchange="tradeSelChange(this)">
                    <option value="">— Trade —</option>
                    @foreach (var tn in allTrades) { <option value="@tn">@tn</option> }
                    <option value="__direct__">✏ Direct Input</option>
                </select>
                <input type="text" name="work_trade" class="form-control form-control-sm work-trade-txt"
                       style="display:none;flex:1;min-width:0;" placeholder="Type trade…" maxlength="100" />
                <button type="button" class="btn p-0 px-1 work-trade-back lh-1"
                        style="display:none;color:#6c757d;font-size:.8rem;" onclick="tradeBackToSel(this)" title="Back to list">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        </td>
        <td><input type="text"   name="work_area"    class="form-control form-control-sm" maxlength="200" placeholder="Bldg A – L3" /></td>
        <td><input type="text"   name="work_company" class="form-control form-control-sm" maxlength="200" placeholder="ACI / Sub" /></td>
        <td><input type="number" name="work_count"   class="form-control form-control-sm text-center work-count" min="0" /></td>
        <td><input type="time" name="work_start" class="form-control form-control-sm text-center work-start" style="max-width:100px;padding-left:2px;padding-right:2px;" /></td>
        <td><input type="time" name="work_end"   class="form-control form-control-sm text-center work-end"   style="max-width:100px;padding-left:2px;padding-right:2px;" /></td>
        <td><input type="number" name="work_hours"   class="form-control form-control-sm text-center work-hrs" min="0" step="0.5" /></td>
        <td><textarea name="work_desc" class="form-control form-control-sm" rows="1" style="resize:vertical;min-height:32px;" maxlength="500" placeholder="Describe the work performed…"></textarea></td>
        <td><button type="button" class="btn btn-link text-danger btn-sm py-0" onclick="removeRow(this)"><i class="bi bi-trash"></i></button></td>
    </tr>
</template>

<template id="eq-row-tpl">
    <tr>
        <td><input type="text" name="eq_name"    class="form-control form-control-sm" placeholder="Equipment name" maxlength="200" /></td>
        <td><input type="text" name="eq_tag"     class="form-control form-control-sm" placeholder="#" maxlength="50" /></td>
        <td><input type="number" name="eq_hours" class="form-control form-control-sm text-center" min="0" step="0.5" value="8" /></td>
        <td><input type="text" name="eq_notes"   class="form-control form-control-sm" maxlength="300" /></td>
        <td><button type="button" class="btn btn-link text-danger btn-sm py-0" onclick="removeRow(this)"><i class="bi bi-trash"></i></button></td>
    </tr>
</template>

@section Scripts {
<script>
const _isModal       = @(Model.Modal ? "true" : "false");
const _isNew         = @(isNew ? "true" : "false");
const _siteLat       = @(Model.SiteLat.HasValue ? Model.SiteLat.Value.ToString("R") : "null");
const _siteLon       = @(Model.SiteLon.HasValue ? Model.SiteLon.Value.ToString("R") : "null");
const _weatherAddr   = '@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.WeatherAddress).Trim('"'))';
const _projectId     = @pid;
const _reportDateStr = '@(r?.ReportDate.ToString("yyyy-MM-dd") ?? Model.Date ?? DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd"))';

// ── 날씨 캐시 (서버에서 미리 조회한 결과) ─────────────────────────────────────
@if (isNew && Model.CachedWeather != null)
{
    var cw = Model.CachedWeather;
    <text>
const _cachedWeather = {
    condition : @Html.Raw(System.Text.Json.JsonSerializer.Serialize(cw.Condition)),
    tempHigh  : @(cw.TempHigh?.ToString() ?? "null"),
    tempLow   : @(cw.TempLow?.ToString()  ?? "null"),
    isWindy   : @(cw.IsWindy ? "true" : "false"),
    isRainy   : @(cw.IsRainy ? "true" : "false"),
};
    </text>
}
else
{
    <text>const _cachedWeather = null;</text>
}

// ── Trade 콤보박스: 목록선택 ↔ 직접입력 전환 ──────────────────────────────────
function tradeSelChange(sel) {
    const wrap = sel.closest('.work-trade-wrap');
    const txt  = wrap.querySelector('.work-trade-txt');
    const back = wrap.querySelector('.work-trade-back');
    if (sel.value === '__direct__') {
        sel.style.display  = 'none';
        txt.style.display  = '';
        if (back) back.style.display = '';
        txt.value = '';
        txt.focus();
    } else {
        txt.value = sel.value;   // hidden input에 선택값 저장 (form submit용)
    }
}
function tradeBackToSel(btn) {
    const wrap = btn.closest('.work-trade-wrap');
    const sel  = wrap.querySelector('.work-trade-sel');
    const txt  = wrap.querySelector('.work-trade-txt');
    sel.style.display  = '';
    sel.value          = '';
    txt.style.display  = 'none';
    txt.value          = '';
    btn.style.display  = 'none';
}
// 페이지 로드 시 기존 행 초기화: TradeText 값으로 select 동기화
document.querySelectorAll('#workBody .work-trade-wrap').forEach(wrap => {
    const txt = wrap.querySelector('.work-trade-txt');
    const sel = wrap.querySelector('.work-trade-sel');
    if (!txt || !sel || !txt.value) return;
    // 목록에 있으면 select에 반영, 없으면 직접입력 모드로 전환
    const found = Array.from(sel.options).some(o => o.value === txt.value);
    if (found) {
        sel.value = txt.value;
    } else {
        const back = wrap.querySelector('.work-trade-back');
        sel.style.display  = 'none';
        txt.style.display  = '';
        if (back) back.style.display = '';
    }
});

// ── Work Performed: Description textarea 자동 행 수 ───────────────────────────
function autoRows(ta) {
    const lines = (ta.value.match(/\n/g) || []).length + 1;
    ta.rows = Math.max(1, lines);
}
// 페이지 로드 시 기존 행 적용
document.querySelectorAll('#workBody textarea[name="work_desc"]').forEach(autoRows);
const _notesTA = document.getElementById('reportNotes');
if (_notesTA) autoRows(_notesTA);
// 입력 시 실시간 적용
document.getElementById('workTable')?.addEventListener('input', function (e) {
    if (e.target.name === 'work_desc') autoRows(e.target);
});
_notesTA?.addEventListener('input', () => autoRows(_notesTA));

// ── Work Performed: Man-Hrs 자동 계산 ─────────────────────────────────────────
function calcManHrs(row) {
    const count  = parseFloat(row.querySelector('.work-count')?.value) || 0;
    const start  = row.querySelector('.work-start')?.value;
    const end    = row.querySelector('.work-end')?.value;
    const hrsEl  = row.querySelector('.work-hrs');
    if (!hrsEl) return;

    const canAuto = count > 0 && start && end && end > start;
    if (canAuto) {
        const [sh, sm] = start.split(':').map(Number);
        const [eh, em] = end.split(':').map(Number);
        const hrs = ((eh * 60 + em) - (sh * 60 + sm)) / 60;
        if (hrs > 0) {
            hrsEl.value    = (count * hrs).toFixed(1);
            hrsEl.readOnly = true;
            hrsEl.style.background = 'var(--bs-secondary-bg, #e9ecef)';
            hrsEl.title    = 'Auto-calculated from Workers × Hours';
            return;
        }
    }
    hrsEl.readOnly = false;
    hrsEl.style.background = '';
    hrsEl.title = '';
}

document.getElementById('workTable')?.addEventListener('input', function (e) {
    const row = e.target.closest('tr');
    if (row) calcManHrs(row);
});

// 페이지 로드 시 기존 행도 자동계산 상태 반영
document.querySelectorAll('#workBody tr').forEach(calcManHrs);

// ── Date 변경 확인 다이얼로그 ──────────────────────────────────────────────────
(function () {
    const dateInput = document.getElementById('reportDate');
    if (!dateInput || dateInput.readOnly) return;
    dateInput.addEventListener('change', function () {
        const newDate = this.value;
        const orig    = this.dataset.original;
        if (newDate === orig) return;
        const fmt = d => {
            const [y, m, day] = d.split('-');
            const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
            return `${months[parseInt(m,10)-1]} ${parseInt(day,10)}, ${y}`;
        };
        const confirmed = confirm(
            `Change the report date from ${fmt(orig)} to ${fmt(newDate)}?\n\n` +
            `This will re-assign the report to the selected date.`
        );
        if (!confirmed) {
            this.value = orig;   // 원래 날짜로 복원
        }
    });
})();

// ── Sticky footer: sidebar width 동기화 ─────────────────────────────────────
(function () {
    const footer  = document.getElementById('stickyFooter');
    const sidebar = document.getElementById('sidebar');
    if (!footer) return;

    function syncLeft() {
        const w = sidebar ? sidebar.offsetWidth : 0;
        footer.style.left = w + 'px';
    }
    syncLeft();

    document.getElementById('sidebarToggle')?.addEventListener('click', () => {
        setTimeout(syncLeft, 280);   // CSS transition: .25s
    });
    window.addEventListener('resize', syncLeft);
})();

// ── 날씨 자동 채우기 (신규 작성 시에만) ────────────────────────────────────
if (_isNew) {
    if (_cachedWeather) {
        // DB 캐시 있음 → 바로 폼에 채우기 (인터넷 조회 불필요)
        applyWeatherToForm(_cachedWeather.condition, _cachedWeather.tempHigh,
                           _cachedWeather.tempLow, _cachedWeather.isWindy,
                           _cachedWeather.isRainy, true);
    } else if (_siteLat !== null && _siteLon !== null) {
        fetchWeatherByCoords(_siteLat, _siteLon, null);
    } else if (_weatherAddr) {
        fetchWeatherByAddress(_weatherAddr);
    }
}

// 폼 필드 채우기 + status 표시
function applyWeatherToForm(condition, tempHigh, tempLow, isWindy, isRainy, fromCache) {
    const statusEl = document.getElementById('weatherStatus');
    const condSel  = document.querySelector('[name="WeatherCondition"]');
    if (condSel && condition) {
        const opt = [...condSel.options].find(o => o.value === condition);
        if (opt) condSel.value = condition;
    }
    const hi = document.querySelector('[name="TempHigh"]');
    const lo = document.querySelector('[name="TempLow"]');
    if (hi && tempHigh != null) hi.value = tempHigh;
    if (lo && tempLow  != null) lo.value = tempLow;
    const chkWindy = document.getElementById('chkWindy');
    const chkRainy = document.getElementById('chkRainy');
    if (chkWindy) chkWindy.checked = isWindy;
    if (chkRainy) chkRainy.checked = isRainy;
    if (statusEl) {
        // const now = new Date().toLocaleTimeString();
        // const src = fromCache
        //     ? `<span class="badge bg-secondary" style="font-size:.65rem;">DB Cache</span>`
        //     : `<span class="badge bg-success"   style="font-size:.65rem;">API</span>`;
        const icon = fromCache
            ? `<i class="bi bi-database text-secondary me-1"></i>`
            : `<i class="bi bi-check-circle text-success me-1"></i>`;
        statusEl.innerHTML = icon +
            `${condition ?? '—'}, ${tempLow ?? '?'}–${tempHigh ?? '?'}°F` +
            (isWindy ? ' · Windy' : '') + (isRainy ? ' · Rain' : '');
            // + `&nbsp;<span style="color:#aaa;">(${now})</span>`;
    }
}

async function fetchWeatherByAddress(address) {
    const statusEl = document.getElementById('weatherStatus');
    try {
        const geoRes  = await fetch(
            `https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(address)}&format=json&limit=1`,
            { headers: { 'Accept': 'application/json' } }
        );
        const geoData = await geoRes.json();
        if (!geoData.length) {
            if (statusEl) statusEl.textContent = 'Address not found.';
            return;
        }
        await fetchWeatherByCoords(parseFloat(geoData[0].lat), parseFloat(geoData[0].lon), address);
    } catch {
        if (statusEl) statusEl.textContent = 'Weather fetch failed.';
    }
}

async function fetchWeatherByCoords(lat, lon, addr) {
    const statusEl = document.getElementById('weatherStatus');
    try {
        const wxRes = await fetch(
            `https://api.open-meteo.com/v1/forecast` +
            `?latitude=${lat}&longitude=${lon}` +
            `&current=temperature_2m,weather_code,wind_speed_10m,precipitation` +
            `&daily=temperature_2m_max,temperature_2m_min` +
            `&temperature_unit=fahrenheit&wind_speed_unit=mph` +
            `&timezone=auto&forecast_days=1`
        );
        const wx  = await wxRes.json();
        const cur = wx.current;

        const condition = wmoToCondition(cur.weather_code);
        const tempHigh  = Math.round(wx.daily.temperature_2m_max[0]);
        const tempLow   = Math.round(wx.daily.temperature_2m_min[0]);
        const isWindy   = cur.wind_speed_10m > 15;
        const isRainy   = cur.precipitation  > 0;

        applyWeatherToForm(condition, tempHigh, tempLow, isWindy, isRainy, false);

        // DB 캐시에 저장 (fire-and-forget)
        fetch('/api/daily-reports/weather-cache', {
            method : 'POST',
            headers: { 'Content-Type': 'application/json' },
            body   : JSON.stringify({
                projectId : _projectId,
                date      : _reportDateStr,
                latitude  : lat,
                longitude : lon,
                address   : addr ?? null,
                condition,
                tempHigh,
                tempLow,
                isWindy,
                isRainy,
                source    : 'open-meteo',
            }),
        }).catch(() => {/* 캐시 저장 실패해도 무시 */});
    } catch {
        if (statusEl) statusEl.textContent = 'Weather fetch failed.';
    }
}

/** WMO weather code → 폼 WeatherCondition 값으로 매핑 */
function wmoToCondition(code) {
    if (code === 0)                        return 'Clear';
    if (code <= 2)                         return 'Partly Cloudy';
    if (code === 3)                        return 'Cloudy';
    if (code >= 45 && code <= 48)          return 'Fog';
    if ((code >= 51 && code <= 67) ||
        (code >= 80 && code <= 82))        return code >= 55 ? 'Heavy Rain' : 'Rain';
    if (code >= 71 && code <= 77)          return 'Snow';
    if (code >= 85 && code <= 86)          return 'Snow';
    if (code === 95 || code >= 96)         return 'Heavy Rain';   // 뇌우
    return 'Cloudy';
}

// ── Row helpers ─────────────────────────────────────────────────────────────
function addRow(tableId, tplId) {
    const tpl  = document.getElementById(tplId);
    const tbody = document.getElementById(tableId).querySelector('tbody');
    // 빈 안내 행 제거
    const empty = tbody.querySelector('tr.text-muted');
    if (empty) empty.remove();
    tbody.appendChild(tpl.content.cloneNode(true));
}
function removeRow(btn) { btn.closest('tr').remove(); }


// ── File upload ──────────────────────────────────────────────────────────────
const reportId  = @(r?.Id.ToString() ?? "0");
const projectId = @pid;
const dateVal   = '@dateStr';

// ── File upload (공통 처리) ───────────────────────────────────────────────────
async function uploadFiles(files) {
    if (!files.length) return;
    const status = document.getElementById('uploadStatus');

    // 신규 미저장 report에는 업로드 불가 — 먼저 Save 필요
    if (reportId === 0) {
        status.textContent = '⚠ Please save the report first before uploading files.';
        status.style.color = '#dc3545';
        return;
    }

    status.textContent = 'Uploading…';
    status.style.color = '';

    const fd = new FormData();
    fd.append('projectId',  projectId);
    fd.append('reportDate', dateVal);
    [...files].forEach(f => {
        fd.append('files', f);
        fd.append('fileTypes', /\.(jpg|jpeg|png|gif|webp)$/i.test(f.name) ? '1' : '0');
    });

    try {
        const res  = await fetch('/api/daily-reports/upload', { method: 'POST', body: fd });
        const json = await res.json();
        if (!res.ok) { status.textContent = json.error ?? 'Upload failed.'; return; }
        status.textContent = `${files.length} file(s) uploaded.`;
        if (_isModal && window.parent !== window)
            window.parent.postMessage({ type: 'aci-daily-changed' }, '*');
        setTimeout(() => window.location.reload(), 800);
    } catch (e) { status.textContent = 'Upload error.'; }
}

// ── file input change ────────────────────────────────────────────────────────
document.getElementById('fileInput')?.addEventListener('change', function () {
    uploadFiles(this.files);
    this.value = '';
});

// ── Drag & Drop ──────────────────────────────────────────────────────────────
const _dropZone = document.getElementById('dropZone');
if (_dropZone) {
    _dropZone.addEventListener('dragover', e => {
        e.preventDefault();
        _dropZone.style.background      = '#e8f0fe';
        _dropZone.style.borderColor     = '#4a90d9';
    });
    ['dragleave', 'dragend'].forEach(evt => {
        _dropZone.addEventListener(evt, () => {
            _dropZone.style.background  = '#fafcff';
            _dropZone.style.borderColor = '#b0bec5';
        });
    });
    _dropZone.addEventListener('drop', e => {
        e.preventDefault();
        _dropZone.style.background  = '#fafcff';
        _dropZone.style.borderColor = '#b0bec5';
        uploadFiles(e.dataTransfer.files);
    });
}

async function deleteFile(fileId, btn) {
    if (!confirm('Delete this file?')) return;
    const res = await fetch(`/api/daily-reports/files/${fileId}`, { method: 'DELETE' });
    if (res.ok) {
        btn.closest('div.border').remove();
        if (_isModal && window.parent !== window)
            window.parent.postMessage({ type: 'aci-daily-changed' }, '*');
    }
}

// ── Modal parent notification after form submit ──────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
    if (_isModal && window.parent !== window) {
        const alert = document.querySelector('.alert-success');
        if (alert) window.parent.postMessage({ type: 'aci-daily-changed' }, '*');
    }
});
</script>
