@page
@using ACI.Web.Data.Entities
@model ACI.Web.Pages.Daily.IndexModel
@{
    ViewData["Title"]      = "Daily Reports";
    ViewData["ActiveMenu"] = "daily-reports";

    var curPeriod = (Model.Period ?? "3m").ToLower();

    // 페이징 쿼리스트링 빌더 (페이지 번호만 교체)
    var filterPid  = Model.FilterProjectId.HasValue ? Model.FilterProjectId.Value.ToString() : "";
    var filterFrom = Uri.EscapeDataString(Model.From ?? "");
    var filterTo   = Uri.EscapeDataString(Model.To   ?? "");
    var filterPer  = Uri.EscapeDataString(Model.Period ?? "");
    var qsBase     = $"filterProjectId={filterPid}&period={filterPer}&from={filterFrom}&to={filterTo}&pageSize={Model.PageSize}&pageNum=";
}

<!-- ── Delete Draft Modal ───────────────────────────────────────────────────── -->
<div class="modal fade" id="deleteDraftModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:400px;">
        <div class="modal-content">
            <form method="post" asp-page-handler="Delete">
                @Html.AntiForgeryToken()
                <input type="hidden" name="DeleteReportId" id="deleteReportIdInput" value="0" />
                <input type="hidden" name="FilterProjectId" value="@Model.FilterProjectId" />
                <input type="hidden" name="Period"          value="@Model.Period" />
                <input type="hidden" name="From"            value="@Model.From" />
                <input type="hidden" name="To"              value="@Model.To" />
                <input type="hidden" name="PageNum"         value="@Model.PageNum" />
                <input type="hidden" name="PageSize"        value="@Model.PageSize" />
                <div class="modal-header py-2">
                    <h6 class="modal-title text-danger">
                        <i class="bi bi-trash me-2"></i>Delete Draft Report
                    </h6>
                    <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body small">
                    <p class="mb-1">Are you sure you want to delete <strong id="deleteReportLabel">Report</strong>?</p>
                    <p class="mt-2 mb-0 text-danger"><i class="bi bi-exclamation-triangle me-1"></i>This action cannot be undone.</p>
                </div>
                <div class="modal-footer py-2">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger btn-sm">
                        <i class="bi bi-trash me-1"></i>Delete
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ── Report Detail Modal ──────────────────────────────────────────────────── -->
<div class="modal fade" id="reportDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable" style="max-width:960px;">
        <div class="modal-content" style="height:92vh;">
            <div class="modal-header py-2 px-3">
                <span class="fw-semibold small">
                    <i class="bi bi-journal-text me-1 text-primary"></i>Daily Report
                </span>
                <button type="button" class="btn-close btn-close-sm ms-auto" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0" style="overflow:hidden;">
                <iframe id="reportDetailFrame" src=""
                        style="width:100%; height:100%; border:none;"
                        title="Daily Report Detail"></iframe>
            </div>
        </div>
    </div>
</div>

<div class="p-3">

    <!-- ── 필터 + 페이징 컨트롤 ──────────────────────────────────────────── -->
    <form method="get" id="filterForm" class="d-flex align-items-center gap-2 flex-wrap mb-3">

        <!-- 제목 -->
        <h5 class="mb-0 fw-bold flex-shrink-0">
            <i class="bi bi-journal-text me-2" style="color:#0d6efd;"></i>Daily Reports
        </h5>
        <small class="text-muted flex-shrink-0">@Model.TotalCount records</small>
        <div class="vr flex-shrink-0 mx-2"></div>

        <!-- 프로젝트 콤보 -->
        <select name="filterProjectId" id="filterProject"
                class="form-select form-select-sm flex-shrink-0" style="min-width:220px; max-width:320px;"
                onchange="onProjectChange(this)">
            @if (Model.Projects.Count != 1)
            {
                if (Model.FilterProjectId == null)
                {
                    <option value="" selected>All Projects</option>
                }
                else
                {
                    <option value="">All Projects</option>
                }
            }
            @foreach (var p in Model.Projects)
            {
                if (Model.FilterProjectId == p.Id)
                {
                    <option value="@p.Id" selected>@p.Code — @p.Name</option>
                }
                else
                {
                    <option value="@p.Id">@p.Code — @p.Name</option>
                }
            }
        </select>

        <div class="vr flex-shrink-0 mx-1"></div>

        <!-- Period 쇼트컷 -->
        <div class="btn-group btn-group-sm flex-shrink-0" role="group">
            @foreach (var (lbl, val) in new[] { ("3m","3m"),("6m","6m"),("9m","9m"),("1yr","1yr"),("All","all") })
            {
                <button type="button"
                        class="btn @(curPeriod == val ? "btn-primary" : "btn-outline-secondary")"
                        onclick="setPeriod('@val')">@lbl</button>
            }
        </div>

        <!-- Custom 날짜 범위 -->
        <span class="text-muted small flex-shrink-0">From</span>
        <input type="date" class="form-control form-control-sm flex-shrink-0" style="width:150px;"
               name="from" id="filterFrom" value="@Model.From"
               onchange="document.getElementById('filterPeriod').value=''" />
        <span class="text-muted small flex-shrink-0">To</span>
        <input type="date" class="form-control form-control-sm flex-shrink-0" style="width:150px;"
               name="to" id="filterTo" value="@Model.To"
               onchange="document.getElementById('filterPeriod').value=''" />
        <input type="hidden" name="period" id="filterPeriod" value="@Model.Period" />
        <input type="hidden" name="pageNum" value="1" />

        <button type="submit" class="btn btn-sm btn-outline-primary flex-shrink-0">
            <i class="bi bi-funnel me-1"></i>Apply
        </button>

        <div class="vr flex-shrink-0 mx-1"></div>

        <!-- 페이지 크기 -->
        <select name="pageSize" class="form-select form-select-sm flex-shrink-0" style="width:auto;"
                onchange="this.form.submit()">
            @foreach (var sz in Model.PageSizeOptions)
            {
                if (Model.PageSize == sz)
                {
                    <option value="@sz" selected>@sz</option>
                }
                else
                {
                    <option value="@sz">@sz</option>
                }
            }
        </select>

        <!-- 페이징 버튼 -->
        <div class="d-flex align-items-center gap-1 flex-shrink-0">
            <a href="?@(qsBase)1"
               class="btn btn-outline-secondary btn-sm py-0 px-1 @(Model.PageNum <= 1 ? "disabled" : "")"
               title="First"><i class="bi bi-chevron-double-left"></i></a>
            <a href="?@(qsBase)@(Model.PageNum - 1)"
               class="btn btn-outline-secondary btn-sm py-0 px-1 @(Model.PageNum <= 1 ? "disabled" : "")"
               title="Previous"><i class="bi bi-chevron-left"></i></a>
            @{
                var pageList = new List<int?>();
                if (Model.TotalPages <= 7)
                {
                    for (var i = 1; i <= Model.TotalPages; i++) pageList.Add(i);
                }
                else
                {
                    pageList.Add(1);
                    if (Model.PageNum - 2 > 2) pageList.Add(null);
                    for (var i = Math.Max(2, Model.PageNum - 2);
                             i <= Math.Min(Model.TotalPages - 1, Model.PageNum + 2); i++)
                        pageList.Add(i);
                    if (Model.PageNum + 2 < Model.TotalPages - 1) pageList.Add(null);
                    if (Model.TotalPages > 1) pageList.Add(Model.TotalPages);
                }
            }
            @foreach (var pg in pageList)
            {
                if (pg == null)
                {
                    <span class="small text-muted px-1">…</span>
                }
                else if (pg == Model.PageNum)
                {
                    <button type="button" class="btn btn-primary btn-sm py-0 px-2" disabled>@pg</button>
                }
                else
                {
                    <a href="?@(qsBase)@pg" class="btn btn-outline-secondary btn-sm py-0 px-2">@pg</a>
                }
            }
            <a href="?@(qsBase)@(Model.PageNum + 1)"
               class="btn btn-outline-secondary btn-sm py-0 px-1 @(Model.PageNum >= Model.TotalPages ? "disabled" : "")"
               title="Next"><i class="bi bi-chevron-right"></i></a>
            <a href="?@(qsBase)@Model.TotalPages"
               class="btn btn-outline-secondary btn-sm py-0 px-1 @(Model.PageNum >= Model.TotalPages ? "disabled" : "")"
               title="Last"><i class="bi bi-chevron-double-right"></i></a>
        </div>

        <!-- Today's Report -->
        @if (Model.CanWrite)
        {
            var singlePid = Model.FilterProjectId.HasValue ? Model.FilterProjectId
                          : Model.Projects.Count == 1      ? Model.Projects[0].Id
                          : (int?)null;
            if (singlePid.HasValue)
            {
                <a href="/Daily/Report?projectId=@singlePid&date=@DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd")"
                   class="btn btn-primary btn-sm ms-2 flex-shrink-0">
                    <i class="bi bi-plus-lg me-1"></i>Add New Report
                </a>
            }
            else
            {
                <button type="button" class="btn btn-primary btn-sm ms-2 flex-shrink-0" disabled
                        title="Select a specific project to add a report">
                    <i class="bi bi-plus-lg me-1"></i>Add New Report
                </button>
            }
        }

    </form>

    @if (TempData["Success"] is string ok)
    {
        <div class="alert alert-success alert-dismissible fade show py-2 small mb-3" role="alert">
            <i class="bi bi-check-circle me-1"></i>@ok
            <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] is string err)
    {
        <div class="alert alert-danger alert-dismissible fade show py-2 small mb-3" role="alert">
            <i class="bi bi-exclamation-triangle me-1"></i>@err
            <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- ── 보고서 테이블 ──────────────────────────────────────────────────── -->
    @if (!Model.Reports.Any())
    {
        <div class="card p-5 text-center text-muted shadow-sm">
            <i class="bi bi-journal-x display-4 d-block mb-3"></i>
            <h5>No daily reports found.</h5>
            <p class="mb-0 small">Adjust the filters or create today's report.</p>
        </div>
    }
    else
    {
        <div class="card shadow-sm overflow-auto">
            <table id="reportTable" class="table table-sm table-hover mb-0 align-middle"
                   style="table-layout:fixed; width:100%; font-size:.85rem;">
                <thead class="table-light">
                    <tr>
                        <th style="width:80px;">Code</th>
                        <th>Project Name</th>
                        <th style="width:50px;">#</th>
                        <th style="width:115px;">Date</th>
                        <th style="width:130px;">Status</th>
                        <th class="text-center" style="width:75px;">Man-hrs</th>
                        <th class="text-center" style="width:55px;">Tasks</th>
                        <th class="text-center" style="width:55px;">Files</th>
                        <th style="width:130px;">Author</th>
                        <th class="text-center" style="width:70px;">Action</th>
                        <th>Notes</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.Reports)
                    {
                        var (css, icon, label) = IndexModel.StatusBadge(r.Status);
                        <tr>
                            <td class="fw-semibold small"
                                style="overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"
                                title="@r.Project?.ProjectCode">
                                @(r.Project?.ProjectCode ?? "—")
                            </td>
                            <td style="overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"
                                title="@r.Project?.Name">
                                @(r.Project?.Name ?? "—")
                            </td>
                            <td class="text-muted small">@r.ReportNumber</td>
                            <td class="fw-semibold">
                                @r.ReportDate.ToString("MM/dd/yyyy")
                                <div class="text-muted" style="font-size:.72rem;">@r.ReportDate.DayOfWeek</div>
                            </td>
                            <td>
                                <span class="badge @css"
                                      style="font-size:.7rem; display:inline-block; width:115px; text-align:center; cursor:pointer;"
                                      onclick="openReport('/Daily/Report?reportId=@r.Id&modal=true')">
                                    <i class="bi @icon me-1"></i>@label
                                </span>
                            </td>
                            <td class="text-center text-muted small">@r.TotalManHours.ToString("F0")</td>
                            <td class="text-center text-muted small">@r.TaskProgress.Count</td>
                            <td class="text-center text-muted small">@r.Files.Count(f => f.IsActive)</td>
                            <td class="small"
                                style="overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"
                                title="@r.AuthoredByName">
                                @(r.AuthoredByName ?? "—")
                            </td>
                            <td class="text-center">
                                <button type="button"
                                        class="btn btn-sm btn-link text-secondary py-0 px-1"
                                        title="Open"
                                        onclick="openReport('/Daily/Report?reportId=@r.Id&modal=true')">
                                    <i class="bi bi-clipboard-check" style="font-size:.8rem;"></i>
                                </button>
                                @if (Model.CanWrite && r.Status == DailyReportStatus.Draft)
                                {
                                    <a asp-page="/Daily/Report"
                                       asp-route-reportId="@r.Id"
                                       class="btn btn-sm btn-link text-primary py-0 px-1"
                                       title="Edit">
                                        <i class="bi bi-pencil-square" style="font-size:.8rem;"></i>
                                    </a>
                                    <button type="button"
                                            class="btn btn-sm btn-link text-danger py-0 px-1"
                                            title="Delete Draft"
                                            onclick="confirmDeleteDraft(@r.Id, '@r.ReportDate.ToString("MM/dd/yyyy")', @r.ReportNumber)">
                                        <i class="bi bi-trash" style="font-size:.8rem;"></i>
                                    </button>
                                }
                            </td>
                            <td class="text-muted small"
                                style="overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"
                                title="@r.Notes">
                                @(r.Notes ?? "")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</div>

@section Scripts {
<script>
// ── 프로젝트 변경 → 페이지 1로 이동 ─────────────────────────────────────────
function onProjectChange(sel) {
    var p = new URLSearchParams(window.location.search);
    p.set('filterProjectId', sel.value);
    p.set('pageNum', '1');
    window.location.href = '?' + p.toString();
}

// ── Period 버튼 ──────────────────────────────────────────────────────────────
function setPeriod(val) {
    document.getElementById('filterPeriod').value = val;
    if (val === 'all') {
        document.getElementById('filterFrom').value = '';
        document.getElementById('filterTo').value   = '';
    } else {
        var today = new Date();
        var days  = { '3m':90, '6m':180, '9m':270, '1yr':365 }[val] || 90;
        var from  = new Date(today);
        from.setDate(from.getDate() - days);
        document.getElementById('filterFrom').value = toDateVal(from);
        document.getElementById('filterTo').value   = toDateVal(today);
    }
    document.getElementById('filterForm').submit();
}

function toDateVal(d) {
    return d.getFullYear() + '-'
        + String(d.getMonth()+1).padStart(2,'0') + '-'
        + String(d.getDate()).padStart(2,'0');
}

// ── Delete Draft ──────────────────────────────────────────────────────────────
const _deleteModal = new bootstrap.Modal(document.getElementById('deleteDraftModal'));
function confirmDeleteDraft(reportId, dateStr, reportNum) {
    document.getElementById('deleteReportIdInput').value = reportId;
    document.getElementById('deleteReportLabel').textContent = 'Report #' + reportNum + ' (' + dateStr + ')';
    _deleteModal.show();
}

// ── Report Detail Modal ───────────────────────────────────────────────────────
const _detailModal = new bootstrap.Modal(document.getElementById('reportDetailModal'));
const _detailFrame = document.getElementById('reportDetailFrame');
let   _reportChanged = false;

function openReport(url) {
    _reportChanged = false;
    _detailFrame.src = url;
    _detailModal.show();
}

document.getElementById('reportDetailModal').addEventListener('hidden.bs.modal', function () {
    _detailFrame.src = '';
    if (_reportChanged) window.location.reload();
});

window.addEventListener('message', function (e) {
    if (e.data?.type === 'aci-daily-changed') { _reportChanged = true; }
});
</script>
}
