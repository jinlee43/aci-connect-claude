@page "{projectId:int}"
@model ACI.Web.Pages.Progress.RevisionsModel
@using ACI.Web.Data.Entities
@{
    ViewData["Title"] = "Change Log";
    ViewData["ActiveMenu"] = "revisions";
    ViewData["CurrentProjectId"] = Model.ProjectId;
    ViewData["CurrentProjectName"] = Model.ProjectName;
}

<div class="aci-page-header">
    <div>
        <h1><i class="bi bi-clock-history me-2 text-primary"></i>Change Log</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-page="/Projects/Index">Projects</a></li>
                <li class="breadcrumb-item"><a asp-page="/Progress/Index" asp-route-projectId="@Model.ProjectId">Current Schedule</a></li>
                <li class="breadcrumb-item active">Change Log</li>
            </ol>
        </nav>
    </div>
    <button class="btn btn-sm btn-success" data-bs-toggle="modal" data-bs-target="#newRevModal">
        <i class="bi bi-plus-lg me-1"></i>New Revision
    </button>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible"><i class="bi bi-check-circle me-2"></i>@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible"><i class="bi bi-x-circle me-2"></i>@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="row g-3">
    <!-- Left: Revision list -->
    <div class="col-md-4 col-lg-3">
        <div class="list-group shadow-sm">
            @foreach (var rev in Model.Revisions)
            {
                var isActive = Model.Selected?.Id == rev.Id;
                <a href="?projectId=@Model.ProjectId&revisionId=@rev.Id"
                   class="list-group-item list-group-item-action @(isActive ? "active" : "")">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="fw-semibold small">@rev.RevisionLabel</div>
                            <div class="@(isActive ? "text-white-50" : "text-muted") small text-truncate" style="max-width:160px">
                                @rev.Title
                            </div>
                        </div>
                        <span class="badge @rev.StatusBadgeClass ms-1" style="font-size:.65rem">
                            @rev.Status
                        </span>
                    </div>
                    <div class="@(isActive ? "text-white-50" : "text-muted") small mt-1">
                        <i class="bi bi-calendar3 me-1"></i>
                        @(rev.ApprovedAt?.ToString("MMM d, yyyy") ?? rev.CreatedAt.ToString("MMM d, yyyy"))
                        · @rev.Changes.Count changes
                    </div>
                </a>
            }
            @if (!Model.Revisions.Any())
            {
                <div class="list-group-item text-muted text-center py-4 small">No revisions yet</div>
            }
        </div>
    </div>

    <!-- Right: Revision detail -->
    <div class="col-md-8 col-lg-9">
        @if (Model.Selected is { } sel)
        {
            <!-- Header card -->
            <div class="card shadow-sm mb-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h5 class="mb-1">@sel.RevisionLabel — @sel.Title</h5>
                            <span class="badge @sel.StatusBadgeClass me-2">@sel.Status</span>
                            <span class="badge bg-light text-dark border">@sel.RevisionType.ToString().ToUpper()</span>
                            @if (!string.IsNullOrEmpty(sel.ChangeOrderRef))
                            {
                                <span class="badge bg-info ms-1">CO: @sel.ChangeOrderRef</span>
                            }
                        </div>
                        <!-- Actions -->
                        <div class="d-flex gap-2">
                            @if (sel.Status == RevisionStatus.Draft)
                            {
                                <form method="post" asp-page-handler="Submit" class="d-inline">
                                    <input type="hidden" name="revisionId" value="@sel.Id" />
                                    <button class="btn btn-sm btn-warning">
                                        <i class="bi bi-send me-1"></i>Submit
                                    </button>
                                </form>
                            }
                            @if (sel.Status == RevisionStatus.Submitted)
                            {
                                <button class="btn btn-sm btn-success" data-bs-toggle="modal"
                                        data-bs-target="#approveModal" data-rev-id="@sel.Id">
                                    <i class="bi bi-check-lg me-1"></i>Approve
                                </button>
                                <form method="post" asp-page-handler="Reject" class="d-inline">
                                    <input type="hidden" name="revisionId" value="@sel.Id" />
                                    <button class="btn btn-sm btn-outline-danger">Reject</button>
                                </form>
                            }
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(sel.Description))
                    {
                        <p class="text-muted small mt-2 mb-0">@sel.Description</p>
                    }

                    <div class="row g-2 mt-2 text-muted small">
                        @if (sel.DataDate.HasValue)
                        {
                            <div class="col-auto"><i class="bi bi-calendar-date me-1"></i>Data Date: <strong>@sel.DataDate.Value.ToString("MMM d, yyyy")</strong></div>
                        }
                        @if (sel.SubmittedAt.HasValue)
                        {
                            <div class="col-auto"><i class="bi bi-send me-1"></i>Submitted: <strong>@sel.SubmittedAt.Value.ToString("MMM d, yyyy")</strong></div>
                        }
                        @if (sel.ApprovedAt.HasValue)
                        {
                            <div class="col-auto"><i class="bi bi-check-circle me-1"></i>Approved: <strong>@sel.ApprovedAt.Value.ToString("MMM d, yyyy")</strong> by @sel.ApprovedByName</div>
                        }
                    </div>
                </div>
            </div>

            <!-- Changes table -->
            <div class="card shadow-sm mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span class="fw-semibold"><i class="bi bi-list-check me-2"></i>Schedule Changes (@sel.Changes.Count)</span>
                </div>
                <div class="card-body p-0">
                    @if (sel.Changes.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Activity</th>
                                        <th>Change</th>
                                        <th>Before</th>
                                        <th>After</th>
                                        <th>Delay</th>
                                        <th>Changed By</th>
                                        <th>Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var chg in sel.Changes.OrderBy(c => c.ChangedAt))
                                    {
                                        <tr>
                                            <td class="small">@chg.WorkingTask?.Text</td>
                                            <td>
                                                @{
                                                    var (badgeClass, icon) = chg.ChangeType switch {
                                                        ChangeType.Added           => ("bg-primary","bi-plus-circle"),
                                                        ChangeType.Removed         => ("bg-secondary","bi-dash-circle"),
                                                        ChangeType.StartShifted or
                                                        ChangeType.FinishShifted or
                                                        ChangeType.DatesShifted    => ("bg-warning text-dark","bi-arrow-left-right"),
                                                        ChangeType.DurationChanged => ("bg-info text-dark","bi-arrows-expand"),
                                                        ChangeType.ProgressUpdated => ("bg-success","bi-graph-up"),
                                                        _                          => ("bg-light text-dark","bi-pencil")
                                                    };
                                                }
                                                <span class="badge @badgeClass" style="font-size:.7rem">
                                                    <i class="bi @icon me-1"></i>@chg.ChangeType.ToString()
                                                </span>
                                            </td>
                                            <td class="small text-muted">
                                                @if (chg.OldStartDate.HasValue)
                                                { @($"{chg.OldStartDate:MMM d} → {chg.OldEndDate:MMM d}") }
                                            </td>
                                            <td class="small">
                                                @if (chg.NewStartDate.HasValue)
                                                { @($"{chg.NewStartDate:MMM d} → {chg.NewEndDate:MMM d}") }
                                            </td>
                                            <td class="small">
                                                @if (chg.DaysShifted.HasValue && chg.DaysShifted != 0)
                                                {
                                                    <span class="@(chg.DaysShifted > 0 ? "text-warning" : "text-success") fw-semibold">
                                                        @(chg.DaysShifted > 0 ? $"+{chg.DaysShifted}" : $"{chg.DaysShifted}")d
                                                    </span>
                                                }
                                            </td>
                                            <td class="small">@chg.ChangedByName</td>
                                            <td class="small text-muted">@chg.ChangedAt.ToString("MMM d HH:mm")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-4 small">No changes recorded in this revision.</div>
                    }
                </div>
            </div>

            <!-- Documents -->
            <div class="card shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span class="fw-semibold"><i class="bi bi-paperclip me-2"></i>Attached Documents (@sel.Documents.Count)</span>
                    <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal"
                            data-bs-target="#uploadDocModal" data-rev-id="@sel.Id">
                        <i class="bi bi-upload me-1"></i>Attach
                    </button>
                </div>
                <div class="card-body p-0">
                    @if (sel.Documents.Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var doc in sel.Documents.OrderBy(d => d.CreatedAt))
                            {
                                <div class="list-group-item d-flex align-items-center gap-3">
                                    <i class="bi @doc.FileIconClass fs-5"></i>
                                    <div class="flex-fill">
                                        <div class="small fw-semibold">@doc.FileName</div>
                                        <div class="text-muted" style="font-size:.75rem">
                                            <span class="badge bg-light text-dark border me-1">@doc.DocumentTypeLabel</span>
                                            @if (!string.IsNullOrEmpty(doc.ReferenceNumber))
                                            { <span class="me-2">Ref: @doc.ReferenceNumber</span> }
                                            @doc.FileSizeDisplay · @doc.CreatedAt.ToString("MMM d, yyyy") · @doc.UploadedByName
                                        </div>
                                        @if (!string.IsNullOrEmpty(doc.Notes))
                                        { <div class="text-muted small">@doc.Notes</div> }
                                    </div>
                                    <div class="d-flex gap-1">
                                        @if (doc.IsPreviewable)
                                        {
                                            <a href="?handler=DocFile&docId=@doc.Id&inline=true&projectId=@Model.ProjectId"
                                               target="_blank" class="btn btn-sm btn-outline-secondary" title="Preview">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        }
                                        <a href="?handler=DocFile&docId=@doc.Id&projectId=@Model.ProjectId"
                                           class="btn btn-sm btn-outline-secondary" title="Download">
                                            <i class="bi bi-download"></i>
                                        </a>
                                        <form method="post" asp-page-handler="DeleteDoc" class="d-inline"
                                              id="frm-delete-doc-@doc.Id">
                                            <input type="hidden" name="documentId" value="@doc.Id" />
                                            <input type="hidden" name="revisionId" value="@sel.Id" />
                                            <button type="button" class="btn btn-sm btn-outline-danger" title="Delete"
                                                    onclick="confirmAction('frm-delete-doc-@doc.Id', 'Remove Document', 'Remove this document?')">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-4 small">No documents attached.</div>
                    }
                </div>
            </div>
        }
    </div>
</div>

<!-- New Revision Modal -->
<div class="modal fade" id="newRevModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">New Revision</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="NewRevision">
                <input type="hidden" name="projectId" value="@Model.ProjectId" />
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Title *</label>
                        <input type="text" name="title" class="form-control" required
                               placeholder="e.g. Rev 3 – March Update" />
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col">
                            <label class="form-label">Type *</label>
                            <select name="revisionType" class="form-select">
                                @foreach (RevisionType rt in Enum.GetValues<RevisionType>())
                                {
                                    <option value="@((int)rt)">@rt.ToString()</option>
                                }
                            </select>
                        </div>
                        <div class="col">
                            <label class="form-label">Data Date</label>
                            <input type="date" name="dataDate" class="form-control"
                                   value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Change Order Ref #</label>
                        <input type="text" name="changeOrderRef" class="form-control" placeholder="CO-007" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea name="description" class="form-control" rows="3"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Create</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Approve Modal -->
<div class="modal fade" id="approveModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Approve Revision</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="Approve">
                <input type="hidden" name="revisionId" id="approveRevId" />
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Approved By *</label>
                        <input type="text" name="approvedByName" class="form-control" required
                               placeholder="Owner / CM / Architect name" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Approval Date</label>
                        <input type="date" name="approvedDate" class="form-control"
                               value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Notes</label>
                        <textarea name="approvalNotes" class="form-control" rows="2"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-lg me-1"></i>Approve
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Upload Document Modal -->
<div class="modal fade" id="uploadDocModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Attach Document</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="UploadDoc" enctype="multipart/form-data">
                <input type="hidden" name="revisionId" id="uploadRevId" />
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Document Type</label>
                        <select name="documentType" class="form-select">
                            @foreach (RevisionDocumentType dt in Enum.GetValues<RevisionDocumentType>())
                            {
                                <option value="@((int)dt)">@dt.ToString()</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">File *</label>
                        <input type="file" name="file" class="form-control" required
                               accept=".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.jpg,.jpeg,.png,.gif,.eml,.msg,.txt,.zip" />
                        <div class="form-text">PDF, Office, images, email (.eml/.msg), ZIP</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Reference # (CO No., RFI No., etc.)</label>
                        <input type="text" name="referenceNumber" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Notes</label>
                        <textarea name="notes" class="form-control" rows="2"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-upload me-1"></i>Upload
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
// Pass revision ID to modals
document.getElementById('approveModal').addEventListener('show.bs.modal', e => {
    document.getElementById('approveRevId').value = e.relatedTarget.dataset.revId;
});
document.getElementById('uploadDocModal').addEventListener('show.bs.modal', e => {
    document.getElementById('uploadRevId').value = e.relatedTarget.dataset.revId;
});
</script>
}
