@page "{projectId:int}"
@model ACI.Web.Pages.Progress.ComparisonModel
@{
    ViewData["Title"] = "Schedule Comparison";
    ViewData["ActiveMenu"] = "progress";
    ViewData["CurrentProjectId"] = Model.ProjectId;
    ViewData["CurrentProjectName"] = Model.ProjectName;
    ViewData["LoadGanttBundle"] = true;
}

@section Styles {
<style>
html, body { height: 100%; }
.aci-gantt-wrapper { padding: 0 12px 12px; }
</style>
}

<div class="aci-page-header">
    <div>
        <h1><i class="bi bi-layout-split me-2 text-primary"></i>Schedule Comparison</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-page="/Projects/Index">Projects</a></li>
                <li class="breadcrumb-item">
                    <a asp-page="/Progress/Index" asp-route-projectId="@Model.ProjectId">Current Schedule</a>
                </li>
                <li class="breadcrumb-item active">Baseline vs Current</li>
            </ol>
        </nav>
    </div>
    <div class="d-flex gap-2">
        <a asp-page="/Progress/Revisions" asp-route-projectId="@Model.ProjectId"
           class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-clock-history me-1"></i>Change Log
        </a>
        <a asp-page="/Progress/Index" asp-route-projectId="@Model.ProjectId"
           class="btn btn-sm btn-outline-success">
            <i class="bi bi-bar-chart-line me-1"></i>Current Schedule
        </a>
    </div>
</div>

<!-- React Comparison Gantt Mount Point -->
<div class="aci-gantt-wrapper">
    <div
        id="comparison-gantt-root"
        data-project-id="@Model.ProjectId"
        data-initialized="@Model.IsInitialized.ToString().ToLower()"
        style="width:100%;">
    </div>
</div>

@section Scripts {
}
