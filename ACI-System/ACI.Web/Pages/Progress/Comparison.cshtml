@page "{projectId:int}"
@model ACI.Web.Pages.Progress.ComparisonModel
@{
    ViewData["Title"] = "Schedule Comparison";
    ViewData["ActiveMenu"] = "progress";
    ViewData["CurrentProjectId"] = Model.ProjectId;
    ViewData["CurrentProjectName"] = Model.ProjectName;
}

<div class="aci-page-header">
    <div>
        <h1><i class="bi bi-layout-split me-2 text-primary"></i>Schedule Comparison</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-page="/Projects/Index">Projects</a></li>
                <li class="breadcrumb-item">
                    <a asp-page="/Progress/Index" asp-route-projectId="@Model.ProjectId">Current Schedule</a>
                </li>
                <li class="breadcrumb-item active">Baseline vs Current</li>
            </ol>
        </nav>
    </div>
    <div class="d-flex gap-2">
        <a asp-page="/Progress/Revisions" asp-route-projectId="@Model.ProjectId"
           class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-clock-history me-1"></i>Change Log
        </a>
        <a asp-page="/Progress/Index" asp-route-projectId="@Model.ProjectId"
           class="btn btn-sm btn-outline-success">
            <i class="bi bi-bar-chart-line me-1"></i>Current Schedule
        </a>
    </div>
</div>

@if (!Model.IsInitialized)
{
    <div class="card border-0 shadow-sm mx-auto mt-5" style="max-width:480px">
        <div class="card-body text-center py-5">
            <i class="bi bi-layout-split fs-1 text-primary mb-3 d-block"></i>
            <h4>Current Schedule Not Initialized</h4>
            <p class="text-muted">
                Initialize the Current Schedule first to enable Baseline vs Current comparison.
            </p>
            <a asp-page="/Progress/Index" asp-route-projectId="@Model.ProjectId"
               class="btn btn-primary mt-2">
                <i class="bi bi-arrow-right-circle me-2"></i>Go to Current Schedule
            </a>
        </div>
    </div>
}
else
{
    <!-- ── Toolbar ──────────────────────────────────────────────────────────── -->
    <div class="d-flex gap-2 mb-2 px-1 align-items-center flex-wrap">

        <!-- Scale buttons -->
        <div class="btn-group btn-group-sm">
            <button class="btn btn-outline-secondary active" id="btnDay"   onclick="setScale('day')">Day</button>
            <button class="btn btn-outline-secondary"        id="btnWeek"  onclick="setScale('week')">Week</button>
            <button class="btn btn-outline-secondary"        id="btnMonth" onclick="setScale('month')">Month</button>
        </div>

        <!-- Baseline toggle -->
        <div class="form-check form-switch ms-2 mb-0">
            <input class="form-check-input" type="checkbox" id="showBaseline" checked
                   onchange="toggleBaselineLayer(this.checked)">
            <label class="form-check-label small" for="showBaseline">Show Baseline</label>
        </div>

        <!-- Legend -->
        <span class="ms-auto d-flex gap-2 align-items-center flex-wrap">
            <span class="badge bg-success-subtle text-success border border-success-subtle">■ On Track / Ahead</span>
            <span class="badge bg-warning-subtle text-warning border border-warning-subtle">■ Delayed</span>
            <span class="badge bg-primary-subtle text-primary border border-primary-subtle">■ New Activity</span>
            <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle">■ Removed</span>
            <span class="badge" style="background:#6c757d33;color:#6c757d;border:1px solid #6c757d55;">▬ Baseline</span>
        </span>
    </div>

    <!-- ── Gantt ────────────────────────────────────────────────────────────── -->
    <div id="comparisonGantt" style="width:100%; height:calc(100vh - 310px);"></div>

    <!-- ── Animation Panel ─────────────────────────────────────────────────── -->
    <div class="card border-0 shadow-sm mt-2" id="animationPanel">
        <div class="card-body py-2 px-3">
            <div class="d-flex align-items-center gap-3">

                <!-- Play / Pause -->
                <button class="btn btn-sm btn-primary" id="btnPlay" onclick="togglePlay()" disabled>
                    <i class="bi bi-play-fill" id="playIcon"></i>
                </button>

                <!-- Step back / forward -->
                <button class="btn btn-sm btn-outline-secondary" id="btnPrev" onclick="stepRevision(-1)" disabled>
                    <i class="bi bi-skip-start-fill"></i>
                </button>
                <button class="btn btn-sm btn-outline-secondary" id="btnNext" onclick="stepRevision(1)" disabled>
                    <i class="bi bi-skip-end-fill"></i>
                </button>

                <!-- Slider -->
                <div class="flex-grow-1">
                    <input type="range" class="form-range" id="revSlider"
                           min="0" value="0" step="1" disabled
                           oninput="onSliderInput(this.value)">
                </div>

                <!-- Speed -->
                <div class="d-flex align-items-center gap-1">
                    <label class="form-label small mb-0 text-muted">Speed</label>
                    <select class="form-select form-select-sm" id="speedSelect" style="width:80px"
                            onchange="onSpeedChange(this.value)">
                        <option value="2000">0.5×</option>
                        <option value="1000" selected>1×</option>
                        <option value="500">2×</option>
                        <option value="250">4×</option>
                    </select>
                </div>

                <!-- Revision info label -->
                <div class="text-end" style="min-width:220px">
                    <div class="small fw-semibold" id="revTitle">—</div>
                    <div class="text-muted" style="font-size:.75rem" id="revMeta">Load comparison data to animate</div>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
@if (Model.IsInitialized)
{
<script src="https://cdn.dhtmlx.com/gantt/edge/dhtmlxgantt.js"></script>
<link  href="https://cdn.dhtmlx.com/gantt/edge/dhtmlxgantt.css" rel="stylesheet" />
<script>
// ── State ──────────────────────────────────────────────────────────────────────
let _compData        = null;   // full ScheduleComparisonDto
let _snapshots       = [];     // RevisionSnapshotDto[]
let _currentFrame    = 0;
let _playTimer       = null;
let _speed           = 1000;   // ms per frame
let _showBaseline    = true;

// ── Gantt Config ───────────────────────────────────────────────────────────────
gantt.config.date_format         = "%Y-%m-%d";
gantt.config.xml_date            = "%Y-%m-%d";
gantt.config.readonly            = true;
gantt.config.show_progress       = true;
gantt.config.open_tree_initially = true;
gantt.config.fit_tasks           = true;

gantt.config.columns = [
    { name:"wbs",      label:"WBS",      width:60,  template: t => t.wbs_code || "" },
    { name:"text",     label:"Activity", width:220, tree:true },
    { name:"start_date", label:"Start",  width:85,  align:"center" },
    { name:"end_date",   label:"Finish", width:85,  align:"center" },
    {
        name:"delta", label:"Delta", width:70, align:"center",
        template: t => {
            if (t.is_baseline) return "";
            if (t.days_shifted == null) return t.is_new ? '<span class="text-primary">New</span>' : "—";
            if (t.days_shifted === 0)   return '<span class="text-success">On Track</span>';
            if (t.days_shifted > 0)     return `<span class="text-warning fw-semibold">+${t.days_shifted}d</span>`;
            return `<span class="text-success">-${Math.abs(t.days_shifted)}d</span>`;
        }
    },
    {
        name:"progress", label:"%", width:45, align:"center",
        template: t => t.is_baseline ? "" : `${Math.round((t.progress||0)*100)}%`
    },
];

// ── Baseline bar overlay ───────────────────────────────────────────────────────
let _baselineLayerKey = null;

function addBaselineLayer() {
    _baselineLayerKey = gantt.addTaskLayer(task => {
        if (!_showBaseline || task.is_baseline || !task.baseline_start || !task.baseline_end) return false;
        const el = document.createElement("div");
        el.className = "baseline-bar";
        const sizes = gantt.getTaskPosition(task,
            gantt.date.parseDate(task.baseline_start, "xml_date"),
            gantt.date.parseDate(task.baseline_end,   "xml_date"));
        el.style.cssText =
            `left:${sizes.left}px;width:${Math.max(sizes.width,4)}px;` +
            `top:${sizes.top + sizes.height - 6}px;height:5px;` +
            `background:#6c757d;opacity:.55;border-radius:2px;position:absolute;`;
        el.title = `Baseline: ${task.baseline_start} → ${task.baseline_end}`;
        return el;
    });
}

// ── Task class by status ───────────────────────────────────────────────────────
gantt.templates.task_class = (start, end, task) => {
    if (task.is_baseline)                        return "gantt-task-baseline-row";
    if (task.is_removed || task.working_status === "Removed") return "gantt-task-removed";
    if (task.is_new)                             return "gantt-task-new";
    if ((task.days_shifted || 0) > 0)            return "gantt-task-delayed";
    if ((task.days_shifted || 0) < 0)            return "gantt-task-ahead";
    return "gantt-task-ontrack";
};

gantt.templates.grid_row_class = (start, end, task) => {
    if (task.is_baseline) return "gantt-row-baseline";
    if (task.is_removed || task.working_status === "Removed") return "gantt-row-removed";
    return "";
};

// ── Init ──────────────────────────────────────────────────────────────────────
gantt.init("comparisonGantt");
addBaselineLayer();

// ── Load data ─────────────────────────────────────────────────────────────────
fetch(`?handler=ComparisonJson&projectId=@Model.ProjectId`)
    .then(r => r.json())
    .then(data => {
        _compData   = data;
        _snapshots  = data.revisionSnapshots || [];

        // Build baseline→date lookup for overlay bars
        const baselineMap = {};
        (data.baselineTasks || []).forEach(b => {
            baselineMap[b.id] = { start: b.start_date, end: b.end_date };
        });

        // Render current (latest) state
        renderFrame(data.workingTasks, baselineMap);

        // Wire up animation controls
        if (_snapshots.length > 0) {
            const slider = document.getElementById('revSlider');
            slider.max       = _snapshots.length - 1;
            slider.value     = _snapshots.length - 1;  // start at latest
            slider.disabled  = false;
            _currentFrame    = _snapshots.length - 1;

            document.getElementById('btnPlay').disabled = false;
            document.getElementById('btnPrev').disabled = false;
            document.getElementById('btnNext').disabled = false;

            showRevisionLabel(_currentFrame);
        }
    })
    .catch(err => console.error("Failed to load comparison data:", err));

// ── Render helpers ────────────────────────────────────────────────────────────

function renderFrame(workingTasks, baselineMap) {
    const tasks = workingTasks.map(w => ({
        id:             w.id,
        text:           w.text,
        start_date:     w.start_date,
        end_date:       w.end_date,
        duration:       w.duration,
        progress:       w.progress || 0,
        parent:         w.parent || 0,
        type:           w.type || "task",
        color:          w.color,
        wbs_code:       w.wbs_code,
        is_new:         w.is_new,
        is_removed:     w.is_removed,
        days_shifted:   w.days_shifted,
        working_status: w.working_status,
        open:           true,
        // Baseline overlay data
        baseline_start: baselineMap[w.baseline_task_id]?.start || null,
        baseline_end:   baselineMap[w.baseline_task_id]?.end   || null,
    }));

    gantt.clearAll();
    gantt.parse({ data: tasks, links: [] });
}

function applySnapshot(snapshotIndex) {
    if (!_compData || snapshotIndex < 0 || snapshotIndex >= _snapshots.length) return;

    const snap = _snapshots[snapshotIndex];

    // Build baseline lookup
    const baselineMap = {};
    (_compData.baselineTasks || []).forEach(b => {
        baselineMap[b.id] = { start: b.start_date, end: b.end_date };
    });

    // Merge snapshot taskStates into working tasks
    const stateById = {};
    (snap.taskStates || []).forEach(ts => { stateById[ts.id] = ts; });

    const merged = (_compData.workingTasks || []).map(w => {
        const ts = stateById[w.id];
        if (!ts) return w;
        return {
            ...w,
            start_date: ts.start_date,
            end_date:   ts.end_date,
            duration:   ts.duration,
            progress:   ts.progress,
            text:       ts.text,
            is_removed: ts.is_removed,
        };
    });

    renderFrame(merged, baselineMap);
    showRevisionLabel(snapshotIndex);
}

function showRevisionLabel(index) {
    if (_snapshots.length === 0) return;
    const snap = _snapshots[index];
    document.getElementById('revTitle').textContent =
        `Rev ${snap.revisionNumber}: ${snap.title}`;
    document.getElementById('revMeta').textContent =
        `Approved ${snap.approvedAt}${snap.approvedBy ? ' · ' + snap.approvedBy : ''}`;
}

// ── Animation controls ────────────────────────────────────────────────────────

function togglePlay() {
    if (_playTimer) {
        pauseAnimation();
    } else {
        playAnimation();
    }
}

function playAnimation() {
    // If at end, restart from beginning
    if (_currentFrame >= _snapshots.length - 1) {
        _currentFrame = 0;
        applySnapshot(0);
        document.getElementById('revSlider').value = 0;
    }

    document.getElementById('playIcon').className = "bi bi-pause-fill";
    _playTimer = setInterval(() => {
        _currentFrame++;
        if (_currentFrame >= _snapshots.length) {
            pauseAnimation();
            return;
        }
        applySnapshot(_currentFrame);
        document.getElementById('revSlider').value = _currentFrame;
    }, _speed);
}

function pauseAnimation() {
    clearInterval(_playTimer);
    _playTimer = null;
    document.getElementById('playIcon').className = "bi bi-play-fill";
}

function stepRevision(delta) {
    pauseAnimation();
    _currentFrame = Math.max(0, Math.min(_snapshots.length - 1, _currentFrame + delta));
    applySnapshot(_currentFrame);
    document.getElementById('revSlider').value = _currentFrame;
}

function onSliderInput(val) {
    pauseAnimation();
    _currentFrame = parseInt(val, 10);
    applySnapshot(_currentFrame);
}

function onSpeedChange(val) {
    _speed = parseInt(val, 10);
    if (_playTimer) {
        pauseAnimation();
        playAnimation();
    }
}

// ── Scale controls ─────────────────────────────────────────────────────────────
function setScale(unit) {
    document.querySelectorAll('#comparisonGantt + * .btn-group .btn, .btn-group .btn')
        .forEach(b => b.classList.remove('active'));
    document.getElementById('btn' + unit.charAt(0).toUpperCase() + unit.slice(1))
        .classList.add('active');
    gantt.config.scale_unit  = unit;
    gantt.config.step        = 1;
    gantt.config.date_scale  = unit === 'day'  ? '%d %M'
                             : unit === 'week' ? 'Week %W'
                             : '%F %Y';
    gantt.config.subscales   = unit === 'month' ? [{ unit:"week", step:1, date:"W%W" }] : [];
    gantt.render();
}

function toggleBaselineLayer(show) {
    _showBaseline = show;
    gantt.render();
}
</script>

<style>
/* ── Working task colours ────────────────────────────────────── */
.gantt-task-ontrack  .gantt_task_content  { background:#198754; border-color:#146c43; }
.gantt-task-ontrack  .gantt_task_progress { background:#12653f; }

.gantt-task-ahead    .gantt_task_content  { background:#0d6efd; border-color:#0a58ca; }
.gantt-task-ahead    .gantt_task_progress { background:#084298; }

.gantt-task-delayed  .gantt_task_content  { background:#ffc107; border-color:#e0a800; color:#000; }
.gantt-task-delayed  .gantt_task_progress { background:#cc9a06; }

.gantt-task-new      .gantt_task_content  { background:#0dcaf0; border-color:#0a9ec2; color:#000; }

.gantt-task-removed  .gantt_task_content  { background:#adb5bd; border-color:#868e96;
                                             text-decoration:line-through; opacity:.5; }
.gantt-row-removed   { opacity:.4; }

/* ── Baseline row (hidden — we only show overlay bars) ───────── */
.gantt-row-baseline  { display:none !important; }
.gantt-task-baseline-row .gantt_task_content { display:none !important; }

/* ── Animation panel ─────────────────────────────────────────── */
#animationPanel { background:#f8f9fa; }
</style>
}
}
