@page
@model ACI.Web.Pages.Projects.IndexModel
@{
    ViewData["Title"] = "Projects";
    ViewData["ActiveMenu"] = "projects";
}

<div class="aci-page-header">
    <div>
        <h1><i class="bi bi-folder2 me-2 text-primary"></i>Projects</h1>
    </div>
    @if (Model.CanCreate)
    {
        <a class="btn btn-primary btn-sm" asp-page="Detail">
            <i class="bi bi-plus-lg me-1"></i>New Project
        </a>
    }
</div>

<div class="p-3">
    <div class="row g-3">
        @foreach (var p in Model.Projects)
        {
            <div class="col-md-4 col-xl-3">
                <div class="aci-card h-100">
                    <div class="card-body">

                        @* 1행: 프로젝트 코드(왼) | Schedule · Active · ✏(오) *@
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="fw-bold text-primary" style="font-size:.95rem;">@p.ProjectCode</span>
                            <div class="d-flex align-items-center gap-1">
                                <span class="badge @GetStatusBadge(p.Status)">@p.Status</span>
                                <a class="btn btn-sm rounded-pill px-3 aci-btn-schedule"
                                   asp-page="/Schedule/Index" asp-route-projectId="@p.Id">
                                    <i class="bi bi-calendar-check-fill me-1"></i>Schedule
                                </a>
                                <a class="aci-icon-edit"
                                   asp-page="Detail" asp-route-id="@p.Id" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </div>
                        </div>

                        @* 2행: 프로젝트 명칭 *@
                        <div class="fw-bold mb-1" style="font-size:.95rem;">@p.Name</div>

                        @* 3~4행: 주소 · 날짜 (들여쓰기) *@
                        <div class="small text-muted mb-3" style="padding-left:1rem; border-left:2px solid #dee2e6;">
                            <div class="mb-1">
                                <i class="bi bi-geo-alt me-1"></i>@(string.IsNullOrWhiteSpace(p.SiteAddress) ? "–" : p.SiteAddress)
                            </div>
                            <div>
                                <i class="bi bi-calendar me-1"></i>
                                @(p.SchdStartDate?.ToString("MMM d, yyyy") ?? "–")
                                ~
                                @(p.ActualEndDate.HasValue
                                    ? p.ActualEndDate.Value.ToString("MMM d, yyyy")
                                    : (p.SchdEndDate?.ToString("MMM d, yyyy") ?? "–"))
                            </div>
                        </div>

                        @* 4행: PM(왼) | Progress bar + %(오) *@
                        <div class="d-flex justify-content-between align-items-center small text-muted">
                            <span><i class="bi bi-person me-1"></i>@(p.PmName ?? "–")</span>
                            <div class="d-flex align-items-center gap-2">
                                <div class="aci-progress" style="width:80px;">
                                    <div class="aci-progress-bar" style="width:@p.OverallProgress%"></div>
                                </div>
                                <span>@p.OverallProgress%</span>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        }

        @if (!Model.Projects.Any())
        {
            <div class="col-12 text-center text-muted py-5">
                <i class="bi bi-folder2-open fs-1"></i>
                <div class="mt-2">No projects found.</div>
                @if (Model.CanCreate)
                {
                    <a class="btn btn-primary mt-3" asp-page="Detail">
                        <i class="bi bi-plus-lg me-1"></i>New Project
                    </a>
                }
            </div>
        }
    </div>
</div>

@functions {
    string GetStatusBadge(ProjectStatus s) => s switch {
        ProjectStatus.Planning  => "badge-planning",
        ProjectStatus.Active    => "badge-active",
        ProjectStatus.OnHold    => "badge-on-hold",
        ProjectStatus.Completed => "badge-completed",
        ProjectStatus.Cancelled => "badge-cancelled",
        _ => "bg-secondary"
    };
}
