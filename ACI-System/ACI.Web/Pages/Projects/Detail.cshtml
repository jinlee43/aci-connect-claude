@page "{id:int?}"
@model ACI.Web.Pages.Projects.DetailModel
@{
    ViewData["Title"] = Model.IsNew ? "New Project" : Model.Input.Name;
    ViewData["ActiveMenu"] = "projects";
}

<div class="aci-page-header">
    <div>
        <h1>
            <i class="bi bi-folder2 me-2 text-primary"></i>
            @(Model.IsNew ? "New Project" : Model.Input.Name)
        </h1>
        @if (!Model.IsNew)
        {
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a asp-page="Index">Projects</a></li>
                    <li class="breadcrumb-item active">@Model.Input.ProjectCode</li>
                </ol>
            </nav>
        }
    </div>
    <a class="btn btn-outline-secondary btn-sm" asp-page="Index">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
</div>

<div class="p-3">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <form method="post">
                @Html.AntiForgeryToken()
                <fieldset disabled="@(!Model.CanEdit)">

                    @* ── 기본 정보 ─────────────────────────────────────── *@
                    <div class="aci-card mb-3">
                        <div class="card-body p-4">
                            <h6 class="fw-semibold mb-3 text-muted text-uppercase small">Project Info</h6>
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold">Project Number <span class="text-danger">*</span></label>
                                    <input asp-for="Input.ProjectCode" class="form-control" placeholder="ACI-2025-001" />
                                    <span asp-validation-for="Input.ProjectCode" class="text-danger small"></span>
                                </div>
                                <div class="col-md-8">
                                    <label class="form-label fw-semibold">Project Name <span class="text-danger">*</span></label>
                                    <input asp-for="Input.Name" class="form-control" placeholder="City Hall Renovation" />
                                    <span asp-validation-for="Input.Name" class="text-danger small"></span>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold">Contract Type</label>
                                    <select asp-for="Input.Type" class="form-select"
                                            asp-items="Html.GetEnumSelectList<ProjectType>()"></select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold">Status</label>
                                    <select asp-for="Input.Status" class="form-select"
                                            asp-items="Html.GetEnumSelectList<ProjectStatus>()"></select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold">Contract Amount ($)</label>
                                    <input asp-for="Input.ContractAmount" type="number" class="form-control"
                                           step="0.01" min="0" />
                                </div>
                                <div class="col-12">
                                    <label class="form-label fw-semibold">Description</label>
                                    <textarea asp-for="Input.Description" class="form-control" rows="2"></textarea>
                                </div>
                            </div>
                        </div>
                    </div>

                    @* ── 현장 주소 ─────────────────────────────────────── *@
                    <div class="aci-card mb-3">
                        <div class="card-body p-4">
                            <h6 class="fw-semibold mb-3 text-muted text-uppercase small">Site Location</h6>
                            <div class="row g-3">
                                <div class="col-12">
                                    <label class="form-label fw-semibold">Address</label>
                                    <input asp-for="Input.SiteAddress" class="form-control" id="siteAddress" />
                                </div>
                                <div class="col-md-5">
                                    <label class="form-label fw-semibold">City</label>
                                    <input asp-for="Input.City" class="form-control" id="siteCity" />
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label fw-semibold">Zip Code</label>
                                    <input asp-for="Input.ZipCode" class="form-control" id="siteZip" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label fw-semibold">State</label>
                                    <input asp-for="Input.State" class="form-control" placeholder="CA" id="siteState" />
                                </div>
                                <div class="col-12">
                                    <hr class="my-1" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label fw-semibold">
                                        Latitude
                                        <span class="text-muted fw-normal small ms-1">(for weather)</span>
                                    </label>
                                    <input asp-for="Input.Latitude" type="number" step="0.000001"
                                           class="form-control" id="siteLatitude"
                                           placeholder="e.g. 34.052235" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label fw-semibold">Longitude</label>
                                    <input asp-for="Input.Longitude" type="number" step="0.000001"
                                           class="form-control" id="siteLongitude"
                                           placeholder="e.g. -118.243683" />
                                </div>
                                @if (Model.CanEdit)
                                {
                                    <div class="col-md-4 d-flex align-items-end">
                                        <div>
                                            <button type="button" class="btn btn-outline-secondary"
                                                    id="geocodeBtn" onclick="geocodeAddress()">
                                                <i class="bi bi-geo-alt me-1"></i>Get Coordinates
                                            </button>
                                            <div id="geocodeStatus" class="small mt-1 text-muted"></div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    @* ── Owner ─────────────────────────────────────────── *@
                    <div class="aci-card mb-3">
                        <div class="card-body p-4">
                            <h6 class="fw-semibold mb-3 text-muted text-uppercase small">Owner / Client</h6>
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold">Owner Name</label>
                                    <input asp-for="Input.OwnerName" class="form-control" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold">Contact</label>
                                    <input asp-for="Input.OwnerContact" class="form-control" placeholder="phone" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold">Email</label>
                                    <input asp-for="Input.OwnerEmail" class="form-control" />
                                </div>
                                <div class="col-12">
                                    <label class="form-label fw-semibold">Address</label>
                                    <input asp-for="Input.OwnerAddress" class="form-control" />
                                </div>
                                <div class="col-md-5">
                                    <label class="form-label fw-semibold">City</label>
                                    <input asp-for="Input.OwnerCity" class="form-control" />
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label fw-semibold">Zip Code</label>
                                    <input asp-for="Input.OwnerZipCode" class="form-control" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label fw-semibold">State</label>
                                    <input asp-for="Input.OwnerState" class="form-control" placeholder="CA" />
                                </div>
                            </div>
                        </div>
                    </div>

                    @* ── 일정 ──────────────────────────────────────────── *@
                    <div class="aci-card mb-3">
                        <div class="card-body p-4">
                            <h6 class="fw-semibold mb-3 text-muted text-uppercase small">Schedule</h6>
                            <div class="row g-3">
                                <div class="col-md-3">
                                    <label class="form-label fw-semibold">Planned Start</label>
                                    <input asp-for="Input.SchdStartDate" type="date" class="form-control" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label fw-semibold">Planned End</label>
                                    <input asp-for="Input.SchdEndDate" type="date" class="form-control" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label fw-semibold">Actual Start</label>
                                    <input asp-for="Input.ActualStartDate" type="date" class="form-control" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label fw-semibold">Actual End</label>
                                    <input asp-for="Input.ActualEndDate" type="date" class="form-control" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label fw-semibold">Completed Date</label>
                                    <input asp-for="Input.CompletedDate" type="date" class="form-control" />
                                </div>
                            </div>
                        </div>
                    </div>

                </fieldset>

                @if (Model.CanEdit)
                {
                    <div class="d-flex justify-content-end gap-2">
                        <a class="btn btn-secondary" asp-page="Index">Cancel</a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-floppy me-1"></i>@(Model.IsNew ? "Create Project" : "Save Changes")
                        </button>
                    </div>
                }
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
async function geocodeAddress() {
    const parts = [
        document.getElementById('siteAddress')?.value  ?? '',
        document.getElementById('siteCity')?.value     ?? '',
        document.getElementById('siteState')?.value    ?? '',
        document.getElementById('siteZip')?.value      ?? '',
    ].map(s => s.trim()).filter(Boolean);

    if (!parts.length) {
        document.getElementById('geocodeStatus').textContent = 'Please enter an address first.';
        return;
    }

    const btn    = document.getElementById('geocodeBtn');
    const status = document.getElementById('geocodeStatus');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Searching…';
    status.textContent = '';

    try {
        const res  = await fetch(
            `https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(parts.join(', '))}&format=json&limit=1`,
            { headers: { 'Accept': 'application/json' } }
        );
        const data = await res.json();

        if (!data.length) {
            status.innerHTML = '<span class="text-danger">Address not found. Check and try again.</span>';
            return;
        }

        const lat = parseFloat(data[0].lat).toFixed(6);
        const lon = parseFloat(data[0].lon).toFixed(6);
        document.getElementById('siteLatitude').value  = lat;
        document.getElementById('siteLongitude').value = lon;

        status.innerHTML =
            `<span class="text-success"><i class="bi bi-check-circle me-1"></i>` +
            `${lat}, ${lon} — ${data[0].display_name.substring(0, 60)}…</span>`;
    } catch (e) {
        status.innerHTML = '<span class="text-danger">Geocoding failed. Please try again.</span>';
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-geo-alt me-1"></i>Get Coordinates';
    }
}
</script>
}
