@page "{id:int?}"
@model ACI.Web.Pages.Projects.DetailModel
@{
    ViewData["Title"] = Model.IsNew ? "New Project" : Model.Input.Name;
    ViewData["ActiveMenu"] = "projects";
}

<div class="aci-page-header">
    <div>
        <h1>
            <i class="bi bi-folder2 me-2 text-primary"></i>
            @(Model.IsNew ? "New Project" : Model.Input.Name)
        </h1>
        @if (!Model.IsNew)
        {
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a asp-page="Index">Projects</a></li>
                    <li class="breadcrumb-item active">@Model.Input.ProjectCode</li>
                </ol>
            </nav>
        }
    </div>
    <a class="btn btn-outline-secondary btn-sm" asp-page="Index">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
</div>

<div class="p-3">
    <div class="row justify-content-center">
        <div class="col-12">
            <form method="post">
                @Html.AntiForgeryToken()
                <fieldset disabled="@(!Model.CanEdit)">

                    @* ── Project Info + Owner — side by side ──────────── *@
                    <div class="d-flex align-items-stretch gap-3 mb-3">

                        @* Project Info card *@
                        <div class="aci-card" style="flex:1 1 0; min-width:0">
                            <div class="card-body p-4">
                                <h6 class="fw-semibold mb-3 text-muted text-uppercase small">Project Info</h6>

                                @* Row 1: Code (left) | spacer | Type (center) | spacer | Status (right) *@
                                <div class="row g-3 align-items-center mb-2">
                                    <div class="col-auto text-end" style="width:7rem">
                                        <label class="col-form-label fw-semibold">Code <span class="text-danger">*</span></label>
                                    </div>
                                    <div class="col-auto" style="width:10.5rem">
                                        <input asp-for="Input.ProjectCode" class="form-control form-control-sm" />
                                        <span asp-validation-for="Input.ProjectCode" class="text-danger small"></span>
                                    </div>
                                    <div class="col-auto text-end" style="width:7rem">
                                        <label class="col-form-label fw-semibold">Type</label>
                                    </div>
                                    <div class="col-auto" style="width:10.5rem">
                                        <select asp-for="Input.Type" class="form-select form-select-sm">
                                            <option value="0">Lump Sum</option>
                                            <option value="1">JOC</option>
                                        </select>
                                    </div>
                                    <div class="col"></div>
                                    <div class="col-auto text-end" style="width:7rem">
                                        <label class="col-form-label fw-semibold">Status</label>
                                    </div>
                                    <div class="col-auto" style="width:7rem">
                                        <select asp-for="Input.Status" class="form-select form-select-sm"
                                                asp-items="Html.GetEnumSelectList<ProjectStatus>()"></select>
                                    </div>
                                </div>

                                @* Row 2: Name | Amount *@
                                <div class="row g-3 align-items-center mb-2">
                                    <div class="col-auto text-end" style="width:7rem">
                                        <label class="col-form-label fw-semibold">Name <span class="text-danger">*</span></label>
                                    </div>
                                    <div class="col">
                                        <input asp-for="Input.Name" class="form-control form-control-sm" />
                                        <span asp-validation-for="Input.Name" class="text-danger small"></span>
                                    </div>
                                    <div class="col-auto text-end" style="width:7rem">
                                        <label class="col-form-label fw-semibold">Amount ($)</label>
                                    </div>
                                    <div class="col-auto" style="width:7rem">
                                        <input asp-for="Input.ContractAmount" type="text" inputmode="numeric"
                                               class="form-control form-control-sm" id="contractAmount" />
                                    </div>
                                </div>

                                @* Row 3: Description *@
                                <div class="row g-3 align-items-start mb-2">
                                    <div class="col-auto text-end" style="width:7rem">
                                        <label class="col-form-label fw-semibold">Description</label>
                                    </div>
                                    <div class="col">
                                        <textarea asp-for="Input.Description" class="form-control form-control-sm" rows="2"></textarea>
                                    </div>
                                </div>

                                @* Row 4: Address | Latitude *@
                                <div class="row g-3 align-items-center mb-2">
                                    <div class="col-auto text-end" style="width:7rem">
                                        <label class="col-form-label fw-semibold">Address</label>
                                    </div>
                                    <div class="col-auto" style="width:26rem">
                                        <input asp-for="Input.SiteAddress" class="form-control form-control-sm" id="siteAddress" />
                                    </div>
                                    <div class="col-auto text-end ms-auto" style="width:7rem">
                                        <label class="col-form-label fw-semibold">Latitude</label>
                                    </div>
                                    <div class="col-auto" style="width:8rem">
                                        <input asp-for="Input.Latitude" type="number" step="0.000001"
                                               class="form-control form-control-sm" id="siteLatitude" />
                                    </div>
                                </div>

                                @* Row 5: Address 2 | Longitude *@
                                <div class="row g-3 align-items-center mb-2">
                                    <div class="col-auto text-end" style="width:7rem">
                                        <label class="col-form-label fw-semibold">Address 2</label>
                                    </div>
                                    <div class="col-auto" style="width:26rem">
                                        <input asp-for="Input.SiteAddress2" class="form-control form-control-sm" />
                                    </div>
                                    <div class="col-auto text-end ms-auto" style="width:7rem">
                                        <label class="col-form-label fw-semibold">Longitude</label>
                                    </div>
                                    <div class="col-auto" style="width:8rem">
                                        <input asp-for="Input.Longitude" type="number" step="0.000001"
                                               class="form-control form-control-sm" id="siteLongitude" />
                                    </div>
                                </div>

                                @* Row 6: City | Zip | State | Get Coordinates *@
                                <div class="row g-3 align-items-center mb-2">
                                    <div class="col-auto text-end" style="width:7rem">
                                        <label class="col-form-label fw-semibold">City</label>
                                    </div>
                                    <div class="col-auto" style="width:10rem">
                                        <input asp-for="Input.City" class="form-control form-control-sm" id="siteCity" />
                                    </div>
                                    <div class="col-auto text-end" style="width:3.5rem">
                                        <label class="col-form-label fw-semibold">Zip</label>
                                    </div>
                                    <div class="col-auto" style="width:5rem">
                                        <input asp-for="Input.ZipCode" class="form-control form-control-sm" id="siteZip" />
                                    </div>
                                    <div class="col-auto text-end" style="width:3.5rem">
                                        <label class="col-form-label fw-semibold">State</label>
                                    </div>
                                    <div class="col-auto" style="width:4rem">
                                        <input asp-for="Input.State" class="form-control form-control-sm"
                                               list="usStateList" autocomplete="off" placeholder="CA" id="siteState" />
                                    </div>
                                    @if (Model.CanEdit)
                                    {
                                        <div class="col-auto ms-auto">
                                            <button type="button" class="btn btn-sm btn-outline-secondary"
                                                    id="geocodeBtn" onclick="geocodeAddress()">
                                                <i class="bi bi-geo-alt me-1"></i>Get Coordinates
                                            </button>
                                            <div id="geocodeStatus" class="small mt-1 text-muted"></div>
                                        </div>
                                    }
                                </div>

                                @* ── Schedule ─── *@
                                <p class="text-muted small fw-semibold text-uppercase mb-2 mt-3" style="font-size:0.7rem; letter-spacing:.05em">Schedule</p>

                                @* 3-column date layout: Start | Planned End + Actual End | Completed *@
                                <div class="d-flex align-items-start gap-4 mb-2">

                                    @* Col 1: Start *@
                                    <div class="d-flex align-items-center gap-2">
                                        <label class="col-form-label fw-semibold text-end" style="width:4rem">Start</label>
                                        <input asp-for="Input.ActualStartDate" type="date" class="form-control form-control-sm" style="width:9rem" />
                                    </div>

                                    @* Col 2: Planned End (top) + Actual End (bottom) *@
                                    <div class="d-flex flex-column gap-2">
                                        <div class="d-flex align-items-center gap-2">
                                            <label class="col-form-label fw-semibold text-end" style="width:7rem">Planned End</label>
                                            <input asp-for="Input.SchdEndDate" type="date" class="form-control form-control-sm" style="width:9rem" />
                                        </div>
                                        <div class="d-flex align-items-center gap-2">
                                            <label class="col-form-label fw-semibold text-end" style="width:7rem">Actual End</label>
                                            <input asp-for="Input.ActualEndDate" type="date" class="form-control form-control-sm" style="width:9rem" />
                                        </div>
                                    </div>

                                    @* Col 3: Completed *@
                                    <div class="d-flex align-items-center gap-2">
                                        <label class="col-form-label fw-semibold text-end" style="width:6rem">Completed</label>
                                        <input asp-for="Input.CompletedDate" type="date" class="form-control form-control-sm" style="width:9rem" />
                                    </div>

                                </div>

                            </div>
                        </div>

                        @* Owner / Client card *@
                        <div class="aci-card" style="flex:1 1 0; min-width:0">
                            <div class="card-body p-4">
                                <h6 class="fw-semibold mb-3 text-muted text-uppercase small">Owner / Client</h6>

                                @* ── Organization ─── *@
                                <p class="text-muted small fw-semibold text-uppercase mb-2" style="font-size:0.7rem; letter-spacing:.05em">Organization</p>

                                @* Name | Phone *@
                                <div class="row g-3 align-items-center mb-2">
                                    <div class="col-auto text-end" style="width:6rem">
                                        <label class="col-form-label fw-semibold">Name</label>
                                    </div>
                                    <div class="col">
                                        <input asp-for="Input.OwnerName" class="form-control form-control-sm" />
                                    </div>
                                    <div class="col-auto text-end" style="width:5rem">
                                        <label class="col-form-label fw-semibold">Phone</label>
                                    </div>
                                    <div class="col-auto" style="width:11rem">
                                        <input asp-for="Input.OwnerPhone" class="form-control form-control-sm" />
                                    </div>
                                </div>

                                @* Address | Address 2 *@
                                <div class="row g-3 align-items-center mb-2">
                                    <div class="col-auto text-end" style="width:6rem">
                                        <label class="col-form-label fw-semibold">Address</label>
                                    </div>
                                    <div class="col">
                                        <input asp-for="Input.OwnerAddress" class="form-control form-control-sm" />
                                    </div>
                                    <div class="col-auto text-end" style="width:5rem">
                                        <label class="col-form-label fw-semibold">Addr 2</label>
                                    </div>
                                    <div class="col-auto" style="width:15rem">
                                        <input asp-for="Input.OwnerAddress2" class="form-control form-control-sm" />
                                    </div>
                                </div>

                                @* City | Zip | State *@
                                <div class="row g-3 align-items-center mb-3">
                                    <div class="col-auto text-end" style="width:6rem">
                                        <label class="col-form-label fw-semibold">City</label>
                                    </div>
                                    <div class="col-auto" style="width:15rem">
                                        <input asp-for="Input.OwnerCity" class="form-control form-control-sm" />
                                    </div>
                                    <div class="col-auto text-end" style="width:3rem">
                                        <label class="col-form-label fw-semibold">Zip</label>
                                    </div>
                                    <div class="col-auto" style="width:5rem">
                                        <input asp-for="Input.OwnerZipCode" class="form-control form-control-sm" />
                                    </div>
                                    <div class="col-auto text-end" style="width:3.5rem">
                                        <label class="col-form-label fw-semibold">State</label>
                                    </div>
                                    <div class="col-auto" style="width:4rem">
                                        <input asp-for="Input.OwnerState" class="form-control form-control-sm"
                                               list="usStateList" autocomplete="off" placeholder="CA" />
                                    </div>
                                </div>

                                @* ── Primary Contact ─── *@
                                <p class="text-muted small fw-semibold text-uppercase mb-2" style="font-size:0.7rem; letter-spacing:.05em">Primary Contact</p>

                                @* Name | Title *@
                                <div class="row g-3 align-items-center mb-2">
                                    <div class="col-auto text-end" style="width:6rem">
                                        <label class="col-form-label fw-semibold">Name</label>
                                    </div>
                                    <div class="col">
                                        <input asp-for="Input.OwnerContact1Name" class="form-control form-control-sm" />
                                    </div>
                                    <div class="col-auto text-end" style="width:5rem">
                                        <label class="col-form-label fw-semibold">Title</label>
                                    </div>
                                    <div class="col-auto" style="width:20rem">
                                        <input asp-for="Input.OwnerContact1Title" class="form-control form-control-sm" />
                                    </div>
                                </div>

                                @* Phone | Cell | Email *@
                                <div class="row g-3 align-items-center mb-3">
                                    <div class="col-auto text-end" style="width:6rem">
                                        <label class="col-form-label fw-semibold">Phone</label>
                                    </div>
                                    <div class="col-auto" style="width:8rem">
                                        <input asp-for="Input.OwnerContact1Phone" class="form-control form-control-sm" />
                                    </div>
                                    <div class="col-auto text-end" style="width:4rem">
                                        <label class="col-form-label fw-semibold">Cell</label>
                                    </div>
                                    <div class="col-auto" style="width:8rem">
                                        <input asp-for="Input.OwnerContact1Cell" class="form-control form-control-sm" />
                                    </div>
                                    <div class="col-auto text-end" style="width:4rem">
                                        <label class="col-form-label fw-semibold">Email</label>
                                    </div>
                                    <div class="col">
                                        <input asp-for="Input.OwnerContact1Email" class="form-control form-control-sm" />
                                    </div>
                                </div>

                                @* ── Secondary Contact ─── *@
                                <p class="text-muted small fw-semibold text-uppercase mb-2" style="font-size:0.7rem; letter-spacing:.05em">Secondary Contact</p>

                                @* Name | Title *@
                                <div class="row g-3 align-items-center mb-2">
                                    <div class="col-auto text-end" style="width:6rem">
                                        <label class="col-form-label fw-semibold">Name</label>
                                    </div>
                                    <div class="col">
                                        <input asp-for="Input.OwnerContact2Name" class="form-control form-control-sm" />
                                    </div>
                                    <div class="col-auto text-end" style="width:5rem">
                                        <label class="col-form-label fw-semibold">Title</label>
                                    </div>
                                    <div class="col-auto" style="width:20rem">
                                        <input asp-for="Input.OwnerContact2Title" class="form-control form-control-sm" />
                                    </div>
                                </div>

                                @* Phone | Cell | Email *@
                                <div class="row g-3 align-items-center">
                                    <div class="col-auto text-end" style="width:6rem">
                                        <label class="col-form-label fw-semibold">Phone</label>
                                    </div>
                                    <div class="col-auto" style="width:8rem">
                                        <input asp-for="Input.OwnerContact2Phone" class="form-control form-control-sm" />
                                    </div>
                                    <div class="col-auto text-end" style="width:4rem">
                                        <label class="col-form-label fw-semibold">Cell</label>
                                    </div>
                                    <div class="col-auto" style="width:8rem">
                                        <input asp-for="Input.OwnerContact2Cell" class="form-control form-control-sm" />
                                    </div>
                                    <div class="col-auto text-end" style="width:4rem">
                                        <label class="col-form-label fw-semibold">Email</label>
                                    </div>
                                    <div class="col">
                                        <input asp-for="Input.OwnerContact2Email" class="form-control form-control-sm" />
                                    </div>
                                </div>

                            </div>
                        </div>

                    </div>

                    @* ── US State datalist (shared by Site + Owner state inputs) *@
                    <datalist id="usStateList">
                        <option value="AL" /><option value="AK" /><option value="AZ" /><option value="AR" />
                        <option value="CA" /><option value="CO" /><option value="CT" /><option value="DE" />
                        <option value="FL" /><option value="GA" /><option value="HI" /><option value="ID" />
                        <option value="IL" /><option value="IN" /><option value="IA" /><option value="KS" />
                        <option value="KY" /><option value="LA" /><option value="ME" /><option value="MD" />
                        <option value="MA" /><option value="MI" /><option value="MN" /><option value="MS" />
                        <option value="MO" /><option value="MT" /><option value="NE" /><option value="NV" />
                        <option value="NH" /><option value="NJ" /><option value="NM" /><option value="NY" />
                        <option value="NC" /><option value="ND" /><option value="OH" /><option value="OK" />
                        <option value="OR" /><option value="PA" /><option value="RI" /><option value="SC" />
                        <option value="SD" /><option value="TN" /><option value="TX" /><option value="UT" />
                        <option value="VT" /><option value="VA" /><option value="WA" /><option value="WV" />
                        <option value="WI" /><option value="WY" />
                    </datalist>


                </fieldset>

                @if (Model.CanEdit)
                {
                    <div class="d-flex justify-content-end gap-2">
                        <a class="btn btn-secondary" asp-page="Index">Cancel</a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-floppy me-1"></i>@(Model.IsNew ? "Create Project" : "Save Changes")
                        </button>
                    </div>
                }
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
// Contract Amount — 달러 정수 (쉼표 포맷, 센트 없음)
document.addEventListener('DOMContentLoaded', function () {
    const el = document.getElementById('contractAmount');
    if (!el) return;

    function fmt(raw) {
        const n = parseInt(raw.replace(/[^0-9]/g, ''), 10);
        return isNaN(n) ? '' : n.toLocaleString('en-US');
    }

    // 기존 값 포맷 (편집 시 raw decimal → 1,250,000)
    if (el.value) el.value = fmt(el.value);

    el.addEventListener('input', function () {
        const pos = this.selectionStart;
        const before = (this.value.substring(0, pos).match(/[0-9]/g) || []).length;
        this.value = fmt(this.value);
        // 커서 위치 복원
        let cnt = 0, i = 0;
        while (i < this.value.length && cnt < before) {
            if (/[0-9]/.test(this.value[i])) cnt++;
            i++;
        }
        this.setSelectionRange(i, i);
    });

    // 제출 전 쉼표 제거 → 서버 decimal 바인딩
    el.form?.addEventListener('submit', function () {
        el.value = el.value.replace(/[^0-9]/g, '') || '0';
    });
});
</script>
<script>
async function geocodeAddress() {
    const parts = [
        document.getElementById('siteAddress')?.value  ?? '',
        document.getElementById('siteCity')?.value     ?? '',
        document.getElementById('siteState')?.value    ?? '',
        document.getElementById('siteZip')?.value      ?? '',
    ].map(s => s.trim()).filter(Boolean);

    if (!parts.length) {
        document.getElementById('geocodeStatus').textContent = 'Please enter an address first.';
        return;
    }

    const btn    = document.getElementById('geocodeBtn');
    const status = document.getElementById('geocodeStatus');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Searching…';
    status.textContent = '';

    try {
        const res  = await fetch(
            `https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(parts.join(', '))}&format=json&limit=1`,
            { headers: { 'Accept': 'application/json' } }
        );
        const data = await res.json();

        if (!data.length) {
            status.innerHTML = '<span class="text-danger">Address not found. Check and try again.</span>';
            return;
        }

        const lat = parseFloat(data[0].lat).toFixed(6);
        const lon = parseFloat(data[0].lon).toFixed(6);
        document.getElementById('siteLatitude').value  = lat;
        document.getElementById('siteLongitude').value = lon;

        status.innerHTML =
            `<span class="text-success"><i class="bi bi-check-circle me-1"></i>` +
            `${lat}, ${lon} — ${data[0].display_name.substring(0, 60)}…</span>`;
    } catch (e) {
        status.innerHTML = '<span class="text-danger">Geocoding failed. Please try again.</span>';
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-geo-alt me-1"></i>Get Coordinates';
    }
}
</script>
}
