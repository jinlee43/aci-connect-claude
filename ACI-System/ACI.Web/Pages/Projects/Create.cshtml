@page
@model ACI.Web.Pages.Projects.CreateModel
@{
    ViewData["Title"] = "New Project";
    ViewData["ActiveMenu"] = "projects";
}

<div class="aci-page-header">
    <div>
        <h1><i class="bi bi-plus-circle me-2 text-primary"></i>New Project</h1>
    </div>
    <a class="btn btn-outline-secondary btn-sm" asp-page="Index">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
</div>

<div class="p-3">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="aci-card">
                <div class="card-body p-4">
                    <form method="post">
                        <div class="row g-3">
                            <!-- Project Number -->
                            <div class="col-md-4">
                                <label asp-for="Input.ProjectCode" class="form-label">Project Number *</label>
                                <input asp-for="Input.ProjectCode" class="form-control"
                                       placeholder="ACI-2024-001" />
                                <span asp-validation-for="Input.ProjectCode" class="text-danger small"></span>
                            </div>
                            <!-- Project Name -->
                            <div class="col-md-8">
                                <label asp-for="Input.Name" class="form-label">Project Name *</label>
                                <input asp-for="Input.Name" class="form-control"
                                       placeholder="City Hall Renovation" />
                                <span asp-validation-for="Input.Name" class="text-danger small"></span>
                            </div>
                            <!-- Type -->
                            <div class="col-md-4">
                                <label asp-for="Input.Type" class="form-label">Contract Type *</label>
                                <select asp-for="Input.Type" class="form-select"
                                        asp-items="Html.GetEnumSelectList<ProjectType>()"></select>
                            </div>
                            <!-- Status -->
                            <div class="col-md-4">
                                <label asp-for="Input.Status" class="form-label">Status</label>
                                <select asp-for="Input.Status" class="form-select"
                                        asp-items="Html.GetEnumSelectList<ProjectStatus>()"></select>
                            </div>
                            <!-- Contract Amount -->
                            <div class="col-md-4">
                                <label asp-for="Input.ContractAmount" class="form-label">Contract Amount ($)</label>
                                <input asp-for="Input.ContractAmount" type="number" class="form-control"
                                       step="0.01" min="0" />
                            </div>
                            <!-- Address -->
                            <div class="col-md-8">
                                <label asp-for="Input.SiteAddress" class="form-label">Address</label>
                                <input asp-for="Input.SiteAddress" class="form-control" />
                            </div>
                            <!-- City -->
                            <div class="col-md-4">
                                <label asp-for="Input.City" class="form-label">City</label>
                                <input asp-for="Input.City" class="form-control"
                                       placeholder="Los Angeles, CA" />
                            </div>
                            <!-- Dates -->
                            <div class="col-md-6">
                                <label asp-for="Input.SchdStartDate" class="form-label">Planned Start *</label>
                                <input asp-for="Input.SchdStartDate" type="date" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Input.SchdEndDate" class="form-label">Planned End *</label>
                                <input asp-for="Input.SchdEndDate" type="date" class="form-control" />
                            </div>
                            <!-- Owner -->
                            <div class="col-md-6">
                                <label asp-for="Input.OwnerName" class="form-label">Owner / Client</label>
                                <input asp-for="Input.OwnerName" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Input.OwnerEmail" class="form-label">Owner Contact</label>
                                <input asp-for="Input.OwnerEmail" class="form-control"
                                       placeholder="email or phone" />
                            </div>
                            <!-- Description -->
                            <div class="col-12">
                                <label asp-for="Input.Description" class="form-label">Description</label>
                                <textarea asp-for="Input.Description" class="form-control" rows="3"></textarea>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <a class="btn btn-secondary" asp-page="Index">Cancel</a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-lg me-1"></i>Create Project
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
