@page
@model ACI.Web.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Sign In";
    Layout = "_LayoutNoNav";
}

<div class="min-vh-100 d-flex align-items-center justify-content-center bg-light">
    <div class="card shadow-sm" style="width:380px">
        <div class="card-body p-4">
            <!-- Logo -->
            <div class="text-center mb-4">
                <div class="bg-primary d-inline-flex align-items-center justify-content-center rounded-3 mb-3"
                     style="width:56px;height:56px">
                    <i class="bi bi-building text-white fs-3"></i>
                </div>
                <h4 class="fw-bold mb-0">ACI Project System</h4>
                <p class="text-muted small">Angeles Contractor Inc.</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger py-2">
                    <i class="bi bi-exclamation-circle me-2"></i>@Model.ErrorMessage
                </div>
            }

            <form method="post">
                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label">Email</label>
                    <input asp-for="Input.Email" type="email" class="form-control"
                           placeholder="you@aci-la.com" autofocus />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label">Password</label>
                    <input asp-for="Input.Password" type="password" class="form-control" />
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>
                <div class="mb-3 form-check">
                    <input asp-for="Input.RememberMe" type="checkbox" class="form-check-input" />
                    <label asp-for="Input.RememberMe" class="form-check-label">Remember me</label>
                </div>
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                </button>
            </form>
        </div>
        <div class="card-footer text-center text-muted small py-2">
            Angeles Contractor Inc. © @DateTime.Now.Year
        </div>
    </div>
</div>
