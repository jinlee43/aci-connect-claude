@page
@model ACI.Web.Pages.Account.AccessDeniedModel
@{
    ViewData["Title"] = "Access Denied";
    Layout = "_Layout";
}

<div class="container" style="max-width: 600px; margin-top: 80px;">
    <div class="card border-danger shadow-sm">
        <div class="card-body text-center p-5">
            <i class="bi bi-shield-lock text-danger" style="font-size: 3rem;"></i>
            <h3 class="mt-3 mb-2">Access Denied</h3>
            <p class="text-muted mb-4">
                You don't have permission to access this page.<br />
                Please contact the System Admin or HR Admin if you need access.
            </p>
            <div class="d-flex justify-content-center gap-2">
                <a asp-page="/Index" class="btn btn-primary">
                    <i class="bi bi-house me-1"></i>Home
                </a>
                <a asp-page="/Account/Logout" class="btn btn-outline-secondary">
                    <i class="bi bi-box-arrow-right me-1"></i>Sign in as another user
                </a>
            </div>
            @if (!string.IsNullOrEmpty(Model.ReturnUrl))
            {
                <p class="text-muted small mt-3 mb-0">
                    Requested path: <code>@Model.ReturnUrl</code>
                </p>
            }
        </div>
    </div>
</div>
