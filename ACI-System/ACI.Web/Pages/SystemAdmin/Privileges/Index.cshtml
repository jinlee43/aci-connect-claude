@page
@model ACI.Web.Pages.SystemAdmin.Privileges.IndexModel
@{
    ViewData["Title"] = "Privileges";
    ViewData["ActiveMenu"] = "privileges";
}

<div class="p-3">
    <!-- Header -->
    <div class="d-flex align-items-center gap-2 mb-3">
        <span class="badge" style="background:#6f42c1;font-size:0.9rem;">
            <i class="bi bi-shield-lock me-1"></i>System Admin
        </span>
        <h5 class="mb-0 fw-bold"><i class="bi bi-key me-2"></i>Privileges</h5>
    </div>

    <div class="alert alert-warning small py-2 mb-3">
        <i class="bi bi-exclamation-triangle me-1"></i>
        <strong>Warning:</strong> A privilege's <code>Code</code> is the authorization key used by
        <code>Program.cs</code> policies. Built-in codes cannot be changed. Creating a new custom
        code here does NOT automatically grant access anywhere — you must wire it up in code first.
    </div>

    <!-- New Privilege Form -->
    <div class="card shadow-sm mb-3">
        <div class="card-header py-2 fw-semibold">
            <i class="bi bi-plus-circle me-2 text-primary"></i>Add Custom Privilege
        </div>
        <div class="card-body">
            <form method="post" asp-page-handler="Create" class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small fw-semibold">Code <span class="text-danger">*</span></label>
                    <input asp-for="NewCode" class="form-control form-control-sm font-monospace"
                           placeholder="e.g. AccountingAdmin" required />
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-semibold">Display Name <span class="text-danger">*</span></label>
                    <input asp-for="NewName" class="form-control form-control-sm"
                           placeholder="e.g. Accounting Admin" required />
                </div>
                <div class="col-md-5">
                    <label class="form-label small fw-semibold">Description</label>
                    <input asp-for="NewDescription" class="form-control form-control-sm"
                           placeholder="What this privilege grants" />
                </div>
                <div class="col-md-1">
                    <button type="submit" class="btn btn-primary btn-sm w-100">
                        <i class="bi bi-plus-lg"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Privilege List -->
    <div class="card shadow-sm">
        <div class="card-header py-2 fw-semibold d-flex justify-content-between">
            <span><i class="bi bi-list-ul me-2"></i>All Privileges</span>
            <span class="small text-muted">@Model.Privileges.Count total</span>
        </div>
        <div class="table-responsive">
            <table class="table table-sm table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width:40px;"></th>
                        <th style="width:180px;">Code</th>
                        <th style="width:200px;">Name</th>
                        <th>Description</th>
                        <th class="text-center" style="width:80px;">Users</th>
                        <th class="text-center" style="width:80px;">Active</th>
                        <th class="text-end" style="width:140px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Privileges)
                    {
                        var isEditingThis = Model.IsEditing && Model.EditId == p.Id;
                        if (isEditingThis)
                        {
                            <tr class="table-warning">
                                <td colspan="7">
                                    <form method="post" asp-page-handler="Update" class="row g-2 align-items-center">
                                        <input type="hidden" asp-for="EditId" />
                                        <div class="col-md-2">
                                            <label class="form-label small mb-0">Code</label>
                                            <input asp-for="EditCode" class="form-control form-control-sm font-monospace"
                                                   readonly="@p.IsBuiltIn" />
                                            @if (p.IsBuiltIn)
                                            {
                                                <small class="text-muted">Built-in — locked</small>
                                            }
                                        </div>
                                        <div class="col-md-2">
                                            <label class="form-label small mb-0">Name</label>
                                            <input asp-for="EditName" class="form-control form-control-sm" required />
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label small mb-0">Description</label>
                                            <input asp-for="EditDescription" class="form-control form-control-sm" />
                                        </div>
                                        <div class="col-md-1 text-center">
                                            <label class="form-label small mb-0 d-block">Active</label>
                                            <div class="form-check d-inline-block">
                                                <input asp-for="EditIsActive" class="form-check-input" type="checkbox" />
                                            </div>
                                        </div>
                                        <div class="col-md-3 text-end">
                                            <button type="submit" class="btn btn-primary btn-sm">
                                                <i class="bi bi-check-lg me-1"></i>Save
                                            </button>
                                            <a asp-page="Index" class="btn btn-outline-secondary btn-sm">Cancel</a>
                                        </div>
                                    </form>
                                </td>
                            </tr>
                        }
                        else
                        {
                            <tr class="@(p.IsActive ? "" : "text-muted")">
                                <td class="text-center">
                                    @if (p.IsBuiltIn)
                                    {
                                        <i class="bi bi-lock-fill text-secondary" title="Built-in"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-pencil-square text-primary" title="Custom"></i>
                                    }
                                </td>
                                <td><code>@p.Code</code></td>
                                <td class="fw-semibold">@p.Name</td>
                                <td class="small text-muted">@p.Description</td>
                                <td class="text-center">
                                    <span class="badge bg-secondary">@p.UserPrivileges.Count</span>
                                </td>
                                <td class="text-center">
                                    @if (p.IsActive)
                                    {
                                        <span class="badge bg-success">Yes</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">No</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <a asp-page="Index" asp-route-editId="@p.Id"
                                       class="btn btn-outline-secondary btn-sm py-0 px-2" title="Edit">
                                        <i class="bi bi-pencil" style="font-size:0.75rem"></i>
                                    </a>
                                    @if (!p.IsBuiltIn)
                                    {
                                        <form method="post" asp-page-handler="Delete"
                                              asp-route-id="@p.Id" class="d-inline"
                                              id="frm-delete-privilege-@p.Id">
                                            <button type="button" class="btn btn-outline-danger btn-sm py-0 px-2" title="Delete"
                                                    onclick="confirmAction('frm-delete-privilege-@p.Id', 'Delete Privilege', 'Delete privilege @p.Code? This cannot be undone.')">
                                                <i class="bi bi-trash" style="font-size:0.75rem"></i>
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
