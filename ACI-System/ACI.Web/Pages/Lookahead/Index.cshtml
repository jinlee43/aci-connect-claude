@page "{projectId:int}"
@model ACI.Web.Pages.Lookahead.IndexModel
@{
    ViewData["Title"] = "Lookahead Schedule";
    ViewData["ActiveMenu"] = "lookahead";
    ViewData["CurrentProjectId"] = Model.ProjectId;
    ViewData["CurrentProjectName"] = Model.ProjectName;
}

<div class="aci-page-header">
    <div>
        <h1><i class="bi bi-calendar3-range me-2 text-primary"></i>Lookahead Schedule</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-page="/Projects/Index">Projects</a></li>
                <li class="breadcrumb-item"><a asp-page="/Schedule/Index" asp-route-projectId="@Model.ProjectId">@Model.ProjectName</a></li>
                <li class="breadcrumb-item active">Lookahead</li>
            </ol>
        </nav>
    </div>
    <div class="d-flex gap-2">
        <!-- Weeks selector -->
        <div class="btn-group btn-group-sm">
            <button class="btn @(Model.Weeks == 3 ? "btn-primary" : "btn-outline-secondary")"
                    hx-get="?projectId=@Model.ProjectId&weeks=3&lookaheadId=@Model.CurrentLookaheadId"
                    hx-target="#lookahead-content" hx-swap="outerHTML">3W</button>
            <button class="btn @(Model.Weeks == 4 ? "btn-primary" : "btn-outline-secondary")"
                    hx-get="?projectId=@Model.ProjectId&weeks=4&lookaheadId=@Model.CurrentLookaheadId"
                    hx-target="#lookahead-content" hx-swap="outerHTML">4W</button>
            <button class="btn @(Model.Weeks == 6 ? "btn-primary" : "btn-outline-secondary")"
                    hx-get="?projectId=@Model.ProjectId&weeks=6&lookaheadId=@Model.CurrentLookaheadId"
                    hx-target="#lookahead-content" hx-swap="outerHTML">6W</button>
        </div>
        <!-- Trade filter -->
        <select class="form-select form-select-sm" style="width:160px" id="tradeFilter"
                onchange="filterByTrade(this.value)">
            <option value="">All Trades</option>
            @foreach (var t in Model.Trades)
            {
                <option value="@t.Id">@t.Name</option>
            }
        </select>
        <button class="btn btn-sm btn-success" data-bs-toggle="modal" data-bs-target="#addTaskModal">
            <i class="bi bi-plus-lg me-1"></i>Add Task
        </button>
        <button class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-download me-1"></i>Export
        </button>
    </div>
</div>

<!-- Lookahead Grid -->
<div id="lookahead-content" class="p-3">

    <!-- Week column headers -->
    <div class="d-flex overflow-auto">
        <!-- Trade column -->
        <div style="min-width:220px; max-width:220px;" class="pe-2">
            <div class="fw-semibold text-muted small text-uppercase mb-2 pt-2">Activity</div>
        </div>
        @for (int w = 0; w < Model.Weeks; w++)
        {
            var weekStart = Model.PeriodStart.AddDays(w * 7);
            var weekEnd = weekStart.AddDays(4);
            var today = DateOnly.FromDateTime(DateTime.Today);
            var isCurrentWeek = today >= weekStart && today <= weekEnd.AddDays(2);
            <div class="lookahead-week-col flex-fill @(isCurrentWeek ? "bg-primary bg-opacity-5" : "")">
                <div class="text-center py-2 border-bottom">
                    <div class="fw-bold small">@weekStart.ToString("MMM d") – @weekEnd.ToString("MMM d")</div>
                    <div class="text-muted" style="font-size:.7rem">Week @(System.Globalization.ISOWeek.GetWeekOfYear(weekStart.ToDateTime(TimeOnly.MinValue)))</div>
                    @if (isCurrentWeek)
                    {
                        <span class="badge bg-primary" style="font-size:.65rem">CURRENT</span>
                    }
                </div>
            </div>
        }
    </div>

    <!-- Tasks by Trade -->
    @foreach (var tradeGroup in Model.TasksByTrade)
    {
        <div class="trade-section mb-2" data-trade-id="@tradeGroup.TradeId">
            <!-- Trade header -->
            <div class="d-flex align-items-center px-2 py-1 rounded-1 mt-2"
                 style="background:@tradeGroup.TradeColor20; border-left:4px solid @tradeGroup.TradeColor; cursor:pointer"
                 onclick="toggleTradeSection(this)">
                <i class="bi bi-chevron-down me-2 small toggle-icon"></i>
                <span class="fw-semibold small" style="color:@tradeGroup.TradeColor">@tradeGroup.TradeName</span>
                <span class="badge ms-2" style="background:@tradeGroup.TradeColor20; color:@tradeGroup.TradeColor">
                    @tradeGroup.Tasks.Count tasks
                </span>
            </div>

            <!-- Task rows -->
            <div class="trade-tasks">
                @foreach (var task in tradeGroup.Tasks)
                {
                    <div class="d-flex lookahead-task-row @(task.HasConstraint ? "has-constraint" : "")"
                         data-task-id="@task.Id">
                        <!-- Task name -->
                        <div style="min-width:220px; max-width:220px;" class="pe-2 py-1">
                            <div class="lookahead-task-card">
                                @if (task.HasConstraint)
                                {
                                    <i class="bi bi-exclamation-triangle-fill text-warning me-1" title="Has Constraint"></i>
                                }
                                <span class="fw-medium">@task.Text</span>
                                @if (!string.IsNullOrEmpty(task.Location))
                                {
                                    <div class="text-muted small"><i class="bi bi-geo-alt me-1"></i>@task.Location</div>
                                }
                                @if (!string.IsNullOrEmpty(task.AssigneeName))
                                {
                                    <div class="text-muted small"><i class="bi bi-person me-1"></i>@task.AssigneeName</div>
                                }
                            </div>
                        </div>
                        <!-- Week cells -->
                        @for (int w = 0; w < Model.Weeks; w++)
                        {
                            var weekStart = Model.PeriodStart.AddDays(w * 7);
                            var weekEnd = weekStart.AddDays(6);
                            var taskSpansWeek = task.StartDate <= weekEnd && task.EndDate >= weekStart;
                            <div class="lookahead-week-col flex-fill py-1 px-1">
                                @if (taskSpansWeek)
                                {
                                    var barColor = tradeGroup.TradeColor;
                                    <div class="rounded px-2 py-1 text-white small text-center"
                                         style="background:@barColor; min-height:32px; display:flex; align-items:center; justify-content:center;">
                                        @if (task.CrewSize > 0)
                                        {
                                            <i class="bi bi-people me-1"></i>
                                            <span>@task.CrewSize</span>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }

    @if (!Model.TasksByTrade.Any())
    {
        <div class="text-center text-muted py-5">
            <i class="bi bi-calendar-x fs-1"></i>
            <div class="mt-2">No tasks for this period. Pull from Master Schedule or add manually.</div>
            <button class="btn btn-primary mt-3" onclick="pullFromSchedule()">
                <i class="bi bi-arrow-down-circle me-1"></i>Pull from Master Schedule
            </button>
        </div>
    }

</div>

<!-- Add Task Modal -->
<div class="modal fade" id="addTaskModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add Lookahead Task</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="AddTask">
                <div class="modal-body">
                    <input type="hidden" name="LookaheadId" value="@Model.CurrentLookaheadId" />
                    <div class="mb-3">
                        <label class="form-label">Activity Name *</label>
                        <input type="text" name="Text" class="form-control" required />
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col">
                            <label class="form-label">Start Date *</label>
                            <input type="date" name="StartDate" class="form-control" required />
                        </div>
                        <div class="col">
                            <label class="form-label">Duration (days) *</label>
                            <input type="number" name="Duration" class="form-control" min="1" value="5" required />
                        </div>
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col">
                            <label class="form-label">Trade</label>
                            <select name="TradeId" class="form-select">
                                <option value="">-- Select --</option>
                                @foreach (var t in Model.Trades)
                                {
                                    <option value="@t.Id">@t.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col">
                            <label class="form-label">Crew Size</label>
                            <input type="number" name="CrewSize" class="form-control" min="0" value="0" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Assignee</label>
                        <input type="text" name="AssigneeName" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Location</label>
                        <input type="text" name="Location" class="form-control" placeholder="e.g. Floor 3, Zone A" />
                    </div>
                    <div class="form-check">
                        <input type="checkbox" name="HasConstraint" class="form-check-input" id="hasConstraint" />
                        <label class="form-check-label" for="hasConstraint">Has Constraint</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Add Task</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
function toggleTradeSection(header) {
    const tasks = header.nextElementSibling;
    const icon = header.querySelector('.toggle-icon');
    tasks.style.display = tasks.style.display === 'none' ? '' : 'none';
    icon.classList.toggle('bi-chevron-down');
    icon.classList.toggle('bi-chevron-right');
}
function filterByTrade(tradeId) {
    document.querySelectorAll('.trade-section').forEach(s => {
        s.style.display = (!tradeId || s.dataset.tradeId === tradeId) ? '' : 'none';
    });
}
</script>
}
