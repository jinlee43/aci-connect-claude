@page "{id:int}"
@model ACI.Web.Pages.Hr.Employees.AdminDetailModel
@{
    ViewData["Title"] = $"HR Admin — {Model.EmpDisplayName}";
    ViewData["ActiveMenu"] = "employees";
}

<div class="p-3">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb small">
            <li class="breadcrumb-item"><a asp-page="Index">Employees</a></li>
            <li class="breadcrumb-item"><a asp-page="Detail" asp-route-id="@Model.Emp.Id">@Model.EmpDisplayName</a></li>
            <li class="breadcrumb-item active">HR Admin</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="d-flex align-items-center gap-2 mb-3">
        <span class="badge bg-danger fs-6 px-3 py-2">
            <i class="bi bi-shield-lock me-1"></i>HR Admin Only
        </span>
        <h5 class="mb-0 fw-bold">@Model.EmpDisplayName</h5>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show py-2" role="alert">
            <i class="bi bi-check-circle me-1"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- ═══════════════════════════════════════════════════════════
         Row 1: Employment Detail (col-lg-7) | Benefits (col-lg-5)
         Both are OUTSIDE save-form. All inputs use form="save-form"
         so they are submitted with the save form even though they
         live outside it.
    ═══════════════════════════════════════════════════════════ -->
    <div class="row g-3 mb-0">

        <!-- Employment Detail (col-lg-7) — OUTSIDE save form, inputs use form="save-form" -->
        <div class="col-lg-7">
            <div class="card shadow-sm">
                <div class="card-header py-2 fw-semibold">
                    <i class="bi bi-briefcase me-2 text-primary"></i>Employment Detail
                </div>
                <div class="card-body" style="display:grid; grid-template-columns:0.49fr 1fr; gap:0.4rem 0.5rem;">
                    <!-- Row 1, Col 1: Application Date -->
                    <div class="d-flex align-items-center gap-2">
                        <label class="form-label small fw-semibold mb-0 text-nowrap" style="min-width:110px;text-align:right">Application Date</label>
                        <input asp-for="Emp.ApplyDate" type="date" class="form-control form-control-sm" style="width:120px;flex:none" form="save-form" />
                    </div>
                    <!-- Row 1, Col 2: Hire Date + Re-hired? + Old Date -->
                    <div class="d-flex align-items-center gap-2">
                        <label class="form-label small fw-semibold mb-0 text-nowrap" style="min-width:160px;text-align:right">Hire Date</label>
                        <input asp-for="Emp.HireDate" type="date" class="form-control form-control-sm"
                               style="width:120px;flex:none" form="save-form" />
                        <div class="form-check mb-0 text-nowrap">
                            <input asp-for="Emp.IsReEmp" class="form-check-input" type="checkbox" id="chkReEmp"
                                   onchange="toggleOldHireDate(this)" form="save-form" />
                            <label class="form-check-label small fw-semibold" for="chkReEmp">Re-hired?</label>
                        </div>
                        <div id="oldHireDateGroup" class="d-flex align-items-center gap-2 @(Model.Emp.IsReEmp ? "" : "d-none")">
                            <label class="form-label small fw-semibold mb-0 text-nowrap">Old Date</label>
                            <input asp-for="Emp.OldStartDate" type="date" class="form-control form-control-sm" style="width:120px;flex:none" form="save-form" />
                        </div>
                    </div>
                    <!-- Row 2, Col 1: Live Scan Date + OK -->
                    <div class="d-flex align-items-center gap-2">
                        <label class="form-label small fw-semibold mb-0 text-nowrap" style="min-width:110px;text-align:right">Live Scan Date</label>
                        <input asp-for="Emp.BkgrndCheckDate" type="date" class="form-control form-control-sm" style="width:120px;flex:none" form="save-form" />
                        <div class="form-check mb-0">
                            <input asp-for="Emp.BackgroudCheckOk" class="form-check-input" type="checkbox" form="save-form" />
                            <label class="form-check-label small">OK</label>
                        </div>
                    </div>
                    <!-- Row 2, Col 2: Pre-Placement Drug Test + OK -->
                    <div class="d-flex align-items-center gap-2">
                        <label class="form-label small fw-semibold mb-0 text-nowrap" style="min-width:160px;text-align:right">Pre-Placement Drug Test</label>
                        <input asp-for="Emp.DrugScreeningDate" type="date" class="form-control form-control-sm" style="width:120px;flex:none" form="save-form" />
                        <div class="form-check mb-0">
                            <input asp-for="Emp.DrugScreeningOk" class="form-check-input" type="checkbox" form="save-form" />
                            <label class="form-check-label small">OK</label>
                        </div>
                    </div>
                    <!-- Row 3, Col 1: Termination Date -->
                    <div class="d-flex align-items-center gap-2">
                        <label class="form-label small fw-semibold mb-0 text-nowrap" style="min-width:110px;text-align:right">Termination Date</label>
                        <input asp-for="Emp.TerminationDate" type="date" class="form-control form-control-sm" style="width:120px;flex:none" form="save-form" />
                    </div>
                    <!-- Row 3, Col 2: Termination Type -->
                    <div class="d-flex align-items-center gap-2">
                        <label class="form-label small fw-semibold mb-0 text-nowrap" style="min-width:160px;text-align:right">Termination Type</label>
                        <select asp-for="Emp.TerminationType" class="form-select form-select-sm" style="width:150px;flex:none" form="save-form">
                            <option value="">—</option>
                            <option value="Resignation">Resignation</option>
                            <option value="LaidOff">Laid Off</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <!-- Benefits card (col-lg-5) — OUTSIDE save form, inputs use form="save-form" -->
        <div class="col-lg-5">
            <div class="card shadow-sm h-100">
                <div class="card-header py-2 fw-semibold">
                    <i class="bi bi-heart me-2 text-danger"></i>Benefits
                </div>
                <div class="card-body">
                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.4rem 1rem;">
                        <!-- Col 1: Insurance -->
                        <div class="d-flex flex-column gap-2">
                            <div class="d-flex align-items-center gap-1">
                                <span class="small fw-semibold" style="min-width:7rem">Health Insurance</span>
                                <input asp-for="Emp.HealthStartDate" type="date" class="form-control form-control-sm" style="width:120px" form="save-form" />
                                <span class="text-muted">~</span>
                                <input asp-for="Emp.HealthEndDate" type="date" class="form-control form-control-sm" style="width:120px" form="save-form" />
                            </div>
                            <div class="d-flex align-items-center gap-1">
                                <span class="small fw-semibold" style="min-width:7rem">Dental Insurance</span>
                                <input asp-for="Emp.DentalStartDate" type="date" class="form-control form-control-sm" style="width:120px" form="save-form" />
                                <span class="text-muted">~</span>
                                <input asp-for="Emp.DentalEndDate" type="date" class="form-control form-control-sm" style="width:120px" form="save-form" />
                            </div>
                            <div class="d-flex align-items-center gap-1">
                                <span class="small fw-semibold" style="min-width:7rem">Vision Insurance</span>
                                <input asp-for="Emp.VisionStartDate" type="date" class="form-control form-control-sm" style="width:120px" form="save-form" />
                                <span class="text-muted">~</span>
                                <input asp-for="Emp.VisionEndDate" type="date" class="form-control form-control-sm" style="width:120px" form="save-form" />
                            </div>
                        </div>
                        <!-- Col 2: 401K -->
                        <div class="d-flex flex-column gap-2">
                            <div class="d-flex align-items-center gap-1">
                                <span class="small fw-semibold" style="min-width:5.5rem">401K Eligible</span>
                                <input asp-for="Emp.Eligible401kDate" type="date" class="form-control form-control-sm" style="width:120px" form="save-form" />
                            </div>
                            <div class="d-flex align-items-center gap-1">
                                <span class="small fw-semibold" style="min-width:5.5rem">401K Enrolled</span>
                                <input asp-for="Emp.Enrolled401kDate" type="date" class="form-control form-control-sm" style="width:120px" form="save-form" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- ═══════════════════════════════════════════════════════════
         Row 2: Status & Private ID (col-lg-7, inside save-form)
                | Role card (col-lg-5, own sub-forms, outside save-form)
         save-form is scoped to col-lg-7 only — no nesting conflict.
    ═══════════════════════════════════════════════════════════ -->
    <div class="row g-3 mt-0">
        <div class="col-lg-7">
            <form id="save-form" method="post" asp-page-handler="Save" asp-route-id="@Model.Emp.Id">

                <!-- Status & Private ID Card -->
                <div class="card shadow-sm border-danger">
                    <div class="card-header py-2 fw-semibold bg-danger bg-opacity-10">
                        <i class="bi bi-person-vcard me-2 text-danger"></i>Status &amp; Private Identification
                        <span class="badge bg-danger ms-2" style="font-size:0.65rem">ENCRYPTED</span>
                    </div>
                    <div class="card-body" style="display:grid; grid-template-columns:0.4fr 1fr; gap:0.5rem 2rem;">

                        <!-- Col 1: Citizenship Status -->
                        <div>
                            <p class="text-muted small mb-2 fw-semibold text-uppercase" style="font-size:0.7rem;letter-spacing:.05em">Citizenship Status</p>
                            <div class="d-flex flex-column gap-2">
                                @foreach (var status in new[] {
                                    "A citizen of the U.S.",
                                    "A noncitizen national of the U.S.",
                                    "A lawful permanent resident",
                                    "A noncitizen (other)"
                                })
                                {
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio"
                                               name="Emp.StatusName" value="@status"
                                               @(Model.Emp.StatusName == status ? "checked" : "") />
                                        <label class="form-check-label small">@status</label>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Col 2: Sensitive IDs -->
                        <div>
                            <p class="text-muted small mb-2 fw-semibold text-uppercase" style="font-size:0.7rem;letter-spacing:.05em">
                                Sensitive IDs — AES-256 encrypted
                                <i class="bi bi-info-circle ms-1" title="Values are encrypted before saving to DB. Masked by default."></i>
                            </p>
                            <div class="d-flex flex-column gap-2">

                                <!-- SSN -->
                                <div class="d-flex align-items-center gap-2">
                                    <label class="form-label small fw-semibold mb-0 text-nowrap text-end" style="min-width:6.5rem">SSN</label>
                                    <input type="password" name="SsnPlain"
                                           value="@(string.IsNullOrEmpty(Model.SsnPlain) ? "" : Model.SsnPlain)"
                                           class="form-control form-control-sm font-monospace sensitive-field"
                                           placeholder="@(Model.Emp.SsnEncrypted != null ? "••••••••• (stored)" : "Not set")"
                                           style="width:200px;flex:none" autocomplete="off" />
                                    <button type="button" class="btn btn-sm btn-outline-secondary ms-auto" onclick="toggleSensitive()">
                                        <i class="bi bi-eye" id="sensitiveIcon"></i>
                                        <span id="sensitiveLabel">Show Values (Click to reveal)</span>
                                    </button>
                                    @if (Model.Emp.SsnEncrypted != null)
                                    {
                                        <form method="post" asp-page-handler="ClearField" asp-route-id="@Model.Emp.Id"
                                              class="d-inline" id="frm-clear-ssn">
                                            <input type="hidden" name="field" value="ssn" />
                                            <button type="button" class="btn btn-outline-danger btn-sm py-0 px-2"
                                                    onclick="confirmAction('frm-clear-ssn', 'Clear SSN', 'Clear SSN?')">
                                                <i class="bi bi-trash" style="font-size:0.75rem"></i>
                                            </button>
                                        </form>
                                    }
                                </div>

                                <!-- TIN -->
                                <div class="d-flex align-items-center gap-2">
                                    <label class="form-label small fw-semibold mb-0 text-nowrap text-end" style="min-width:6.5rem">TIN</label>
                                    <input type="password" name="TinPlain"
                                           value="@(string.IsNullOrEmpty(Model.TinPlain) ? "" : Model.TinPlain)"
                                           class="form-control form-control-sm font-monospace sensitive-field"
                                           placeholder="@(Model.Emp.TinEncrypted != null ? "••••••••• (stored)" : "Not set")"
                                           style="width:200px;flex:none" autocomplete="off" />
                                    @if (Model.Emp.TinEncrypted != null)
                                    {
                                        <form method="post" asp-page-handler="ClearField" asp-route-id="@Model.Emp.Id"
                                              class="d-inline" id="frm-clear-tin">
                                            <input type="hidden" name="field" value="tin" />
                                            <button type="button" class="btn btn-outline-danger btn-sm py-0 px-2"
                                                    onclick="confirmAction('frm-clear-tin', 'Clear TIN', 'Clear TIN?')">
                                                <i class="bi bi-trash" style="font-size:0.75rem"></i>
                                            </button>
                                        </form>
                                    }
                                </div>

                                <hr class="my-1" />

                                <!-- Driver's License -->
                                <div class="d-flex align-items-center gap-2">
                                    <label class="form-label small fw-semibold mb-0 text-nowrap text-end" style="min-width:6.5rem">Driver's Lic #</label>
                                    <input type="password" name="DriversLicPlain"
                                           value="@(string.IsNullOrEmpty(Model.DriversLicPlain) ? "" : Model.DriversLicPlain)"
                                           class="form-control form-control-sm font-monospace sensitive-field"
                                           placeholder="@(Model.Emp.DriversLicNumEncrypted != null ? "••••••••• (stored)" : "Not set")"
                                           autocomplete="off" />
                                    <span class="small text-muted text-nowrap">Issued</span>
                                    <input asp-for="Emp.DriversLicIssuedDate" type="date" class="form-control form-control-sm" style="width:120px" />
                                    <span class="small text-muted text-nowrap">Exp</span>
                                    <input asp-for="Emp.DriversLicExpiration" type="date" class="form-control form-control-sm" style="width:120px" />
                                </div>

                                <!-- Alien Number -->
                                <div class="d-flex align-items-center gap-2">
                                    <label class="form-label small fw-semibold mb-0 text-nowrap text-end" style="min-width:6.5rem">Alien # (A-#)</label>
                                    <input type="password" name="AlienNumPlain"
                                           value="@(string.IsNullOrEmpty(Model.AlienNumPlain) ? "" : Model.AlienNumPlain)"
                                           class="form-control form-control-sm font-monospace sensitive-field"
                                           placeholder="@(Model.Emp.AlienNumberEncrypted != null ? "••••••••• (stored)" : "Not set")"
                                           autocomplete="off" />
                                    <span class="small text-muted text-nowrap">Issued</span>
                                    <input asp-for="Emp.AlienCardIssuedDate" type="date" class="form-control form-control-sm" style="width:120px" />
                                    <span class="small text-muted text-nowrap">Exp</span>
                                    <input asp-for="Emp.AlienCardExpirationDate" type="date" class="form-control form-control-sm" style="width:120px" />
                                </div>

                                <!-- Passport -->
                                <div class="d-flex align-items-center gap-2">
                                    <label class="form-label small fw-semibold mb-0 text-nowrap text-end" style="min-width:6.5rem">Passport #</label>
                                    <input type="password" name="PassportNumPlain"
                                           value="@(string.IsNullOrEmpty(Model.PassportNumPlain) ? "" : Model.PassportNumPlain)"
                                           class="form-control form-control-sm font-monospace sensitive-field"
                                           placeholder="@(Model.Emp.PassportNumberEncrypted != null ? "••••••••• (stored)" : "Not set")"
                                           autocomplete="off" />
                                    <span class="small text-muted text-nowrap">Issued</span>
                                    <input asp-for="Emp.PassportIssedDate" type="date" class="form-control form-control-sm" style="width:120px" />
                                    <span class="small text-muted text-nowrap">Exp</span>
                                    <input asp-for="Emp.PassportExpiredDate" type="date" class="form-control form-control-sm" style="width:120px" />
                                </div>


                            </div>
                        </div>

                    </div>
                </div>

            </form><!-- /save-form -->
        </div>

        <!-- Role card (col-lg-5) — keeps its own sub-forms, OUTSIDE save-form -->
        <div class="col-lg-5">
            @*
                Role 관리는 HrAdmin 전용 기능.
                - Detail(HrUser) 에서는 읽기 전용 표시만 제공
                - 이 섹션은 별도 <form> 으로 두어 상단의 민감정보 Save form 과 분리.
                  (Role Add/Delete/SetPrimary 는 독립 핸들러로 동작)
            *@
            <div class="card shadow-sm border-primary h-100 d-flex flex-column overflow-hidden">
                <div class="card-header py-2 fw-semibold d-flex justify-content-between align-items-center flex-shrink-0">
                    <span><i class="bi bi-diagram-3 me-2 text-primary"></i>Role Assignment (Department / Position)</span>
                    <button class="btn btn-sm btn-primary py-0 px-2"
                            type="button" data-bs-toggle="collapse" data-bs-target="#addRoleForm">
                        <i class="bi bi-plus me-1"></i>Add Role
                    </button>
                </div>

                <!-- Add Role Form (collapse) -->
                <div class="collapse flex-shrink-0" id="addRoleForm">
                    <div class="card-body border-bottom bg-light">
                        <form method="post" asp-page-handler="AddRole" asp-route-id="@Model.Emp.Id">
                            <div class="row g-3">
                                <div class="col-md-3">
                                    <label class="form-label small fw-semibold">Department / Team <span class="text-danger">*</span></label>
                                    <select name="NewRoleOrgUnitId" class="form-select form-select-sm" required>
                                        <option value="0">-- select --</option>
                                        @foreach (var o in Model.OrgUnitOptions)
                                        {
                                            <option value="@o.Value">@o.Text</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small fw-semibold">Position</label>
                                    <select name="NewRoleJobPositionId" class="form-select form-select-sm">
                                        <option value="">-- select --</option>
                                        @foreach (var p in Model.JobPositionOptions)
                                        {
                                            <option value="@p.Value">@p.Text</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label small">Start</label>
                                    <input type="date" name="NewRoleStartDate" class="form-control form-control-sm" />
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label small">End</label>
                                    <input type="date" name="NewRoleEndDate" class="form-control form-control-sm" />
                                </div>
                                <div class="col-md-2 d-flex align-items-end pb-1">
                                    <div class="form-check">
                                        <input type="checkbox" name="NewRoleIsPrimary" value="true"
                                               class="form-check-input" id="chkPrimary" />
                                        <label class="form-check-label small" for="chkPrimary">Primary</label>
                                    </div>
                                </div>
                            </div>
                            <div class="mt-2 d-flex gap-2">
                                <button type="submit" class="btn btn-primary btn-sm">
                                    <i class="bi bi-plus-lg me-1"></i>Add
                                </button>
                                <button type="button" class="btn btn-outline-secondary btn-sm"
                                        data-bs-toggle="collapse" data-bs-target="#addRoleForm">
                                    Cancel
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Roles List (editable) -->
                <div class="list-group list-group-flush" style="overflow-y:auto; flex:1; min-height:0;">
                    @if (!Model.Roles.Any())
                    {
                        <div class="list-group-item text-muted small text-center py-3">
                            No roles assigned. Click "Add Role" above.
                        </div>
                    }
                    @foreach (var role in Model.Roles)
                    {
                        <div class="list-group-item py-2 px-3 d-flex justify-content-between align-items-start">
                            <div>
                                @if (role.IsPrimary)
                                {
                                    <span class="badge bg-primary me-1" style="font-size:0.65rem">PRIMARY</span>
                                }
                                <span class="fw-semibold small">@role.OrgUnit?.Name</span>
                                @if (role.JobPosition != null)
                                {
                                    <span class="text-muted small ms-2">· @role.JobPosition.Name</span>
                                }
                                @if (role.StartDate.HasValue || role.EndDate.HasValue)
                                {
                                    <br /><small class="text-muted">
                                        @role.StartDate?.ToString("yyyy-MM-dd") – @(role.EndDate?.ToString("yyyy-MM-dd") ?? "present")
                                    </small>
                                }
                            </div>
                            <div class="d-flex gap-1">
                                @if (!role.IsPrimary)
                                {
                                    <form method="post" asp-page-handler="SetPrimary"
                                          asp-route-id="@Model.Emp.Id" asp-route-roleId="@role.Id">
                                        <button type="submit" class="btn btn-outline-primary btn-sm py-0 px-2"
                                                title="Set as Primary">
                                            <i class="bi bi-star" style="font-size:0.7rem"></i>
                                        </button>
                                    </form>
                                }
                                <form method="post" asp-page-handler="DeleteRole"
                                      asp-route-id="@Model.Emp.Id" asp-route-roleId="@role.Id"
                                      id="frm-delete-role-@role.Id">
                                    <button type="button" class="btn btn-outline-danger btn-sm py-0 px-2"
                                            onclick="confirmAction('frm-delete-role-@role.Id', 'Remove Role', 'Remove this role?')">
                                        <i class="bi bi-trash" style="font-size:0.7rem"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>

    <!-- Save button — outside Row 2 so it doesn't affect card height alignment -->
    <div class="d-flex gap-2 mt-2">
        <button type="submit" form="save-form" class="btn btn-danger btn-sm">
            <i class="bi bi-shield-lock me-1"></i>Save HR Admin Data
        </button>
        <a asp-page="Detail" asp-route-id="@Model.Emp.Id" class="btn btn-outline-secondary btn-sm">
            Back to Employee
        </a>
    </div>

</div>

<script>
function toggleOldHireDate(chk) {
    const grp = document.getElementById('oldHireDateGroup');
    if (grp) grp.classList.toggle('d-none', !chk.checked);
}

function toggleSensitive() {
    const fields = document.querySelectorAll('.sensitive-field');
    const icon   = document.getElementById('sensitiveIcon');
    const label  = document.getElementById('sensitiveLabel');
    const isHidden = fields[0]?.type === 'password';
    fields.forEach(f => f.type = isHidden ? 'text' : 'password');
    icon.className  = isHidden ? 'bi bi-eye-slash' : 'bi bi-eye';
    label.textContent = isHidden ? 'Hide Values' : 'Show Values (Click to reveal)';
}
</script>
