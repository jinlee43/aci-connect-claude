@page
@model ACI.Web.Pages.Admin.OrgUnits.IndexModel
@{
    ViewData["Title"] = "Org Units";
    ViewData["ActiveMenu"] = "orgunits";
}

<div class="p-3">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h5 class="mb-0 fw-bold"><i class="bi bi-diagram-3 me-2 text-primary"></i>Organization Units</h5>
        <button class="btn btn-primary btn-sm" type="button"
                data-bs-toggle="collapse" data-bs-target="#addForm">
            <i class="bi bi-plus me-1"></i>Add New
        </button>
    </div>

    <!-- Add / Edit Form -->
    <div class="collapse mb-3" id="addForm">
        <div class="card shadow-sm">
            <div class="card-body">
                <form method="post" asp-page-handler="Save">
                    <input type="hidden" asp-for="Input.Id" />
                    <div class="row g-3 align-items-end">
                        <div class="col-md-2">
                            <label class="form-label small fw-semibold">Code</label>
                            <input asp-for="Input.Code" class="form-control form-control-sm" placeholder="e.g. JD" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-semibold">Name</label>
                            <input asp-for="Input.Name" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label small fw-semibold">Type</label>
                            <select asp-for="Input.Type" class="form-select form-select-sm">
                                <option value="0">Company</option>
                                <option value="1">Division</option>
                                <option value="2">Department</option>
                                <option value="3">Team</option>
                                <option value="4">Branch</option>
                                <option value="5">Project Team</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-semibold">Parent</label>
                            <select asp-for="Input.ParentId" class="form-select form-select-sm">
                                <option value="">-- none (top level) --</option>
                                @foreach (var p in Model.ParentOptions)
                                {
                                    <option value="@p.Id">@p.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-auto">
                            <div class="form-check">
                                <input asp-for="Input.IsActive" class="form-check-input" type="checkbox" checked />
                                <label class="form-check-label small">Active</label>
                            </div>
                        </div>
                        <div class="col-auto">
                            <button type="submit" class="btn btn-primary btn-sm">Save</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Table -->
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-sm table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Code</th>
                        <th>Name</th>
                        <th>Type</th>
                        <th>Parent</th>
                        <th class="text-center">Status</th>
                        <th style="width:80px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var org in Model.OrgUnits)
                    {
                        <tr class="@(!org.IsActive ? "text-muted" : "")">
                            <td class="small fw-semibold">@org.Code</td>
                            <td class="small">@org.Name</td>
                            <td><span class="badge bg-secondary-subtle text-secondary">@org.Type</span></td>
                            <td class="small text-muted">@org.Parent?.Name</td>
                            <td class="text-center">
                                @if (org.IsActive)
                                {
                                    <span class="badge bg-success-subtle text-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary">Inactive</span>
                                }
                            </td>
                            <td>
                                <form method="post" asp-page-handler="Toggle" asp-route-id="@org.Id" class="d-inline">
                                    <button type="submit" class="btn btn-outline-secondary btn-sm py-0 px-2"
                                            title="@(org.IsActive ? "Deactivate" : "Activate")">
                                        <i class="bi bi-@(org.IsActive ? "toggle-on text-success" : "toggle-off text-muted")"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
