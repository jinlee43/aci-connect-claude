@page
@model ACI.Web.Pages.Admin.JobPositions.IndexModel
@{
    ViewData["Title"] = "Job Positions";
    ViewData["ActiveMenu"] = "jobpositions";
}

<div class="p-3">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h5 class="mb-0 fw-bold"><i class="bi bi-person-badge me-2 text-primary"></i>Job Positions</h5>
        <button class="btn btn-primary btn-sm" type="button"
                data-bs-toggle="collapse" data-bs-target="#addForm">
            <i class="bi bi-plus me-1"></i>Add New
        </button>
    </div>

    <!-- Add Form -->
    <div class="collapse mb-3" id="addForm">
        <div class="card shadow-sm">
            <div class="card-body">
                <form method="post" asp-page-handler="Save">
                    <input type="hidden" asp-for="Input.Id" />
                    <div class="row g-3 align-items-end">
                        <div class="col-md-2">
                            <label class="form-label small fw-semibold">Code</label>
                            <input asp-for="Input.Code" class="form-control form-control-sm" placeholder="e.g. PM" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-semibold">Name</label>
                            <input asp-for="Input.Name" class="form-control form-control-sm" placeholder="e.g. Project Manager" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label small fw-semibold">Order #</label>
                            <input asp-for="Input.OrdNum" type="number" class="form-control form-control-sm" />
                        </div>
                        <div class="col-auto">
                            <div class="form-check">
                                <input asp-for="Input.IsActive" class="form-check-input" type="checkbox" checked />
                                <label class="form-check-label small">Active</label>
                            </div>
                        </div>
                        <div class="col-auto">
                            <button type="submit" class="btn btn-primary btn-sm">Save</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Table -->
    <div class="card shadow-sm" style="max-width: 700px;">
        <div class="table-responsive">
            <table class="table table-sm table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width:60px" class="text-center">Order</th>
                        <th style="width:100px">Code</th>
                        <th>Name</th>
                        <th class="text-center" style="width:80px">Status</th>
                        <th style="width:60px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var pos in Model.JobPositions)
                    {
                        <tr class="@(!pos.IsActive ? "text-muted" : "")">
                            <td class="text-center small">@pos.OrdNum</td>
                            <td class="small fw-semibold">@pos.Code</td>
                            <td class="small">@pos.Name</td>
                            <td class="text-center">
                                @if (pos.IsActive)
                                {
                                    <span class="badge bg-success-subtle text-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary">Inactive</span>
                                }
                            </td>
                            <td>
                                <form method="post" asp-page-handler="Toggle" asp-route-id="@pos.Id">
                                    <button type="submit" class="btn btn-outline-secondary btn-sm py-0 px-2">
                                        <i class="bi bi-@(pos.IsActive ? "toggle-on text-success" : "toggle-off text-muted")"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
