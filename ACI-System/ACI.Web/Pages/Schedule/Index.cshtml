@page "{projectId:int}"
@model ACI.Web.Pages.Schedule.IndexModel
@{
    ViewData["Title"] = "Baseline Schedule";
    ViewData["ActiveMenu"] = "schedule";
    ViewData["CurrentProjectId"] = Model.ProjectId;
    ViewData["CurrentProjectName"] = Model.ProjectName;
    ViewData["LoadGanttBundle"] = true;
}

@section Styles {
<style>
html, body { height: 100%; }
.aci-gantt-wrapper { padding: 0 12px 12px; }
</style>
}

<!-- Page Header -->
<div class="aci-page-header">
    <div>
        <h1><i class="bi bi-bar-chart-steps me-2 text-primary"></i>Baseline Schedule</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-page="/Projects/Index">Projects</a></li>
                <li class="breadcrumb-item active">@Model.ProjectName</li>
            </ol>
        </nav>
    </div>
    <div class="d-flex gap-2 align-items-center">
        <a asp-page="/Progress/Revisions" asp-route-projectId="@Model.ProjectId"
           class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-clock-history me-1"></i>Change Log
        </a>
    </div>
</div>

@* Antiforgery token (Freeze Baseline 폼에서 사용) *@
@Html.AntiForgeryToken()

<!-- React Gantt Mount Point -->
<div class="aci-gantt-wrapper">
    <div
        id="baseline-gantt-root"
        data-project-id="@Model.ProjectId"
        data-api-base="/api"
        data-import-url="@Url.Page("/Schedule/Import", new { projectId = Model.ProjectId })"
        style="width:100%;">
    </div>
</div>

@section Scripts {
}
