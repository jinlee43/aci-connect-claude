// ── 행 CSS (summary / milestone 강조) ────────────────────────
gantt.templates.grid_row_class = (start, end, task) => {
    if (task.type === 'project')   return 'summary-row';
    if (task.type === 'milestone') return 'milestone-row';
    return '';
};
gantt.templates.task_row_class = gantt.templates.grid_row_class;

// ── Task 바 클래스 (status-based color) ───────────────────
gantt.templates.task_class = (start, end, task) => {
    if (task.type === 'project')   return 'gantt_project';
    if (task.type === 'milestone') return '';
    const pct  = task.progress || 0;
    const now  = new Date();
    if (pct >= 1)            return 'aci-task-complete';   // 100% → green
    if (pct === 0)           return 'aci-task-notstarted'; // 0%   → gray
    if (end < now && pct < 1) return 'aci-task-overdue';  // 기한초과 → red
    return 'aci-task-inprogress';                          // 진행중  → blue
};

// ── 툴팁 ───────────────────────────────────────────────────
gantt.templates.tooltip_text = (start, end, task) => {
    const fmt = gantt.templates.tooltip_date_format;
    const pct = Math.round(task.progress * 100);
    const dur = task.duration;
    return `<b style="color:#1e3a8a">${task.text}</b><br>
            Start: ${fmt(start)}<br>
            End: ${fmt(end)}<br>
            Duration: ${dur} day${dur !== 1 ? 's' : ''}<br>
            Progress: ${pct}%`;
};

// ── Dependency link 타입별 시각 구분 ──────────────────────────
gantt.templates.link_class = function(link) {
    const classes = [];
    switch (link.type) {
        case gantt.config.links.finish_to_start:  classes.push('link-fs'); break;
        case gantt.config.links.start_to_start:   classes.push('link-ss'); break;
        case gantt.config.links.finish_to_finish: classes.push('link-ff'); break;
        case gantt.config.links.start_to_finish:  classes.push('link-sf'); break;
    }
    if (link.lag) classes.push('link-has-lag');
    return classes.join(' ');
};

// ── Procore-style drag: SNET 자동 적용 + Ctrl 누르면 후속 고정 ─────────
let _lastDragCtrl = false;

gantt.attachEvent('onBeforeTaskDrag', function(id, mode, e) {
    if (gantt.hasChild(id)) {
        showParentLockTip(e);
        return false;
    }
    _lastDragCtrl = e.ctrlKey || e.metaKey;   // Ctrl/Cmd 상태 캡처
    return true;
});

gantt.attachEvent('onAfterTaskDrag', function(id, mode, e) {
    if (mode !== gantt.config.drag_mode.move && mode !== gantt.config.drag_mode.resize) return;

    const task = gantt.getTask(id);

    // Procore 방식: 드래그하면 SNET(Start No Earlier Than) 제약 자동 적용
    task.constraint_type = 'snet';
    task.constraint_date = new Date(task.start_date);

    // updateTask → DataProcessor가 서버 저장 트리거
    gantt.updateTask(id);

    // Ctrl/Cmd + 드래그: 후속 태스크 고정 (나만 이동)
    // 일반 드래그: 후속 태스크 cascade
    if (!_lastDragCtrl) {
        cascadeSuccessors(id, new Set());
    }
});

/**
 * Cascade date changes to all successor tasks based on dependency type + lag.
 * Uses FS/SS/FF/SF rules from CPM scheduling.
 * Visited set prevents infinite loops in circular references.
 */
function cascadeSuccessors(taskId, visited) {
    if (visited.has(taskId)) return;
    visited.add(taskId);

    const task = gantt.getTask(taskId);
    const links = task.$source || [];   // outgoing links from this task

    links.forEach(function(linkId) {
        const link = gantt.getLink(linkId);
        if (!link) return;

        const successor = gantt.getTask(link.target);
        if (!successor || successor.type === 'project') return;

        const lagDays = (link.lag || 0);
        let newStart = null;

        switch (link.type) {
            case gantt.config.links.finish_to_start:   // FS
                // Successor starts after predecessor ends + lag
                newStart = gantt.calculateEndDate(task.end_date, lagDays, 'day');
                break;

            case gantt.config.links.start_to_start:    // SS
                // Successor starts when predecessor starts + lag
                newStart = gantt.calculateEndDate(task.start_date, lagDays, 'day');
                break;

            case gantt.config.links.finish_to_finish:  // FF
                // Successor ends when predecessor ends + lag
                // → compute start = (predecessor end + lag) - successor duration
                var targetEnd = gantt.calculateEndDate(task.end_date, lagDays, 'day');
                newStart = gantt.calculateEndDate(targetEnd, -successor.duration, 'day');
                break;

            case gantt.config.links.start_to_finish:   // SF
                // Successor ends when predecessor starts + lag
                var targetEnd2 = gantt.calculateEndDate(task.start_date, lagDays, 'day');
                newStart = gantt.calculateEndDate(targetEnd2, -successor.duration, 'day');
                break;
        }

        if (newStart && newStart > successor.start_date) {
            // Only push forward (never pull backward — respect construction scheduling logic)
            successor.start_date = newStart;
            successor.end_date = gantt.calculateEndDate(newStart, successor.duration, 'day');
            gantt.updateTask(successor.id);

            // Mark as changed for save tracking
            if (typeof window.trackUnsavedChange === 'function') {
                window.trackUnsavedChange(successor.id);
            }

            // Recursively cascade to this successor's successors
            cascadeSuccessors(successor.id, visited);
        }
    });
}

// ── 커스텀 컬럼 리사이즈 (GPL 버전은 resize:true 미지원 → 직접 구현) ──
// ※ 반드시 gantt.init() 보다 먼저 이벤트를 등록해야 함
const RESIZABLE_COLS = ['wbs', 'text', 'trade_name', 'start_date', 'duration', 'end_date_col', 'progress', 'responsible'];

function initColResize() {
    document.querySelectorAll('.aci-col-resize-handle').forEach(h => h.remove());

    document.querySelectorAll('.gantt_grid_head_cell').forEach(cell => {
        const colName = cell.getAttribute('data-column-name');
        if (!RESIZABLE_COLS.includes(colName)) return;

        cell.style.position = 'relative';
        cell.style.overflow = 'visible';

        const handle = document.createElement('div');
        handle.className = 'aci-col-resize-handle';
        cell.appendChild(handle);

        handle.addEventListener('mousedown', e => {
            e.preventDefault();
            e.stopPropagation();

            const startX = e.pageX;
            const col    = gantt.config.columns.find(c => c.name === colName);
            const startW = col.width;

            handle.classList.add('dragging');
            document.body.style.cursor     = 'col-resize';
            document.body.style.userSelect = 'none';

            const onMove = ev => {
                const newW = Math.max(50, startW + ev.pageX - startX);
                cell.style.width = newW + 'px';
            };

            const onUp = ev => {
                document.removeEventListener('mousemove', onMove);
                document.removeEventListener('mouseup',   onUp);
                handle.classList.remove('dragging');
                document.body.style.cursor     = '';
                document.body.style.userSelect = '';
                const newW = Math.max(50, startW + ev.pageX - startX);
                const diff = newW - startW;
                col.width = newW;
                // 전체 그리드 폭 = 모든 컬럼 폭의 합
                gantt.config.grid_width = gantt.config.columns.reduce((sum, c) => sum + (c.width || 0), 0);
                // 타임라인 폭 유지: 컨테이너 폭을 같이 늘림
                const chartEl = document.getElementById('gantt-chart');
                chartEl.style.width = (chartEl.offsetWidth + diff) + 'px';
                gantt.render();
            };

            document.addEventListener('mousemove', onMove);
            document.addEventListener('mouseup',   onUp);
        });
    });
}

// ── 부모 태스크 자동 재계산 (클라이언트) ──────────────────
// 자식 저장 후 부모의 start/end/progress 를 자식들 기준으로 갱신
function recalcParent(parentId) {
    if (!parentId || parentId == 0) return;
    const children = gantt.getChildren(parentId)
        .map(id => gantt.getTask(id))
        .filter(t => t.type !== 'milestone');
    if (children.length === 0) return;

    const parent = gantt.getTask(parentId);
    let minStart = null, maxEnd = null, totalDur = 0, weightedProg = 0;

    children.forEach(c => {
        const s = c.start_date;
        const e = gantt.date.add(new Date(s), c.duration, 'day');
        if (!minStart || s < minStart) minStart = s;
        if (!maxEnd   || e > maxEnd)   maxEnd   = e;
        totalDur    += c.duration;
        weightedProg += (c.progress || 0) * c.duration;
    });

    parent.start_date = minStart;
    parent.duration   = gantt.calculateDuration(minStart, maxEnd);
    parent.progress   = totalDur > 0 ? weightedProg / totalDur : 0;
    gantt.refreshTask(parentId); // DataProcessor 미트리거 — 표시만 갱신

    // 재귀: 조부모까지 올라감
    recalcParent(parent.parent);
}

// ── 태스크 호버 시 연결 화살표만 표시 ─────────────────────
gantt.attachEvent('onMouseMove', function(id) {
    document.querySelectorAll('.gantt_task_link.aci-link-active')
        .forEach(el => el.classList.remove('aci-link-active'));
    if (!id) return;
    document.querySelectorAll('.gantt_task_link').forEach(el => {
        const linkId = el.getAttribute('link_id');
        if (!linkId) return;
        try {
            const lnk = gantt.getLink(linkId);
            if (lnk && (String(lnk.source) === String(id) || String(lnk.target) === String(id))) {
                el.classList.add('aci-link-active');
            }
        } catch(e) {}
    });
});

// 마우스가 차트 영역을 벗어나면 모두 숨김
document.addEventListener('DOMContentLoaded', () => {
    document.getElementById('gantt-chart')?.addEventListener('mouseleave', () => {
