// 렌더 후 핸들 재생성 (이후 gantt.render() 호출 시)
gantt.attachEvent('onGanttRender',   initColResize);
gantt.attachEvent('onGanttRendered', initColResize);
gantt.attachEvent('onLoadEnd',       initColResize);

// ── Actions 컬럼 헬퍼 함수 ────────────────────────────────
function aciToggleDone(id) {
    const task = gantt.getTask(id);
    task.progress = task.progress >= 1 ? 0 : 1;
    gantt.updateTask(id);
}

function aciDeleteTask(id) {
