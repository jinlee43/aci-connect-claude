@page "{projectId:int}"
@model ACI.Web.Pages.Schedule.IndexModel
@{
    ViewData["Title"] = "Baseline Schedule";
    ViewData["ActiveMenu"] = "schedule";
    ViewData["CurrentProjectId"] = Model.ProjectId;
    ViewData["CurrentProjectName"] = Model.ProjectName;
}

@section Styles {
<style>
/* ── 레이아웃 ─────────────────────────────── */
html, body { height: 100%; }
#gantt-chart { width: 100%; height: calc(100vh - 130px); }

/* ── 그리드 헤더 (Outbuild: 연회색) ──────── */
.gantt_grid_head_cell {
    background: #f5f5f5;
    color: #6b7280 !important;
    font-weight: 600;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: .4px;
    border-right: 1px solid #e5e7eb !important;
}
.gantt_grid_scale {
    background: #f5f5f5;
    border-bottom: 1px solid #d1d5db !important;
}

/* ── 타임라인 헤더 ─────────────────────────── */
.gantt_scale_cell {
    font-size: 11px;
    font-weight: 600;
    color: #6b7280;
    background: #f5f5f5;
    border-right: 1px solid #e5e7eb;
}
.gantt_task_scale { border-bottom: 1px solid #d1d5db !important; }

/* ── 그리드 행 ─────────────────────────────── */
.gantt_row, .gantt_task_row {
    border-bottom: 1px solid #f0f0f0;
}
.gantt_row.odd, .gantt_task_row.odd { background: #fafafa; }
.gantt_row:hover, .gantt_task_row:hover { background: #f0f7ff !important; }

/* ── Summary(Phase) 행: 살짝 다른 배경 + Bold ─ */
.gantt_row.summary-row, .gantt_task_row.summary-row {
    background: #f7f7f7 !important;
}
.gantt_row.summary-row:hover, .gantt_task_row.summary-row:hover {
    background: #eef4ff !important;
}

/* ── 그리드 셀 ─────────────────────────────── */
.gantt_cell {
    border-right: 1px solid #f0f0f0;
    font-size: 12px;
    color: #374151;
}

/* ── 타임라인 셀 ───────────────────────────── */
.gantt_task_cell { border-right: 1px solid #f0f0f0; }
.gantt_task_cell.week_end { background: #fafafa; }

/* ── Task 바 기본 ───────────────────────────── */
.gantt_task_line {
    border-radius: 4px;
    border: none;
}
.gantt_task_progress {
    border-radius: 4px 0 0 4px;
    background: rgba(0,0,0,.15);
}

/* Status-based colors (like Outbuild) */
/* Not Started (0%) → slate gray */
.aci-task-notstarted { background: #94a3b8; }
/* In Progress (1–99%) → blue */
.aci-task-inprogress { background: #3b82f6; }
/* Complete (100%) → green */
.aci-task-complete   { background: #16a34a; }
/* Overdue: past end date, not complete → red */
.aci-task-overdue    { background: #ef4444; }

/* Summary(Phase) 바: 짙은 네이비 + 납작하게 */
.gantt_task_line.gantt_project {
    background: #1e40af !important;
    border-color: #1e3a8a !important;
    border-radius: 2px;
    height: 12px !important;
    margin-top: 8px;
}
.gantt_task_line.gantt_project .gantt_task_progress {
    background: rgba(0,0,0,.2);
    border-radius: 2px 0 0 2px;
}

/* ── Dependency Links: 기본 숨김, 호버 시 표시 ── */
.gantt_task_link {
    opacity: 0;
    transition: opacity 0.15s ease;
    pointer-events: none;
}
/* 호버된 태스크의 연결 화살표만 표시 */
.gantt_task_link.aci-link-active {
    opacity: 1;
}
/* Links 버튼 켜면 전체 표시 */
#gantt-chart.aci-links-visible .gantt_task_link {
    opacity: 1;
    pointer-events: auto;
}

/* ── Dependency Type 별 시각 구분 ────────────── */
/* FS (Finish-to-Start) — 기본: 파란색 실선 */
.gantt_task_link.link-fs .gantt_line_wrapper div { background: #3b82f6; }
.gantt_task_link.link-fs .gantt_link_arrow { border-color: #3b82f6; }

/* SS (Start-to-Start) — 초록색 */
.gantt_task_link.link-ss .gantt_line_wrapper div { background: #16a34a; }
.gantt_task_link.link-ss .gantt_link_arrow { border-color: #16a34a; }

/* FF (Finish-to-Finish) — 주황색 */
.gantt_task_link.link-ff .gantt_line_wrapper div { background: #ea580c; }
.gantt_task_link.link-ff .gantt_link_arrow { border-color: #ea580c; }

/* SF (Start-to-Finish) — 보라색, 점선 */
.gantt_task_link.link-sf .gantt_line_wrapper div { background: #9333ea; }
.gantt_task_link.link-sf .gantt_link_arrow { border-color: #9333ea; }

/* Lag 있는 링크: 점선 패턴 */
.gantt_task_link.link-has-lag .gantt_line_wrapper div {
    background: repeating-linear-gradient(
        90deg,
        currentColor 0px, currentColor 6px,
        transparent 6px, transparent 10px
    ) !important;
    background-size: 10px 2px !important;
}

/* ── Critical Path ─────────────────────────── */
.gantt_critical_task {
    background: #7f1d1d !important;
    border-color: #450a0a !important;
}

/* ── Today 마커 ────────────────────────────── */
.today-marker { background: rgba(59,130,246,.8); width: 2px; }
.today-marker .gantt_marker_content {
    background: #3b82f6; color: #fff;
    padding: 2px 6px; border-radius: 4px; font-size: .7rem;
    white-space: nowrap;
}

/* ── Actions 컬럼 버튼 (Outbuild 스타일) ──── */
.aci-act-btn {
    display: inline-flex; align-items: center; justify-content: center;
    width: 20px; height: 20px; border-radius: 4px; cursor: pointer;
    transition: background .15s;
}
.aci-act-btn:hover { background: #f3f4f6; }
.aci-act-btn:hover .bi-trash3 { color: #dc2626 !important; }

/* ── 커스텀 컬럼 리사이즈 핸들 ─────────────── */
.aci-col-resize-handle {
    position: absolute; right: 0; top: 0; bottom: 0;
    width: 6px; cursor: col-resize; z-index: 20;
    background: transparent; transition: background .15s;
}
.aci-col-resize-handle:hover,
.aci-col-resize-handle.dragging { background: #3b82f6; }

/* ── 그리드↔타임라인 경계 드래그 핸들 ─────────── */
.gantt_grid_resize_wrap { cursor: col-resize; }
.gantt_grid_resize_wrap:hover { background: #bfdbfe; }

/* ── 우클릭 컨텍스트 메뉴 ───────────────────── */
#aci-ctx-menu {
    display:none; position:fixed; z-index:9999;
    background:#fff; border:1px solid #e5e7eb;
    border-radius:8px; box-shadow:0 8px 24px rgba(0,0,0,.15);
    min-width:210px; padding:4px; font-size:13px;
}
.aci-ctx-item {
    display:flex; align-items:center; gap:9px;
    padding:8px 13px; border-radius:5px; cursor:pointer; color:#374151;
}
.aci-ctx-item:hover { background:#f3f4f6; }
.aci-ctx-item.danger { color:#dc2626; }
.aci-ctx-item.danger:hover { background:#fef2f2; }
.aci-ctx-divider { height:1px; background:#e5e7eb; margin:3px 0; }

/* ── 툴팁 ──────────────────────────────────── */
.gantt_tooltip {
    border-radius: 6px; border: 1px solid #e5e7eb;
    box-shadow: 0 4px 12px rgba(0,0,0,.12);
    font-size: 12px; padding: 8px 12px; line-height: 1.6;
}
</style>
}

<!-- Page Header -->
<div class="aci-page-header">
    <div>
        <h1><i class="bi bi-bar-chart-steps me-2 text-primary"></i>Baseline Schedule</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-page="/Projects/Index">Projects</a></li>
                <li class="breadcrumb-item active">@Model.ProjectName</li>
            </ol>
        </nav>
    </div>
    <div class="d-flex gap-2 align-items-center flex-wrap">
        <!-- Search / Filter -->
        <div class="input-group input-group-sm" style="width:190px;">
            <span class="input-group-text bg-white border-end-0 pe-1">
                <i class="bi bi-search text-muted" style="font-size:12px;"></i>
            </span>
            <input type="text" class="form-control border-start-0 ps-0" id="taskSearch"
                   placeholder="Search tasks…" style="font-size:12px;"
                   oninput="ACIGantt.filterTasks(this.value)">
            <button class="btn btn-outline-secondary" onclick="ACIGantt.clearFilter()" title="Clear search">
                <i class="bi bi-x" style="font-size:13px;"></i>
            </button>
        </div>
        <!-- Zoom controls -->
        <div class="btn-group btn-group-sm">
            <button class="btn btn-outline-secondary" onclick="gantt.ext.zoom.zoomIn()"  title="Zoom in (Ctrl+Scroll)">
                <i class="bi bi-zoom-in"></i>
            </button>
            <button class="btn btn-outline-secondary" onclick="gantt.ext.zoom.zoomOut()" title="Zoom out">
                <i class="bi bi-zoom-out"></i>
            </button>
            <button class="btn btn-outline-secondary" onclick="ACIGantt.fitToScreen()"   title="Fit all tasks">
                <i class="bi bi-arrows-angle-contract"></i>
            </button>
            <button class="btn btn-outline-secondary" onclick="ACIGantt.goToday()"       title="Jump to today">
                <i class="bi bi-calendar-check"></i>
            </button>
        </div>
        <!-- Scale options -->
        <div class="btn-group btn-group-sm">
            <button class="btn btn-outline-secondary active" onclick="ACIGantt.setScale('week')"    id="scaleWeek">Week</button>
            <button class="btn btn-outline-secondary"        onclick="ACIGantt.setScale('month')"   id="scaleMonth">Month</button>
            <button class="btn btn-outline-secondary"        onclick="ACIGantt.setScale('quarter')" id="scaleQuarter">Quarter</button>
            <button class="btn btn-outline-secondary"        onclick="ACIGantt.setScale('year')"    id="scaleYear">Year</button>
        </div>

        <!-- Date Range -->
        <div class="dropdown">
            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown" id="btnDateRange">
                <i class="bi bi-calendar-range me-1"></i>Date Range
            </button>
            <div class="dropdown-menu dropdown-menu-end p-3" style="min-width:260px;" onclick="event.stopPropagation()">
                <div style="font-size:11px;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px;">Visible Period</div>
                <div class="d-flex align-items-center gap-2 mb-2">
                    <label style="font-size:12px;color:#374151;width:32px;flex-shrink:0;">From</label>
                    <input type="date" id="drFrom" class="form-control form-control-sm" style="font-size:12px;">
                </div>
                <div class="d-flex align-items-center gap-2 mb-3">
                    <label style="font-size:12px;color:#374151;width:32px;flex-shrink:0;">To</label>
                    <input type="date" id="drTo" class="form-control form-control-sm" style="font-size:12px;">
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-sm btn-primary flex-fill" onclick="ACIGantt.applyDateRange()" style="font-size:12px;">Apply</button>
                    <button class="btn btn-sm btn-outline-secondary flex-fill" onclick="ACIGantt.resetDateRange()" style="font-size:12px;">Reset</button>
                </div>
            </div>
        </div>

        <!-- Dependencies toggle -->
        <button class="btn btn-sm btn-outline-secondary active" onclick="ACIGantt.toggleLinks(this)" id="btnLinks">
            <i class="bi bi-arrow-right me-1"></i>Links
        </button>

        <!-- Critical Path toggle -->
        <button class="btn btn-sm btn-outline-danger" onclick="ACIGantt.toggleCriticalPath()" id="btnCritical">
            <i class="bi bi-diagram-3 me-1"></i>Critical Path
        </button>
        <!-- Bar Colors Legend -->
        <div class="dropdown">
            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown">
                <i class="bi bi-palette me-1"></i>Bar Colors
            </button>
            <ul class="dropdown-menu dropdown-menu-end p-2" style="min-width:210px;">
                <li class="mb-1 px-1" style="font-size:11px;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:.5px;">Status Colors</li>
                <li class="d-flex align-items-center gap-2 px-1 py-1">
                    <span style="width:28px;height:12px;border-radius:3px;background:#16a34a;display:inline-block;flex-shrink:0;"></span>
                    <span style="font-size:12px;color:#374151;">Complete (100%)</span>
                </li>
                <li class="d-flex align-items-center gap-2 px-1 py-1">
                    <span style="width:28px;height:12px;border-radius:3px;background:#3b82f6;display:inline-block;flex-shrink:0;"></span>
                    <span style="font-size:12px;color:#374151;">In Progress (1–99%)</span>
                </li>
                <li class="d-flex align-items-center gap-2 px-1 py-1">
                    <span style="width:28px;height:12px;border-radius:3px;background:#94a3b8;display:inline-block;flex-shrink:0;"></span>
                    <span style="font-size:12px;color:#374151;">Not Started (0%)</span>
                </li>
                <li class="d-flex align-items-center gap-2 px-1 py-1">
                    <span style="width:28px;height:12px;border-radius:3px;background:#ef4444;display:inline-block;flex-shrink:0;"></span>
                    <span style="font-size:12px;color:#374151;">Overdue</span>
                </li>
                <li><hr class="dropdown-divider my-1"></li>
                <li class="d-flex align-items-center gap-2 px-1 py-1">
                    <span style="width:28px;height:12px;border-radius:2px;background:#1e40af;display:inline-block;flex-shrink:0;"></span>
                    <span style="font-size:12px;color:#374151;">Summary / Phase</span>
                </li>
                <li><hr class="dropdown-divider my-1"></li>
                <li class="mb-1 px-1" style="font-size:11px;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:.5px;">Link Types</li>
                <li class="d-flex align-items-center gap-2 px-1 py-1">
                    <span style="width:28px;height:2px;background:#3b82f6;display:inline-block;flex-shrink:0;"></span>
                    <span style="font-size:12px;color:#374151;">FS (Finish→Start)</span>
                </li>
                <li class="d-flex align-items-center gap-2 px-1 py-1">
                    <span style="width:28px;height:2px;background:#16a34a;display:inline-block;flex-shrink:0;"></span>
                    <span style="font-size:12px;color:#374151;">SS (Start→Start)</span>
                </li>
                <li class="d-flex align-items-center gap-2 px-1 py-1">
                    <span style="width:28px;height:2px;background:#ea580c;display:inline-block;flex-shrink:0;"></span>
                    <span style="font-size:12px;color:#374151;">FF (Finish→Finish)</span>
                </li>
                <li class="d-flex align-items-center gap-2 px-1 py-1">
                    <span style="width:28px;height:2px;background:#9333ea;display:inline-block;flex-shrink:0;"></span>
                    <span style="font-size:12px;color:#374151;">SF (Start→Finish)</span>
                </li>
            </ul>
        </div>

        <!-- Freeze Baseline -->
        <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#freezeModal">
            <i class="bi bi-snow me-1"></i>Freeze Baseline
        </button>

        <!-- Import / Export -->
        <div class="dropdown">
            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown">
                <i class="bi bi-arrow-down-up me-1"></i>Import/Export
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
                <li>
                    <a class="dropdown-item"
                       asp-page="/Schedule/Import" asp-route-projectId="@Model.ProjectId">
                        <i class="bi bi-file-earmark-arrow-up me-2 text-primary"></i>Import MS Project XML
                    </a>
                </li>
                <li><hr class="dropdown-divider" /></li>
                <li><a class="dropdown-item" onclick="gantt.exportToPDF()">
                    <i class="bi bi-file-earmark-pdf me-2"></i>Export PDF
                </a></li>
                <li><a class="dropdown-item" onclick="exportToMsProjectXml()">
                    <i class="bi bi-file-earmark-spreadsheet me-2"></i>Export MS Project XML
                </a></li>
            </ul>
        </div>
    </div>
</div>

<!-- Gantt Chart Container -->
<div id="gantt-chart-wrapper" style="overflow-x:auto; width:100%;">
    <div id="gantt-chart"></div>
</div>

<!-- ─── Freeze Baseline Modal ────────────────────────────────── -->
<div class="modal fade" id="freezeModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-snow me-2 text-primary"></i>Freeze Baseline</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="Freeze">
                <div class="modal-body">
                    <input type="hidden" name="projectId" value="@Model.ProjectId" />
                    <div class="alert alert-info small mb-3">
                        <i class="bi bi-info-circle me-1"></i>
                        Freezing creates an immutable snapshot of the current Baseline Schedule.
                        This snapshot can then be submitted for Owner approval.
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Baseline Title *</label>
                        <input type="text" name="title" class="form-control" required
                               placeholder="e.g. Initial Baseline, Revised Baseline #2" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea name="description" class="form-control" rows="2"
                                  placeholder="Optional notes about this baseline version"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-snow me-1"></i>Freeze
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
const PROJECT_ID = @Model.ProjectId;

// ─── Gantt 초기화 ─────────────────────────────────────────
// ※ plugins()는 반드시 config/init 보다 먼저 호출해야 함
gantt.plugins({ critical_path: true, tooltip: true, marker: true, zoom: true });

// ── Zoom levels (init 전에 설정 필수) ─────────────────────────────────────────
gantt.ext.zoom.init({
    levels: [
        { name:"day",
          scale_height: 54, min_column_width: 70,
          scales: [{ unit:"week",  step:1, format:"%F %Y – W%W" },
                   { unit:"day",   step:1, format:"%d %D" }] },
        { name:"week",
          scale_height: 54, min_column_width: 50,
          scales: [{ unit:"month", step:1, format:"%F %Y" },
                   { unit:"week",  step:1, format:"W%W" }] },
        { name:"month",
          scale_height: 54, min_column_width: 100,
          scales: [{ unit:"year",  step:1, format:"%Y" },
                   { unit:"month", step:1, format:"%M" }] },
        { name:"quarter",
          scale_height: 54, min_column_width: 90,
          scales: [{ unit:"year",    step:1, format:"%Y" },
                   { unit:"quarter", step:1, format: d => "Q" + (Math.floor(d.getMonth()/3)+1) }] },
        { name:"year",
          scale_height: 54, min_column_width: 100,
          scales: [{ unit:"year",  step:1, format:"%Y" },
                   { unit:"month", step:3, format:"%M" }] }
    ],
    startIndex: 1,    // 초기: Week 뷰
    trigger:    "wheel",
    useKey:     "ctrlKey",
    element:    () => gantt.$root?.querySelector(".gantt_task") ?? gantt.$root
});

gantt.config.date_format = "%m-%d-%Y %H:%i";
gantt.config.work_time = true;
gantt.config.fit_tasks = true;
gantt.config.show_progress = true;
gantt.config.open_tree_initially = true;

// ── 그리드 컬럼 (Outbuild 스타일) ──────────────────────────
gantt.config.columns = [
    // ID (row number or WBS code)
    {
        name: "wbs", label: "ID", align: "center", width: 45, resize: true,
        template: t => {
            const wbs = t.wbs_code;
            if (wbs) return `<span style="font-size:11px;color:#6b7280">${wbs}</span>`;
            // fallback: global row index
            return `<span style="font-size:11px;color:#9ca3af">${gantt.getGlobalTaskIndex(t.id)}</span>`;
        }
    },
    // Task name (tree)
    {
        name: "text", label: "Task", tree: true, width: 220, resize: true,
        template: t => {
            const lvl = t.$level ?? 0;
            const prefix = t.type === 'project'   ? '— '
                         : t.type === 'milestone' ? '⬥ '
                         : '';
            if (t.type === 'milestone') {
                return `<span title="${t.text}" style="font-weight:600;color:#d97706">${prefix}${t.text}</span>`;
            }
            let style;
            if (lvl === 0)      style = 'font-weight:700;font-size:13px;color:#111827';
            else if (lvl === 1) style = 'color:#374151';
            else                style = 'color:#6b7280;font-size:11.5px';
            return `<span title="${t.text}" style="${style}">${prefix}${t.text}</span>`;
        }
    },
    // Actions (Outbuild: +, ✓, 🗑)
    {
        name: "actions", label: "Actions", align: "center", width: 75, resize: false,
        template: t => {
            if (t.type === 'project') {
                // 부모 → + 만 표시
                return `<span class="aci-act-btn" title="Add subtask" onclick="event.stopPropagation();gantt.createTask(null,${t.id})">
                    <i class="bi bi-plus" style="font-size:14px;color:#3b82f6"></i></span>`;
            }
            const isDone = (t.progress || 0) >= 1;
            const checkColor = isDone ? '#16a34a' : '#d1d5db';
            const checkIcon  = isDone ? 'bi-check-circle-fill' : 'bi-circle';
            return `<span class="aci-act-btn" title="Add task after" onclick="event.stopPropagation();gantt.createTask(null,${t.parent||0},gantt.getTaskIndex(${t.id})+1)">
                        <i class="bi bi-plus" style="font-size:14px;color:#3b82f6"></i></span>
                    <span class="aci-act-btn" title="${isDone?'Mark incomplete':'Mark complete'}" onclick="event.stopPropagation();aciToggleDone(${t.id})">
                        <i class="bi ${checkIcon}" style="font-size:12px;color:${checkColor}"></i></span>
                    <span class="aci-act-btn" title="Delete" onclick="event.stopPropagation();aciDeleteTask(${t.id})">
                        <i class="bi bi-trash3" style="font-size:11px;color:#d1d5db"></i></span>`;
        }
    },
    // Trade / Company
    {
        name: "trade_name", label: "Trade", align: "left", width: 90, resize: true,
        template: t => {
            if (!t.trade_name) return '';
            const c = t.color || '#6b7280';
            return `<span style="font-size:11px;color:${c};white-space:nowrap;overflow:hidden;text-overflow:ellipsis;display:block" title="${t.trade_name}">${t.trade_name}</span>`;
        }
    },
    // Start
    { name: "start_date", label: "Start", align: "center", width: 88, resize: true },
    // Duration
    { name: "duration", label: "Duration", align: "center", width: 60, resize: true,
        template: t => `<span style="font-size:12px">${t.duration} d</span>`
    },
    // End (dhtmlxGantt auto-computes end_date as Date)
    {
        name: "end_date_col", label: "End", align: "center", width: 88, resize: true,
        template: t => {
            const d = t.end_date;
            if (!d) return '';
            return gantt.templates.date_grid(d);
        }
    },
    // Progress
    {
        name: "progress", label: "Progress", align: "center", width: 65, resize: true,
        template: t => {
            const pct = Math.round(t.progress * 100);
            if (gantt.hasChild(t.id)) {
                const color = pct >= 100 ? '#86efac' : pct > 0 ? '#93c5fd' : '#cbd5e1';
                return `<span title="Auto-calculated from subtasks"
                    style="font-weight:400;font-style:italic;color:${color};font-size:12px;opacity:0.85">${pct}%</span>`;
            }
            const color = pct >= 100 ? '#16a34a' : pct >= 50 ? '#059669' : pct > 0 ? '#d97706' : '#9ca3af';
            return `<span style="font-weight:700;color:${color};font-size:12px">${pct}%</span>`;
        }
    },
    // Responsible (assigned person)
    {
        name: "responsible", label: "Responsible", align: "center", width: 85, resize: true,
        template: t => {
            if (!t.assigned_to_name) return '';
            // 이니셜 아바타 (Outbuild 스타일)
            const parts = t.assigned_to_name.split(' ').filter(Boolean);
            const initials = parts.length >= 2
                ? (parts[0][0] + parts[parts.length-1][0]).toUpperCase()
                : (parts[0] || '').substring(0,2).toUpperCase();
            const colors = ['#3b82f6','#16a34a','#d97706','#9333ea','#dc2626','#0891b2','#db2777'];
            const ci = (t.assigned_to_id || 0) % colors.length;
            return `<span title="${t.assigned_to_name}" style="display:inline-flex;align-items:center;justify-content:center;
                width:26px;height:26px;border-radius:50%;background:${colors[ci]};color:#fff;font-size:10px;font-weight:700;
                letter-spacing:.5px;cursor:default">${initials}</span>`;
        }
    },
    { name: "add", label: "", width: 36 }
];

