setTimeout(initColResize, 800);

// ── Error toast for DataProcessor failures ────────────────
function showDpError(msg) {
    const el = document.createElement('div');
    el.style.cssText = `
        position:fixed;bottom:24px;right:24px;z-index:99999;
        background:#fef2f2;color:#dc2626;border:1px solid #fca5a5;
        border-radius:8px;padding:12px 16px;font-size:12px;font-family:inherit;
        box-shadow:0 4px 16px rgba(0,0,0,.15);max-width:420px;line-height:1.5;
        white-space:pre-wrap;word-break:break-all;`;
    el.textContent = '⚠ Save failed: ' + msg;
    document.body.appendChild(el);
    setTimeout(() => el.remove(), 6000);
}

// DataProcessor — fetch 기반으로 Content-Type: application/json 보장
const dp = gantt.createDataProcessor(async function(entity, action, data, id) {
    const base = `/api/gantt/projects/${PROJECT_ID}`;
    const urls = {
        task: {
            create: { url: `${base}/task`,       method: 'POST'   },
            update: { url: `${base}/task/${id}`,  method: 'PUT'    },
            delete: { url: `${base}/task/${id}`,  method: 'DELETE' }
        },
        link: {
            create: { url: `${base}/link`,       method: 'POST'   },
            update: { url: `${base}/link/${id}`,  method: 'PUT'    },
            delete: { url: `${base}/link/${id}`,  method: 'DELETE' }
        }
    };
    const route = urls[entity]?.[action];
    if (!route) { showDpError(`Unknown route: ${entity}/${action}`); return Promise.reject(); }

    // dhtmlxGantt는 id/parent/duration 등을 문자열로 보낼 수 있음 → 서버 int 필드에 맞게 변환
    // toInt: NaN 또는 int32 범위 초과 시 null 반환 (신규 태스크 임시 ID가 타임스탬프일 수 있음)
    const INT32_MAX = 2147483647;
    const toInt  = v => { const n = parseInt(v); return (isNaN(n) || n > INT32_MAX || n < -INT32_MAX) ? null : n; };
    const toDbl  = v => { const n = parseFloat(v);return isNaN(n) ? 0    : n; };

    // start_date: dhtmlxGantt may pass a Date object → convert to formatted string
    const fmtDate = v => {
        if (!v) return '';
        if (v instanceof Date) return gantt.templates.format_date(v);
        return String(v);
    };

    const payload = action !== 'delete' ? {
        ...data,
        id:              action === 'create' ? 0 : (toInt(data.id) ?? 0),
        parent:          toInt(data.parent),
        duration:        toInt(data.duration)  ?? 1,
        progress:        toDbl(data.progress),
        sortOrder:       toInt(data.sortOrder) ?? 0,
        tradeId:         toInt(data.tradeId),
        source:          toInt(data.source)    ?? 0,
        target:          toInt(data.target)    ?? 0,
        start_date:      fmtDate(data.start_date),
        constraint_type: data.constraint_type || null,
        constraint_date: fmtDate(data.constraint_date),
    } : undefined;

    console.log(`[DP] ${action} ${entity}`, JSON.stringify(payload));

    try {
        const r = await fetch(route.url, {
            method:  route.method,
            headers: { 'Content-Type': 'application/json' },
            body:    payload ? JSON.stringify(payload) : undefined
        });

        if (!r.ok) {
            const errBody = await r.text().catch(() => '');
            console.error(`[DP] ${r.status} ${r.statusText}`, errBody);
            showDpError(`${r.status} ${r.statusText}\n${errBody.slice(0, 300)}`);
            throw new Error(`${r.status}`);
        }

        const res = await r.json();
        // After child task saved → recalculate parent display
        if (entity === 'task' && (action === 'update' || action === 'create')) {
            try {
                const t = gantt.getTask(action === 'create' ? (res.tid ?? id) : id);
                if (t?.parent) recalcParent(t.parent);
            } catch(e) {}
        }
        return { tid: res.tid ?? id, action: res.action ?? action };
    } catch(err) {
        console.error('[DataProcessor]', entity, action, err);
        throw err;
    }
});

// ── 우클릭 컨텍스트 메뉴 ─────────────────────────────────
(function() {
    const menu = document.createElement('div');
    menu.id = 'aci-ctx-menu';
    document.body.appendChild(menu);
    let ctxId = null;

    function countAll(taskId) {
        let n = 1;
        gantt.eachTask(() => n++, taskId);
        return n;
    }

    function renderMenu(taskId) {
        const hasKids = gantt.hasChild(taskId);
        const total   = hasKids ? countAll(taskId) : 1;
        let html = '';
        if (!hasKids) {
            html += `<div class="aci-ctx-item danger" id="ctx-del-single">
                        <i class="bi bi-trash3"></i> Delete task
                     </div>`;
        } else {
            html += `<div class="aci-ctx-item danger" id="ctx-del-subtree">
                        <i class="bi bi-trash3-fill"></i>
                        Delete with all subtasks <span style="color:#9ca3af;font-size:11px;margin-left:auto">${total}</span>
                     </div>`;
        }
        menu.innerHTML = html;

        document.getElementById('ctx-del-single')?.addEventListener('click', () => {
            menu.style.display = 'none';
            if (!confirm('Delete this task?')) return;
            gantt.deleteTask(ctxId);
        });

        document.getElementById('ctx-del-subtree')?.addEventListener('click', async () => {
            menu.style.display = 'none';
            const task = gantt.getTask(ctxId);
            if (!confirm(`Delete "${task.text}" and all ${total} subtasks?\nThis cannot be undone.`)) return;

            try {
                const res = await fetch(`/api/gantt/projects/${PROJECT_ID}/task/${ctxId}/subtree`, {
                    method: 'DELETE'
                });
                if (!res.ok) throw new Error(res.statusText);
                // 로컬 gantt에서도 제거
                gantt.eachTask(t => gantt.deleteTask(t.id), ctxId);
                gantt.deleteTask(ctxId);
            } catch(e) {
                alert('Delete failed: ' + e.message);
            }
        });
    }

    gantt.attachEvent('onContextMenu', function(taskId, linkId, e) {
        if (!taskId) { menu.style.display = 'none'; return true; }
        e.preventDefault();
        ctxId = taskId;
        renderMenu(taskId);

        // 화면 경계 처리
        menu.style.display = 'block';
        const mw = menu.offsetWidth, mh = menu.offsetHeight;
        const x = Math.min(e.clientX, window.innerWidth  - mw - 8);
        const y = Math.min(e.clientY, window.innerHeight - mh - 8);
        menu.style.left = x + 'px';
        menu.style.top  = y + 'px';
        return false;
    });

    document.addEventListener('click',       () => { menu.style.display = 'none'; });
    document.addEventListener('contextmenu', e => {
        if (!e.target.closest('#gantt-chart')) menu.style.display = 'none';
    });
})();

// ── 부모 태스크 편집 차단 ─────────────────────────────────
// 하위 태스크가 있는 부모는 시작일/기간/%를 직접 편집 불가
// (하위 태스크에 의해 자동 결정)

function showParentLockTip(e) {
    const tip = document.createElement('div');
    tip.textContent = 'Dates & progress are auto-calculated from subtasks';
    tip.style.cssText = `position:fixed;left:${e.clientX+10}px;top:${e.clientY+10}px;
        background:#1e293b;color:#fff;font-size:11px;padding:5px 10px;
        border-radius:5px;z-index:9999;pointer-events:none;white-space:nowrap;`;
    document.body.appendChild(tip);
    setTimeout(() => tip.remove(), 2200);
}

// 라이트박스(편집 팝업) 차단
gantt.attachEvent('onBeforeLightbox', function(id) {
    if (gantt.hasChild(id)) return false;
    return true;
});

// (onBeforeTaskDrag는 Procore-style 핸들러에서 이미 등록됨 — 중복 방지)

// ── % 더블클릭 팝업 ────────────────────────────────────────
(function() {
    // 팝업 DOM 한번만 생성
    const popup = document.createElement('div');
    popup.id = 'aci-progress-popup';
    popup.style.cssText = `
        display:none; position:fixed; z-index:9999;
        background:#fff; border:1px solid #e5e7eb;
        border-radius:10px; box-shadow:0 8px 24px rgba(0,0,0,.15);
        padding:16px 18px; min-width:220px;
        font-family:inherit; font-size:13px;
    `;
    popup.innerHTML = `
        <div style="font-weight:700;color:#111827;margin-bottom:12px;font-size:13px;">Edit Progress</div>
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
            <input id="aci-prog-slider" type="range" min="0" max="100" step="1"
                style="flex:1;accent-color:#3b82f6;cursor:pointer;">
            <input id="aci-prog-num" type="number" min="0" max="100"
                style="width:52px;text-align:center;border:1px solid #d1d5db;
                       border-radius:6px;padding:4px 6px;font-size:13px;font-weight:600;">
            <span style="color:#6b7280;">%</span>
        </div>
        <div style="display:flex;gap:8px;justify-content:flex-end;">
            <button id="aci-prog-cancel"
                style="padding:5px 14px;border:1px solid #d1d5db;border-radius:6px;
                       background:#f9fafb;cursor:pointer;font-size:12px;">Cancel</button>
            <button id="aci-prog-save"
                style="padding:5px 14px;border:none;border-radius:6px;
                       background:#3b82f6;color:#fff;cursor:pointer;font-size:12px;font-weight:600;">Save</button>
        </div>
    `;
    document.body.appendChild(popup);

    const slider = document.getElementById('aci-prog-slider');
    const numIn  = document.getElementById('aci-prog-num');
    let   currentTaskId = null;

    // 슬라이더 ↔ 숫자 동기화
    slider.addEventListener('input', () => { numIn.value = slider.value; });
    numIn.addEventListener('input',  () => {
        const v = Math.min(100, Math.max(0, parseInt(numIn.value) || 0));
        slider.value = v;
    });

    function showPopup(id, anchorEl) {
        currentTaskId = id;
        const task = gantt.getTask(id);
        const pct  = Math.round(task.progress * 100);
        slider.value = pct;
        numIn.value  = pct;

        // 셀 위치 기준으로 팝업 위치 결정
        const rect = anchorEl.getBoundingClientRect();
        popup.style.display = 'block';
        const pw = popup.offsetWidth;
        let left = rect.left - pw / 2 + rect.width / 2;
        left = Math.max(8, Math.min(left, window.innerWidth - pw - 8));
        popup.style.left = left + 'px';
        popup.style.top  = (rect.bottom + 6) + 'px';

        setTimeout(() => numIn.focus(), 50);
    }

    function hidePopup() {
        popup.style.display = 'none';
        currentTaskId = null;
    }

    function saveProgress() {
        if (currentTaskId === null) return;
        const val  = Math.min(100, Math.max(0, parseInt(numIn.value) || 0));
        const task = gantt.getTask(currentTaskId);
        task.progress = val / 100;
        gantt.updateTask(currentTaskId);
        hidePopup();
    }

    document.getElementById('aci-prog-save').addEventListener('click', saveProgress);
    document.getElementById('aci-prog-cancel').addEventListener('click', hidePopup);

    // Enter / Escape
    popup.addEventListener('keydown', ev => {
        if (ev.key === 'Enter')  { ev.preventDefault(); saveProgress(); }
        if (ev.key === 'Escape') { hidePopup(); }
    });

    // 팝업 외부 클릭 시 닫기
    document.addEventListener('mousedown', ev => {
        if (popup.style.display !== 'none' && !popup.contains(ev.target)) hidePopup();
    });

    // % 컬럼 더블클릭 이벤트
    gantt.attachEvent('onTaskDblClick', function(id, e) {
        const cell = (e.target || e.srcElement).closest('.gantt_cell');
        if (!cell) return true;
        if (cell.getAttribute('data-column-name') !== 'progress') return true;

        // 부모 태스크(하위 있음)는 % 편집 불가 — 하위 태스크에 의해 자동 결정
        if (gantt.hasChild(id)) {
            const rect = cell.getBoundingClientRect();
            const tip = document.createElement('div');
            tip.textContent = 'Auto-calculated from subtasks';
            tip.style.cssText = `position:fixed;left:${rect.left}px;top:${rect.bottom+4}px;
                background:#1e293b;color:#fff;font-size:11px;padding:4px 8px;
                border-radius:5px;z-index:9999;pointer-events:none;white-space:nowrap;`;
            document.body.appendChild(tip);
            setTimeout(() => tip.remove(), 2000);
            return false;
        }

        showPopup(id, cell);
        return false;
    });
})();

// ─── ACI Gantt Helper ─────────────────────────────────────
window.ACIGantt = {
    setScale(unit) {
        // zoom 레벨 인덱스와 동기화 (day=0, week=1, month=2, quarter=3, year=4)
        const levelMap = { day:0, week:1, month:2, quarter:3, year:4 };
        if (levelMap[unit] !== undefined) {
            gantt.ext.zoom.setLevel(levelMap[unit]);
        }
        ['scaleWeek','scaleMonth','scaleQuarter','scaleYear'].forEach(id => {
            const el = document.getElementById(id);
            if (el) el.classList.remove('active');
        });
        const active = document.getElementById('scale' + unit.charAt(0).toUpperCase() + unit.slice(1));
        if (active) active.classList.add('active');
    },

    fitToScreen() {
        // gantt.fit()은 GPL 미지원 — 태스크 날짜 범위로 직접 계산
        const tasks = [];
        gantt.eachTask(t => tasks.push(t));
        if (!tasks.length) return;
        const starts = tasks.map(t => +t.start_date).filter(Boolean);
        const ends   = tasks.map(t => +t.end_date).filter(Boolean);
        if (!starts.length) return;
        const pad = 7 * 24 * 3600 * 1000;  // 7일 여백
        gantt.config.start_date = new Date(Math.min(...starts) - pad);
        gantt.config.end_date   = new Date(Math.max(...ends)   + pad);
        gantt.render();
    },

    goToday() {
        gantt.showDate(new Date());
    },

    filterTasks(text) {
        const q = (text || '').toLowerCase().trim();
        gantt.filterTask = q
            ? (id, task) => task.text.toLowerCase().includes(q) || (task.wbs_code || '').toLowerCase().includes(q)
            : null;
        gantt.render();
    },

    clearFilter() {
        document.getElementById('taskSearch').value = '';
        gantt.filterTask = null;
        gantt.render();
    },

    toggleLinks(btn) {
        // show_links는 항상 true 유지 (DOM에서 제거하면 hover 감지 불가)
        document.getElementById('gantt-chart').classList.toggle('aci-links-visible');
        btn.classList.toggle('active');
        btn.classList.toggle('btn-outline-secondary');
        btn.classList.toggle('btn-secondary');
    },

    applyDateRange() {
        const from = document.getElementById('drFrom').value;
        const to   = document.getElementById('drTo').value;
        if (from) gantt.config.start_date = new Date(from);
        if (to)   gantt.config.end_date   = new Date(to);
        gantt.render();
        // 버튼 색상으로 필터 적용 중 표시
        const btn = document.getElementById('btnDateRange');
        if (from || to) btn.classList.add('btn-primary'), btn.classList.remove('btn-outline-secondary');
    },

    resetDateRange() {
        gantt.config.start_date = null;
        gantt.config.end_date   = null;
        document.getElementById('drFrom').value = '';
        document.getElementById('drTo').value   = '';
        gantt.render();
        const btn = document.getElementById('btnDateRange');
        btn.classList.remove('btn-primary');
        btn.classList.add('btn-outline-secondary');
    },

    toggleCriticalPath() {
        gantt.config.highlight_critical_path = !gantt.config.highlight_critical_path;
        gantt.render();
        document.getElementById('btnCritical').classList.toggle('btn-danger');
        document.getElementById('btnCritical').classList.toggle('btn-outline-danger');
    }
};

// ─── MS Project XML Export ────────────────────────────────
async function exportToMsProjectXml() {
    const res  = await fetch(`/api/gantt/projects/${PROJECT_ID}/export-xml`);
    if (!res.ok) { alert('Export failed'); return; }
    const blob = await res.blob();
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href     = url;
    a.download = `schedule_project_${PROJECT_ID}.xml`;
    a.click();
    URL.revokeObjectURL(url);
}
</script>
