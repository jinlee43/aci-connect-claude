@page
@using ACI.Web.Data.Entities
@using System.Globalization
@model ACI.Web.Pages.Safety.MyReportsModel
@{
    ViewData["Title"] = "Safety Report";
    ViewData["ActiveMenu"] = "safety-mine";
}

@functions {
    static (string Css, string Icon, string Label) StatusBadge(SafetyWkRepStatus s) => s switch
    {
        SafetyWkRepStatus.Draft          => ("bg-primary",            "bi-file-earmark-text", "Draft"),
        SafetyWkRepStatus.Staged         => ("bg-secondary",          "bi-file-earmark",      "Staged"),
        SafetyWkRepStatus.Reviewed       => ("bg-info text-dark",     "bi-eye-fill",          "Reviewed"),
        SafetyWkRepStatus.Approved       => ("bg-success",            "bi-shield-check",      "Approved"),
        SafetyWkRepStatus.NoWork         => ("bg-warning text-dark",  "bi-dash-circle",       "No Work"),
        SafetyWkRepStatus.NoWorkReviewed => ("bg-info text-dark",     "bi-dash-circle-fill",  "No Work (Rev)"),
        SafetyWkRepStatus.NoWorkApproved => ("bg-success",            "bi-dash-circle-fill",  "No Work (Apv)"),
        SafetyWkRepStatus.Voided         => ("bg-danger",             "bi-x-circle-fill",     "Voided"),
        _                                => ("bg-secondary",          "bi-question",          "Unknown"),
    };
}

<div class="aci-page-header">
    <div>
        <h1><i class="bi bi-clipboard2-check me-2" style="color:#fd7e14;"></i>Safety Report</h1>
        <p class="text-muted mb-0 small">Weekly safety reports for your assigned projects.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-page="/Safety/Reports" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-grid-3x3-gap me-1"></i>All Projects Grid
        </a>
    </div>
</div>

@if (TempData["Success"] is string ok)
{
    <div class="px-3 pb-1">
        <div class="alert alert-success alert-dismissible fade show py-2 small" role="alert">
            <i class="bi bi-check-circle me-1"></i>@ok
            <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert"></button>
        </div>
    </div>
}
@if (TempData["Error"] is string err)
{
    <div class="px-3 pb-1">
        <div class="alert alert-danger alert-dismissible fade show py-2 small" role="alert">
            <i class="bi bi-exclamation-triangle me-1"></i>@err
            <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert"></button>
        </div>
    </div>
}

<!-- ─── Date range filter ─────────────────────────────────────────── -->
<div class="px-3 pb-2">
    <form method="get" id="filterForm" class="d-flex align-items-center gap-2 flex-wrap">
        <label class="fw-semibold small">From</label>
        <input type="date" class="form-control form-control-sm" style="width:160px;"
               name="from" id="filterFrom" value="@Model.From" />
        <label class="fw-semibold small">To</label>
        <input type="date" class="form-control form-control-sm" style="width:160px;"
               name="to" id="filterTo" value="@Model.To" />
        <button type="submit" class="btn btn-sm btn-primary">
            <i class="bi bi-calendar-range me-1"></i>View
        </button>
        <div class="vr mx-1"></div>
        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="setWeeks(8)">8w</button>
        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="setWeeks(12)">12w</button>
        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="setWeeks(26)">26w</button>
        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="setWeeks(52)">1yr</button>
    </form>
</div>

<div class="p-3">

    @if (!Model.Rows.Any())
    {
        <div class="card p-5 text-center text-muted shadow-sm">
            <i class="bi bi-person-slash display-4 d-block mb-3"></i>
            <h5>No assigned projects found.</h5>
            <p>You must be assigned to a project team to submit safety reports.</p>
        </div>
    }
    else
    {
        <!-- ─── No Work modal ───────────────────────────────────────────── -->
        <div class="modal fade" id="noWorkModal" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <form method="post" asp-page-handler="MarkNoWork" id="nowork-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="projectId" id="nw-project-id" />
                        <input type="hidden" name="weekStart" id="nw-week-start" />
                        <input type="hidden" name="from"      value="@Model.From" />
                        <input type="hidden" name="to"        value="@Model.To" />
                        <div class="modal-header">
                            <h5 class="modal-title"><i class="bi bi-dash-circle me-2 text-warning"></i>Mark as No Work</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <p class="text-muted small mb-3">
                                Project: <strong id="nw-project-name"></strong> &nbsp;·&nbsp;
                                Week of: <strong id="nw-week-label"></strong>
                            </p>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Notes (optional)</label>
                                <textarea class="form-control" name="notes" rows="3"
                                          placeholder="Reason or remarks…" maxlength="500"></textarea>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-dash-circle me-1"></i>Mark No Work
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- ─── Review modal ─────────────────────────────────────────── -->
        @if (Model.CanReview)
        {
            <div class="modal fade" id="reviewModal" tabindex="-1">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <form method="post" asp-page-handler="Review">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="reportId" id="review-report-id" />
                            <input type="hidden" name="from"     value="@Model.From" />
                            <input type="hidden" name="to"       value="@Model.To" />
                            <div class="modal-header">
                                <h5 class="modal-title"><i class="bi bi-eye me-2"></i>Review Report</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Review Notes (optional)</label>
                                    <textarea class="form-control" name="notes" rows="3"
                                              placeholder="Optional notes…"></textarea>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button class="btn btn-secondary" data-bs-dismiss="modal" type="button">Cancel</button>
                                <button class="btn btn-info text-white" type="submit">
                                    <i class="bi bi-check2 me-1"></i>Mark Reviewed
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }

        <!-- ─── Flat list table ───────────────────────────────────────── -->
        <div class="card shadow-sm overflow-auto">
            <table id="reportTable" class="table table-sm table-hover mb-0 align-middle"
                   style="table-layout:fixed; width:100%;">
                <thead class="table-light">
                    <tr>
                        <th class="sortable" data-col="0" style="width:135px; cursor:pointer;">
                            Code <i class="bi bi-chevron-expand text-muted small"></i>
                        </th>
                        <th class="sortable text-center" data-col="1" style="width:55px; cursor:pointer;">
                            Wk <i class="bi bi-chevron-expand text-muted small"></i>
                        </th>
                        <th class="sortable" data-col="2" style="width:130px; cursor:pointer;">
                            Status <i class="bi bi-chevron-expand text-muted small"></i>
                        </th>
                        <th class="sortable" data-col="3" style="width:105px; cursor:pointer;">
                            Due Date <i class="bi bi-chevron-expand text-muted small"></i>
                        </th>
                        <th class="sortable" data-col="4" style="width:105px; cursor:pointer;">
                            Upload <i class="bi bi-chevron-expand text-muted small"></i>
                        </th>
                        <th class="sortable" data-col="5" style="width:120px; cursor:pointer;">
                            Submitter <i class="bi bi-chevron-expand text-muted small"></i>
                        </th>
                        <th style="width:70px;" class="text-center">File</th>
                        <th>Notes</th>
                        <th style="width:90px;" class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.Rows)
                    {
                        var rep        = row.Report;
                        var isLocked   = rep?.IsLocked ?? false;
                        var canEdit    = rep == null ? true
                                         : Model.CanUnreview ? !isLocked
                                         : rep.Status != SafetyWkRepStatus.Reviewed && !isLocked;
                        var wStr       = row.WeekStartDate.ToString("yyyy-MM-dd");
                        var wLabel     = row.WeekStartDate.ToString("MMM d, yyyy");
                        var rowMuted   = rep == null ? "text-muted" : "";

                        <tr class="@rowMuted">
                            <!-- Code -->
                            <td class="small fw-semibold" data-val="@row.ProjectCode"
                                style="overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"
                                title="@row.ProjectName">
                                @row.ProjectCode
                            </td>
                            <!-- Wk -->
                            <td class="small text-center" data-val="@row.WeekNumber.ToString("D2")">
                                @row.WeekNumber
                            </td>
                            <!-- Status -->
                            <td data-val="@(rep == null ? "zz" : rep.Status.ToString())">
                                @if (rep != null)
                                {
                                    var (css, icon, label) = StatusBadge(rep.Status);
                                    <span class="badge @css"
                                          style="font-size:.7rem; display:inline-block; width:115px; text-align:center;">
                                        <i class="bi @icon me-1"></i>@label
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted small">—</span>
                                }
                            </td>
                            <!-- Due Date -->
                            <td class="small" data-val="@row.DueDate.ToString("yyyy-MM-dd")">
                                @row.DueDate.ToString("MM/dd/yyyy")
                            </td>
                            <!-- Upload Date -->
                            <td class="small" data-val="@(rep?.UploadedAt?.ToString("yyyy-MM-ddTHH:mm") ?? "")">
                                @(rep?.UploadedAt?.ToString("MM/dd/yyyy") ?? "—")
                            </td>
                            <!-- Submitter -->
                            <td class="small" data-val="@(rep?.UploadedByName ?? "")"
                                style="overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                                @(rep?.UploadedByName ?? "—")
                            </td>
                            <!-- File -->
                            <td class="text-center">
                                @if (rep?.HasFile == true)
                                {
                                    <a href="/api/safety-reports/@rep.Id/file?inline=true"
                                       target="_blank"
                                       class="btn btn-outline-secondary btn-sm py-0 px-1"
                                       title="Preview">
                                        <i class="bi bi-eye" style="font-size:.8rem;"></i>
                                    </a>
                                    <a href="/api/safety-reports/@rep.Id/file"
                                       class="btn btn-outline-secondary btn-sm py-0 px-1"
                                       title="Download">
                                        <i class="bi bi-download" style="font-size:.8rem;"></i>
                                    </a>
                                }
                            </td>
                            <!-- Notes -->
                            <td class="small text-muted"
                                style="overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"
                                title="@rep?.Notes">
                                @(rep?.Notes ?? "")
                            </td>
                            <!-- Actions -->
                            <td class="text-center text-nowrap">
                                @if (rep == null)
                                {
                                    <!-- 업로드 → Report 페이지로 이동 -->
                                    <a href="/Safety/Report?projectId=@row.ProjectId&weekStart=@wStr&from=@Model.From&to=@Model.To"
                                       class="text-primary me-1" title="Upload Report">
                                        <i class="bi bi-upload" style="font-size:.85rem;"></i>
                                    </a>
                                    <!-- No Work -->
                                    <i class="bi bi-dash-circle text-warning"
                                       style="font-size:.85rem; cursor:pointer;"
                                       title="Mark as No Work"
                                       onclick="openNoWork(@row.ProjectId, '@row.ProjectCode — @row.ProjectName', '@wStr', '@wLabel')"></i>
                                }
                                else
                                {
                                    <!-- 파일 추가/수정 → Report 페이지로 이동 -->
                                    @if (canEdit)
                                    {
                                        <a href="/Safety/Report?reportId=@rep.Id&from=@Model.From&to=@Model.To"
                                           class="text-primary me-1" title="Add / Replace Files">
                                            <i class="bi bi-arrow-repeat" style="font-size:.85rem;"></i>
                                        </a>
                                    }
                                    <!-- Review -->
                                    @if (Model.CanReview && rep.Status == SafetyWkRepStatus.Draft)
                                    {
                                        <i class="bi bi-eye-fill text-info me-1"
                                           style="font-size:.85rem; cursor:pointer;"
                                           title="Mark Reviewed"
                                           onclick="openReview(@rep.Id)"></i>
                                    }
                                    <!-- Unreview -->
                                    @if (Model.CanUnreview && rep.Status == SafetyWkRepStatus.Reviewed)
                                    {
                                        <form method="post" asp-page-handler="Unreview"
                                              id="frm-unrev-@rep.Id" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="reportId" value="@rep.Id" />
                                            <input type="hidden" name="from" value="@Model.From" />
                                            <input type="hidden" name="to"   value="@Model.To" />
                                            <i class="bi bi-arrow-counterclockwise text-secondary me-1"
                                               style="font-size:.85rem; cursor:pointer;"
                                               title="Clear Review"
                                               onclick="confirmAction('frm-unrev-@rep.Id','Clear Review','Clear the review status?')"></i>
                                        </form>
                                    }
                                    <!-- Delete -->
                                    @if (canEdit && rep.Status != SafetyWkRepStatus.Approved)
                                    {
                                        <form method="post" asp-page-handler="Delete"
                                              id="frm-del-@rep.Id" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="reportId" value="@rep.Id" />
                                            <input type="hidden" name="from" value="@Model.From" />
                                            <input type="hidden" name="to"   value="@Model.To" />
                                            <i class="bi bi-trash3 text-danger"
                                               style="font-size:.85rem; cursor:pointer;"
                                               title="Delete"
                                               onclick="confirmAction('frm-del-@rep.Id','Delete Report','Delete this report?')"></i>
                                        </form>
                                    }
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</div>

@section Scripts {
<script>
// ── Date filter quick buttons ─────────────────────────────────────────────
function getMonday(date) {
    var d   = new Date(date);
    var day = d.getDay();
    d.setDate(d.getDate() - ((day === 0) ? 6 : day - 1));
    return d;
}
function toDateInputValue(d) {
    return d.getFullYear() + '-'
         + String(d.getMonth() + 1).padStart(2,'0') + '-'
         + String(d.getDate()).padStart(2,'0');
}
function setWeeks(weeks) {
    var toVal  = document.getElementById('filterTo').value;
    var toDate = toVal ? new Date(toVal + 'T00:00:00') : new Date();
    var toMon  = getMonday(toDate);
    var fromDate = new Date(toMon);
    fromDate.setDate(fromDate.getDate() - (weeks - 1) * 7);
    document.getElementById('filterFrom').value = toDateInputValue(fromDate);
    document.getElementById('filterForm').submit();
}

// ── No Work modal ────────────────────────────────────────────────────────
const noWorkModal = new bootstrap.Modal(document.getElementById('noWorkModal'));
function openNoWork(projectId, projectName, weekStart, weekLabel) {
    document.getElementById('nw-project-id').value   = projectId;
    document.getElementById('nw-week-start').value   = weekStart;
    document.getElementById('nw-project-name').textContent = projectName;
    document.getElementById('nw-week-label').textContent   = weekLabel;
    // notes textarea 초기화
    document.querySelector('#nowork-form textarea[name="notes"]').value = '';
    noWorkModal.show();
}


@if (Model.CanReview)
{
    <text>
// ── Review modal ──────────────────────────────────────────────────────────
const reviewModal = new bootstrap.Modal(document.getElementById('reviewModal'));
function openReview(reportId) {
    document.getElementById('review-report-id').value = reportId;
    reviewModal.show();
}
    </text>
}

function getAntiForgeryToken() {
    return document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
}

// ── Column sort ───────────────────────────────────────────────────────────
(function () {
    const table  = document.getElementById('reportTable');
    const tbody  = table.querySelector('tbody');
    let sortCol  = 3;    // Due Date 기본 정렬
    let sortAsc  = false;

    function sortRows(col, asc) {
        const rows = Array.from(tbody.querySelectorAll('tr'));
        rows.sort((a, b) => {
            const av = a.cells[col]?.dataset.val ?? '';
            const bv = b.cells[col]?.dataset.val ?? '';
            return asc ? av.localeCompare(bv) : bv.localeCompare(av);
        });
        rows.forEach(r => tbody.appendChild(r));
    }

    function updateIcons(activeCol, asc) {
        table.querySelectorAll('th.sortable').forEach(th => {
            const i = th.querySelector('i');
            const col = parseInt(th.dataset.col);
            if (col === activeCol) {
                i.className = asc ? 'bi bi-chevron-up text-primary small'
                                  : 'bi bi-chevron-down text-primary small';
            } else {
                i.className = 'bi bi-chevron-expand text-muted small';
            }
        });
    }

    // 초기 정렬 아이콘
    updateIcons(sortCol, sortAsc);

    table.querySelectorAll('th.sortable').forEach(th => {
        th.addEventListener('click', () => {
            const col = parseInt(th.dataset.col);
            if (col === sortCol) { sortAsc = !sortAsc; }
            else { sortCol = col; sortAsc = true; }
            sortRows(sortCol, sortAsc);
            updateIcons(sortCol, sortAsc);
        });
    });
})();
</script>
}
